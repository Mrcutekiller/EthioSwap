      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: 'Manrope', sans-serif;\n    background: #010B13;\n    color: #E2E8F0;\n    min-height: 100vh;\n    position: relative;\n    overflow-x: hidden;\n  }\n\n  .top-header {\n    position: sticky;\n    top: 0;\n    height: 64px;\n    background: rgba(6,15,28,0.95);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border-bottom: 1px solid #0F2035;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 0 16px;\n    z-index: 100;\n  }\n\n  .logo {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n  .logo-shield {\n    width: 32px;\n    height: 32px;\n    background: linear-gradient(135deg, #FFD700, #FFE082);\n    border-radius: 8px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-family: 'Space Grotesk', sans-serif;\n    font-weight: 900;\n    font-size: 13px;\n    color: #010B13;\n    box-shadow: 0 0 12px rgba(255,215,0,0.35);\n  }\n  .logo-name {\n    font-family: 'Space Grotesk', sans-serif;\n    font-weight: 800;\n    font-size: 16px;\n    background: linear-gradient(135deg, #FFD700, #FFE082);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    background-clip: text;\n  }\n\n  .balance-pill {\n    position: absolute;\n    left: 50%;\n    transform: translateX(-50%);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    background: rgba(15,32,53,0.8);\n    border: 1px solid rgba(255,215,0,0.15);\n    border-radius: 20px;\n    padding: 6px 14px;\n  }\n  .balance-usd {\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 12px;\n    font-weight: 700;\n    color: #FFD700;\n    line-height: 1.1;\n    text-shadow: 0 0 10px rgba(255,215,0,0.4);\n  }\n  .balance-etb {\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 10px;\n    font-weight: 500;\n    color: #00D4A0;\n    line-height: 1.1;\n  }\n\n  .header-actions {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .icon-btn {\n    width: 36px;\n    height: 36px;\n    border-radius: 10px;\n    background: rgba(15,32,53,0.6);\n    border: 1px solid #0F2035;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: #6B8AAA;\n    cursor: pointer;\n    position: relative;\n    font-size: 18px;\n    transition: all 0.2s;\n  }\n  .icon-btn:hover { background: rgba(15,32,53,0.9); color: #E2E8F0; }\n  .notif-badge {\n    position: absolute;\n    top: -4px;\n    right: -4px;\n    background: #EF4444;\n    color: #fff;\n    border-radius: 99px;\n    min-width: 16px;\n    height: 16px;\n    font-size: 9px;\n    font-weight: 800;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 0 3px;\n    border: 2px solid #010B13;\n    animation: badgePulse 2s ease-in-out infinite;\n  }\n  @keyframes badgePulse {\n    0%,100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.5); }\n    50% { box-shadow: 0 0 0 4px rgba(239,68,68,0); }\n  }\n\n  .page-content {\n    padding: 16px 16px 180px;\n  }\n\n  .buy-sell-toggle {\n    display: flex;\n    background: #0D1520;\n    border: 1px solid #0F2035;\n    border-radius: 50px;\n    padding: 4px;\n    margin-bottom: 16px;\n  }\n  .toggle-btn {\n    flex: 1;\n    padding: 10px;\n    border-radius: 46px;\n    border: none;\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    cursor: pointer;\n    transition: all 0.2s;\n    color: #4A6380;\n    background: transparent;\n  }\n  .toggle-btn.buy-active {\n    background: linear-gradient(135deg, rgba(0,212,160,0.2), rgba(0,212,160,0.1));\n    color: #00D4A0;\n    border: 1px solid rgba(0,212,160,0.3);\n    box-shadow: 0 0 15px rgba(0,212,160,0.15);\n  }\n\n  .listing-card {\n    background: #060F1C;\n    border: 1px solid #0F2035;\n    border-radius: 20px;\n    padding: 16px;\n    margin-bottom: 12px;\n    transition: transform 0.2s, border-color 0.2s;\n  }\n  .listing-card:hover {\n    transform: translateY(-2px);\n    border-color: rgba(255,215,0,0.12);\n  }\n\n  .card-top {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 12px;\n  }\n  .merchant-info {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n  .merchant-avatar {\n    width: 36px;\n    height: 36px;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-family: 'Space Grotesk', sans-serif;\n    font-weight: 700;\n    font-size: 13px;\n    color: #fff;\n    flex-shrink: 0;\n  }\n  .merchant-name {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    color: #E2E8F0;\n  }\n  .merchant-sub {\n    font-size: 11px;\n    color: #4A6380;\n    display: flex;\n    align-items: center;\n    gap: 4px;\n    margin-top: 2px;\n  }\n  .rating {\n    color: #FFD700;\n    font-size: 11px;\n    font-weight: 700;\n  }\n  .rep-badge {\n    background: rgba(0,212,160,0.1);\n    color: #00D4A0;\n    border: 1px solid rgba(0,212,160,0.2);\n    border-radius: 99px;\n    padding: 2px 8px;\n    font-size: 10px;\n    font-weight: 700;\n  }\n\n  .rate-display {\n    text-align: center;\n    margin: 10px 0;\n    padding: 10px 0;\n    border-top: 1px solid rgba(15,32,53,0.8);\n    border-bottom: 1px solid rgba(15,32,53,0.8);\n  }\n  .rate-label {\n    font-size: 10px;\n    color: #4A6380;\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n    margin-bottom: 4px;\n  }\n  .rate-value {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 20px;\n    font-weight: 800;\n    color: #FFD700;\n    text-shadow: 0 0 20px rgba(255,215,0,0.3);\n  }\n\n  .card-footer {\n    margin-top: 12px;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .limits-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n  }\n  .limits-text {\n    font-size: 11px;\n    color: #4A6380;\n  }\n  .payment-badges {\n    display: flex;\n    gap: 6px;\n  }\n  .badge-cbe {\n    background: rgba(34,197,94,0.12);\n    color: #4ade80;\n    border: 1px solid rgba(34,197,94,0.2);\n    border-radius: 99px;\n    padding: 3px 8px;\n    font-size: 10px;\n    font-weight: 700;\n  }\n  .badge-telebirr {\n    background: rgba(59,130,246,0.12);\n    color: #60a5fa;\n    border: 1px solid rgba(59,130,246,0.2);\n    border-radius: 99px;\n    padding: 3px 8px;\n    font-size: 10px;\n    font-weight: 700;\n  }\n  .badge-dashen {\n    background: rgba(168,85,247,0.12);\n    color: #c084fc;\n    border: 1px solid rgba(168,85,247,0.2);\n    border-radius: 99px;\n    padding: 3px 8px;\n    font-size: 10px;\n    font-weight: 700;\n  }\n\n  .buy-btn {\n    width: 100%;\n    padding: 12px;\n    border-radius: 14px;\n    border: none;\n    background: linear-gradient(135deg, rgba(0,212,160,0.18), rgba(0,212,160,0.1));\n    color: #00D4A0;\n    border: 1px solid rgba(0,212,160,0.25);\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 6px;\n    transition: all 0.2s;\n  }\n  .buy-btn:hover {\n    background: linear-gradient(135deg, rgba(0,212,160,0.3), rgba(0,212,160,0.15));\n    box-shadow: 0 0 20px rgba(0,212,160,0.2);\n  }\n\n  /* FAB */\n  .fab {\n    position: fixed;\n    bottom: 100px;\n    right: 20px;\n    width: 52px;\n    height: 52px;\n    border-radius: 50%;\n    background: linear-gradient(135deg, #FFD700, #FFE082);\n    border: none;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: #010B13;\n    font-size: 24px;\n    cursor: pointer;\n    box-shadow: 0 4px 20px rgba(255,215,0,0.45);\n    z-index: 50;\n    transition: transform 0.2s;\n  }\n  .fab:hover { transform: scale(1.08); }\n\n  /* Bottom Nav */\n  .bottom-nav {\n    position: fixed;\n    bottom: 12px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: calc(100% - 24px);\n    max-width: 364px;\n    height: 64px;\n    background: rgba(6,12,22,0.92);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n    border: 1px solid rgba(255,255,255,0.07);\n    border-radius: 50px;\n    display: flex;\n    align-items: center;\n    justify-content: space-around;\n    padding: 0 8px;\n    z-index: 200;\n    box-shadow: 0 8px 32px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,215,0,0.04);\n  }\n\n  .nav-item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    gap: 3px;\n    flex: 1;\n    height: 100%;\n    cursor: pointer;\n    position: relative;\n    color: #4A6380;\n    transition: color 0.2s;\n    font-size: 18px;\n  }\n  .nav-item span {\n    font-family: 'Manrope', sans-serif;\n    font-size: 8.5px;\n    font-weight: 700;\n    letter-spacing: 0.01em;\n  }\n  .nav-item.active {\n    color: #FFD700;\n  }\n  .nav-item.active::before {\n    content: '';\n    position: absolute;\n    inset: 8px 4px;\n    background: rgba(255,215,0,0.1);\n    border-radius: 16px;\n    border: 1px solid rgba(255,215,0,0.15);\n    box-shadow: 0 0 12px rgba(255,215,0,0.12);\n  }\n  .nav-badge {\n    position: absolute;\n    top: 6px;\n    right: 10%;\n    background: #EF4444;\n    color: #fff;\n    border-radius: 99px;\n    min-width: 14px;\n    height: 14px;\n    font-size: 8px;\n    font-weight: 800;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 0 3px;\n    border: 1.5px solid #010B13;\n  }\n</style>\n\n\n<header class=\"top-header\" data-kid=\"1\">\n  <div class=\"logo\" data-kid=\"2\">\n    <div class=\"logo-shield\" data-kid=\"3\">ES</div>\n    <span class=\"logo-name\" data-kid=\"4\">EthioSwap</span>\n  </div>\n\n  <div class=\"balance-pill\" data-kid=\"5\">\n    <span class=\"balance-usd\" data-kid=\"6\">$1,250.00 USD</span>\n    <span class=\"balance-etb\" data-kid=\"7\">≈ 237,500 ETB</span>\n  </div>\n\n  <div class=\"header-actions\" data-kid=\"8\">\n    <button class=\"icon-btn\" data-kid=\"9\">\n      <i class=\"ti ti-bell\" data-kid=\"10\"></i>\n      <span class=\"notif-badge\" data-kid=\"11\">3</span>\n    </button>\n    <button class=\"icon-btn\" style=\"color: rgba(239,68,68,0.7); background: rgba(239,68,68,0.06); border-color: rgba(239,68,68,0.15);\" data-kid=\"12\">\n      <i class=\"ti ti-logout\" data-kid=\"13\"></i>\n    </button>\n  </div>\n</header>\n\n\n<div class=\"page-content\" data-kid=\"14\">\n  \n  <div class=\"buy-sell-toggle\" data-kid=\"15\">\n    <button class=\"toggle-btn buy-active\" data-kid=\"16\">\n      <i class=\"ti ti-trending-up\" style=\"margin-right:6px; font-size:14px;\" data-kid=\"17\"></i>Buy Crypto\n    </button>\n    <button class=\"toggle-btn\" data-kid=\"18\">\n      <i class=\"ti ti-trending-down\" style=\"margin-right:6px; font-size:14px;\" data-kid=\"19\"></i>Sell Crypto\n    </button>\n  </div>\n\n  \n  <div class=\"listing-card\" data-kid=\"20\">\n    <div class=\"card-top\" data-kid=\"21\">\n      <div class=\"merchant-info\" data-kid=\"22\">\n        <div class=\"merchant-avatar\" style=\"background: linear-gradient(135deg, #1d4ed8, #3b82f6);\" data-kid=\"23\">AT</div>\n        <div data-kid=\"24\">\n          <div class=\"merchant-name\" data-kid=\"25\">Abebe T.</div>\n          <div class=\"merchant-sub\" data-kid=\"26\">\n            <span class=\"rating\" data-kid=\"27\">★ 4.8</span>\n            <span data-kid=\"28\">· 124 trades</span>\n          </div>\n        </div>\n      </div>\n      <span class=\"rep-badge\" data-kid=\"29\">99% Rep</span>\n    </div>\n    <div class=\"rate-display\" data-kid=\"30\">\n      <div class=\"rate-label\" data-kid=\"31\">Exchange Rate</div>\n      <div class=\"rate-value\" data-kid=\"32\">1 USD = 120 ETB</div>\n    </div>\n    <div class=\"card-footer\" data-kid=\"33\">\n      <div class=\"limits-row\" data-kid=\"34\">\n        <span class=\"limits-text\" data-kid=\"35\">Available: <b style=\"color:#E2E8F0\" data-kid=\"36\">1,250 USDT</b></span>\n        <div class=\"payment-badges\" data-kid=\"37\">\n          <span class=\"badge-cbe\" data-kid=\"38\">CBE</span>\n          <span class=\"badge-telebirr\" data-kid=\"39\">Telebirr</span>\n        </div>\n      </div>\n      <div style=\"font-size:11px; color:#4A6380;\" data-kid=\"40\">Limits: Min $10 — Max $500</div>\n      <button class=\"buy-btn\" data-kid=\"41\"><i class=\"ti ti-arrows-exchange\" data-kid=\"42\"></i> Buy USDT</button>\n    </div>\n  </div>\n\n  \n  <div class=\"listing-card\" data-kid=\"43\">\n    <div class=\"card-top\" data-kid=\"44\">\n      <div class=\"merchant-info\" data-kid=\"45\">\n        <div class=\"merchant-avatar\" style=\"background: linear-gradient(135deg, #be185d, #ec4899);\" data-kid=\"46\">SM</div>\n        <div data-kid=\"47\">\n          <div class=\"merchant-name\" data-kid=\"48\">Sara M.</div>\n          <div class=\"merchant-sub\" data-kid=\"49\">\n            <span class=\"rating\" data-kid=\"50\">★ 4.6</span>\n            <span data-kid=\"51\">· 87 trades</span>\n          </div>\n        </div>\n      </div>\n      <span class=\"rep-badge\" style=\"background:rgba(255,215,0,0.08); color:#FFE082; border-color:rgba(255,215,0,0.15);\" data-kid=\"52\">97% Rep</span>\n    </div>\n    <div class=\"rate-display\" data-kid=\"53\">\n      <div class=\"rate-label\" data-kid=\"54\">Exchange Rate</div>\n      <div class=\"rate-value\" data-kid=\"55\">1 USD = 119.5 ETB</div>\n    </div>\n    <div class=\"card-footer\" data-kid=\"56\">\n      <div class=\"limits-row\" data-kid=\"57\">\n        <span class=\"limits-text\" data-kid=\"58\">Available: <b style=\"color:#E2E8F0\" data-kid=\"59\">800 USDT</b></span>\n        <div class=\"payment-badges\" data-kid=\"60\">\n          <span class=\"badge-dashen\" data-kid=\"61\">Dashen</span>\n          <span class=\"badge-cbe\" style=\"background:rgba(251,191,36,0.12); color:#fbbf24; border-color:rgba(251,191,36,0.2);\" data-kid=\"62\">Awash</span>\n        </div>\n      </div>\n      <div style=\"font-size:11px; color:#4A6380;\" data-kid=\"63\">Limits: Min $20 — Max $300</div>\n      <button class=\"buy-btn\" data-kid=\"64\"><i class=\"ti ti-arrows-exchange\" data-kid=\"65\"></i> Buy USDT</button>\n    </div>\n  </div>\n\n  \n  <div class=\"listing-card\" data-kid=\"66\">\n    <div class=\"card-top\" data-kid=\"67\">\n      <div class=\"merchant-info\" data-kid=\"68\">\n        <div class=\"merchant-avatar\" style=\"background: linear-gradient(135deg, #c2410c, #f97316);\" data-kid=\"69\">YK</div>\n        <div data-kid=\"70\">\n          <div class=\"merchant-name\" data-kid=\"71\">Yonas K.</div>\n          <div class=\"merchant-sub\" data-kid=\"72\">\n            <span class=\"rating\" data-kid=\"73\">★ 4.9</span>\n            <span data-kid=\"74\">· 215 trades</span>\n          </div>\n        </div>\n      </div>\n      <span class=\"rep-badge\" style=\"background:rgba(0,212,160,0.12); color:#34EAC4; border-color:rgba(0,212,160,0.25); box-shadow:0 0 8px rgba(0,212,160,0.1);\" data-kid=\"75\">100% ✓</span>\n    </div>\n    <div class=\"rate-display\" data-kid=\"76\">\n      <div class=\"rate-label\" data-kid=\"77\">Exchange Rate</div>\n      <div class=\"rate-value\" data-kid=\"78\">1 USD = 120.5 ETB</div>\n    </div>\n    <div class=\"card-footer\" data-kid=\"79\">\n      <div class=\"limits-row\" data-kid=\"80\">\n        <span class=\"limits-text\" data-kid=\"81\">Available: <b style=\"color:#E2E8F0\" data-kid=\"82\">2,000 USDT</b></span>\n        <div class=\"payment-badges\" data-kid=\"83\">\n          <span class=\"badge-cbe\" data-kid=\"84\">CBE</span>\n        </div>\n      </div>\n      <div style=\"font-size:11px; color:#4A6380;\" data-kid=\"85\">Limits: Min $50 — Max $1,000</div>\n      <button class=\"buy-btn\" data-kid=\"86\"><i class=\"ti ti-arrows-exchange\" data-kid=\"87\"></i> Buy USDT</button>\n    </div>\n  </div>\n</div>\n\n\n<button class=\"fab\" data-kid=\"88\">\n  <i class=\"ti ti-plus\" style=\"font-size:22px;\" data-kid=\"89\"></i>\n</button>\n\n\n<nav class=\"bottom-nav\" data-kid=\"90\">\n  <div class=\"nav-item active\" data-kid=\"91\">\n    <i class=\"ti ti-arrows-exchange\" data-kid=\"92\"></i>\n    <span data-kid=\"93\">Trade</span>\n  </div>\n  <div class=\"nav-item\" data-kid=\"94\">\n    <i class=\"ti ti-wallet\" data-kid=\"95\"></i>\n    <span data-kid=\"96\">Wallet</span>\n  </div>\n  <div class=\"nav-item\" data-kid=\"97\">\n    <i class=\"ti ti-messages\" data-kid=\"98\"></i>\n    <span class=\"nav-badge\" data-kid=\"99\">2</span>\n    <span data-kid=\"100\">Trades</span>\n  </div>\n  <div class=\"nav-item\" data-kid=\"101\">\n    <i class=\"ti ti-history\" data-kid=\"102\"></i>\n    <span data-kid=\"103\">History</span>\n  </div>\n  <div class=\"nav-item\" data-kid=\"104\">\n    <i class=\"ti ti-gift\" data-kid=\"105\"></i>\n    <span data-kid=\"106\">Invite</span>\n  </div>\n  <div class=\"nav-item\" data-kid=\"107\">\n    <i class=\"ti ti-trophy\" data-kid=\"108\"></i>\n    <span data-kid=\"109\">Ranks</span>\n  </div>\n  <div class=\"nav-item\" data-kid=\"110\">\n    <i class=\"ti ti-user\" data-kid=\"111\"></i>\n    <span data-kid=\"112\">Profile</span>\n  </div>\n  <div class=\"nav-item\" data-kid=\"113\">\n    <i class=\"ti ti-settings\" data-kid=\"114\"></i>\n    <span data-kid=\"115\">Settings</span>\n  </div>\n</nav>\n",
