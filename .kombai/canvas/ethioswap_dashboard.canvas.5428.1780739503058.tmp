      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n* { box-sizing: border-box; margin: 0; padding: 0; }\n\nbody {\n  font-family: 'Manrope', sans-serif;\n  background: #010B13;\n  color: #E2E8F0;\n  min-height: 100vh;\n}\n\n.page {\n  background: #010B13;\n  min-height: 100vh;\n  padding: 20px 16px 100px;\n  position: relative;\n  overflow: hidden;\n}\n\n.bg-glow {\n  position: absolute;\n  border-radius: 50%;\n  filter: blur(80px);\n  pointer-events: none;\n  z-index: 0;\n  opacity: 0.22;\n}\n.bg-glow-1 {\n  width: 280px; height: 280px;\n  top: -60px; right: -60px;\n  background: radial-gradient(circle, rgba(99,102,241,0.25) 0%, transparent 70%);\n}\n.bg-glow-2 {\n  width: 260px; height: 260px;\n  bottom: 20%; left: -60px;\n  background: radial-gradient(circle, rgba(255,215,0,0.15) 0%, transparent 70%);\n}\n\n.content { position: relative; z-index: 1; }\n\n/* Hero Card */\n.hero-card {\n  position: relative;\n  border-radius: 24px;\n  padding: 22px 20px;\n  overflow: hidden;\n  margin-bottom: 18px;\n  background: linear-gradient(135deg, #060F1C 0%, #0A0E1A 100%);\n  border: 1px solid rgba(99,102,241,0.3);\n  box-shadow: 0 0 30px rgba(99,102,241,0.08), 0 0 60px rgba(255,215,0,0.04);\n}\n\n/* Hex pattern overlay via pseudo/css */\n.hex-pattern {\n  position: absolute;\n  inset: 0;\n  background-image:\n    repeating-linear-gradient(\n      60deg,\n      transparent,\n      transparent 18px,\n      rgba(99,102,241,0.04) 18px,\n      rgba(99,102,241,0.04) 19px\n    ),\n    repeating-linear-gradient(\n      -60deg,\n      transparent,\n      transparent 18px,\n      rgba(99,102,241,0.04) 18px,\n      rgba(99,102,241,0.04) 19px\n    ),\n    repeating-linear-gradient(\n      0deg,\n      transparent,\n      transparent 18px,\n      rgba(99,102,241,0.04) 18px,\n      rgba(99,102,241,0.04) 19px\n    );\n  pointer-events: none;\n  z-index: 0;\n}\n\n.hero-gradient-top {\n  position: absolute;\n  top: -40px; left: -40px;\n  width: 180px; height: 180px;\n  background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%);\n  pointer-events: none;\n  z-index: 0;\n  filter: blur(30px);\n}\n.hero-gradient-right {\n  position: absolute;\n  top: -20px; right: -30px;\n  width: 150px; height: 150px;\n  background: radial-gradient(circle, rgba(255,215,0,0.12) 0%, transparent 70%);\n  pointer-events: none;\n  z-index: 0;\n  filter: blur(25px);\n}\n\n.hero-content { position: relative; z-index: 1; }\n\n.hero-title-row {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  margin-bottom: 6px;\n}\n.hero-title-row .emoji { font-size: 22px; }\n.hero-title-row h1 {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 22px;\n  font-weight: 800;\n  color: #E2E8F0;\n  letter-spacing: -0.03em;\n}\n\n.hero-subtitle {\n  font-size: 12px;\n  color: #6B8AAA;\n  line-height: 1.5;\n  margin-bottom: 18px;\n  max-width: 280px;\n}\n\n/* Referral link */\n.ref-link-row {\n  display: flex;\n  gap: 8px;\n  margin-bottom: 16px;\n  align-items: center;\n}\n.ref-link-input {\n  flex: 1;\n  background: rgba(1,11,19,0.7);\n  border: 1px solid #0F2035;\n  border-radius: 12px;\n  padding: 9px 12px;\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 11px;\n  color: #6B8AAA;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n.ref-copy-btn {\n  background: linear-gradient(135deg, #FFD700, #FFE082);\n  color: #010B13;\n  border: none;\n  border-radius: 12px;\n  padding: 9px 14px;\n  font-size: 12px;\n  font-weight: 700;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  gap: 5px;\n  font-family: 'Manrope', sans-serif;\n  white-space: nowrap;\n  box-shadow: 0 4px 12px rgba(255,215,0,0.2);\n}\n\n/* Social share */\n.social-row {\n  display: flex;\n  gap: 10px;\n  align-items: center;\n}\n.social-label {\n  font-size: 11px;\n  color: #4A6380;\n  font-weight: 600;\n  margin-right: 2px;\n}\n.social-btn {\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  border: none;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 16px;\n  cursor: pointer;\n  transition: transform 0.15s;\n  font-weight: 700;\n}\n.social-btn:hover { transform: scale(1.08); }\n.social-wa { background: rgba(37,211,102,0.15); color: #25D366; border: 1px solid rgba(37,211,102,0.25); }\n.social-tg { background: rgba(0,136,204,0.15); color: #0088cc; border: 1px solid rgba(0,136,204,0.25); }\n.social-link { background: rgba(255,215,0,0.12); color: #FFD700; border: 1px solid rgba(255,215,0,0.25); }\n\n/* Stats Grid */\n.stats-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 10px;\n  margin-bottom: 20px;\n}\n.stat-tile {\n  border-radius: 18px;\n  padding: 14px 10px;\n  text-align: center;\n  border: 1px solid;\n}\n.stat-tile.gold-tint {\n  background: linear-gradient(135deg, rgba(255,215,0,0.07), rgba(255,215,0,0.02));\n  border-color: rgba(255,215,0,0.2);\n}\n.stat-tile.teal-tint {\n  background: linear-gradient(135deg, rgba(0,212,160,0.07), rgba(0,212,160,0.02));\n  border-color: rgba(0,212,160,0.2);\n}\n.stat-tile.indigo-tint {\n  background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(99,102,241,0.02));\n  border-color: rgba(99,102,241,0.2);\n}\n\n.stat-num {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 22px;\n  font-weight: 800;\n  letter-spacing: -0.04em;\n  display: block;\n  margin-bottom: 2px;\n}\n.stat-num.gold { color: #FFD700; text-shadow: 0 0 20px rgba(255,215,0,0.25); }\n.stat-num.teal { color: #00D4A0; text-shadow: 0 0 20px rgba(0,212,160,0.2); }\n.stat-num.indigo { color: #818CF8; text-shadow: 0 0 20px rgba(99,102,241,0.2); }\n\n.stat-label {\n  font-size: 10px;\n  color: #4A6380;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n  line-height: 1.3;\n}\n\n/* Referrals Table */\n.table-section { margin-bottom: 20px; }\n.table-header-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 12px;\n}\n.table-title {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 15px;\n  font-weight: 700;\n  color: #E2E8F0;\n}\n.table-count {\n  font-size: 11px;\n  color: #4A6380;\n  background: #060F1C;\n  border: 1px solid #0F2035;\n  border-radius: 99px;\n  padding: 2px 8px;\n}\n\n.ref-table {\n  background: #060F1C;\n  border: 1px solid #0F2035;\n  border-radius: 18px;\n  overflow: hidden;\n}\n\n.ref-table-head {\n  display: grid;\n  grid-template-columns: 1fr 1fr 80px;\n  padding: 10px 14px;\n  border-bottom: 1px solid #0F2035;\n  background: rgba(255,255,255,0.01);\n}\n.ref-th {\n  font-size: 10px;\n  font-weight: 700;\n  color: #4A6380;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n}\n\n.ref-row {\n  display: grid;\n  grid-template-columns: 1fr 1fr 80px;\n  padding: 11px 14px;\n  border-bottom: 1px solid rgba(15,32,53,0.5);\n  align-items: center;\n  transition: background 0.12s;\n}\n.ref-row:last-child { border-bottom: none; }\n.ref-row:nth-child(even) { background: rgba(255,255,255,0.012); }\n.ref-row:hover { background: rgba(255,255,255,0.02); }\n\n.ref-username {\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 12px;\n  font-weight: 600;\n  color: #E2E8F0;\n}\n.ref-date {\n  font-size: 11px;\n  color: #6B8AAA;\n}\n.ref-status {\n  display: inline-flex;\n  align-items: center;\n  gap: 3px;\n  padding: 3px 8px;\n  border-radius: 99px;\n  font-size: 10px;\n  font-weight: 700;\n  font-family: 'Manrope', sans-serif;\n  justify-self: start;\n}\n.ref-status.rewarded {\n  background: rgba(0,212,160,0.1);\n  border: 1px solid rgba(0,212,160,0.25);\n  color: #00D4A0;\n}\n.ref-status.pending {\n  background: rgba(255,215,0,0.1);\n  border: 1px solid rgba(255,215,0,0.25);\n  color: #FFD700;\n}\n\n/* CTA Button */\n.cta-btn {\n  width: 100%;\n  padding: 15px;\n  background: linear-gradient(135deg, #FFD700 0%, #FFE082 100%);\n  color: #010B13;\n  border: none;\n  border-radius: 16px;\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 15px;\n  font-weight: 800;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 8px;\n  box-shadow: 0 6px 24px rgba(255,215,0,0.25);\n  transition: all 0.2s;\n  letter-spacing: -0.01em;\n}\n.cta-btn:hover {\n  box-shadow: 0 8px 32px rgba(255,215,0,0.35);\n  transform: translateY(-1px);\n}\n</style>\n\n<div class=\"page\" data-kid=\"1\">\n  <div class=\"bg-glow bg-glow-1\" data-kid=\"2\"></div>\n  <div class=\"bg-glow bg-glow-2\" data-kid=\"3\"></div>\n\n  <div class=\"content\" data-kid=\"4\">\n\n    \n    <div class=\"hero-card\" data-kid=\"5\">\n      <div class=\"hex-pattern\" data-kid=\"6\"></div>\n      <div class=\"hero-gradient-top\" data-kid=\"7\"></div>\n      <div class=\"hero-gradient-right\" data-kid=\"8\"></div>\n      <div class=\"hero-content\" data-kid=\"9\">\n        <div class=\"hero-title-row\" data-kid=\"10\">\n          <span class=\"emoji\" data-kid=\"11\">🎁</span>\n          <h1 data-kid=\"12\">Invite &amp; Earn</h1>\n        </div>\n        <p class=\"hero-subtitle\" data-kid=\"13\">Earn 100 points for every friend who completes their first trade on EthioSwap.</p>\n\n        \n        <div class=\"ref-link-row\" data-kid=\"14\">\n          <div class=\"ref-link-input\" data-kid=\"15\">https://ethioswap.com/r/ABEBE123</div>\n          <button class=\"ref-copy-btn\" data-kid=\"16\">\n            <i class=\"ti ti-copy\" data-kid=\"17\"></i> Copy\n          </button>\n        </div>\n\n        \n        <div class=\"social-row\" data-kid=\"18\">\n          <span class=\"social-label\" data-kid=\"19\">Share via:</span>\n          <button class=\"social-btn social-wa\" title=\"WhatsApp\" data-kid=\"20\">\n            <i class=\"ti ti-brand-whatsapp\" data-kid=\"21\"></i>\n          