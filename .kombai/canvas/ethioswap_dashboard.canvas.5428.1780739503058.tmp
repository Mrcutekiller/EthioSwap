      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n* { box-sizing: border-box; margin: 0; padding: 0; }\n\nbody {\n  font-family: 'Manrope', sans-serif;\n  background: #010B13;\n  color: #E2E8F0;\n  min-height: 100vh;\n  padding-bottom: 24px;\n}\n\n.page {\n  padding: 20px 16px 32px;\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n  background: #010B13;\n  min-height: 100vh;\n  position: relative;\n  overflow: hidden;\n}\n\n.page::before {\n  content: '';\n  position: fixed;\n  top: -120px;\n  left: 50%;\n  transform: translateX(-50%);\n  width: 340px;\n  height: 340px;\n  background: radial-gradient(circle, rgba(255,215,0,0.08) 0%, transparent 70%);\n  pointer-events: none;\n  z-index: 0;\n}\n\n/* Header */\n.page-header {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n  position: relative;\n  z-index: 1;\n  padding-top: 8px;\n}\n\n.page-title {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 24px;\n  font-weight: 800;\n  color: #E2E8F0;\n  letter-spacing: -0.03em;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n\n.page-subtitle {\n  font-size: 13px;\n  color: #4A6380;\n  font-weight: 500;\n}\n\n/* Podium */\n.podium-section {\n  position: relative;\n  z-index: 1;\n  display: flex;\n  align-items: flex-end;\n  gap: 8px;\n}\n\n.podium-card {\n  flex: 1;\n  border-radius: 20px;\n  padding: 16px 12px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 6px;\n  position: relative;\n  overflow: hidden;\n  border: 1px solid transparent;\n  transition: transform 0.2s ease;\n}\n\n.podium-card.rank-1 {\n  background: linear-gradient(145deg, rgba(255,215,0,0.14) 0%, rgba(255,215,0,0.04) 100%);\n  border-color: rgba(255,215,0,0.35);\n  box-shadow: 0 0 24px rgba(255,215,0,0.12), inset 0 1px 0 rgba(255,215,0,0.15);\n  padding: 20px 12px;\n}\n\n.podium-card.rank-2 {\n  background: linear-gradient(145deg, rgba(200,200,220,0.08) 0%, rgba(150,160,180,0.03) 100%);\n  border-color: rgba(192,192,210,0.25);\n  box-shadow: 0 0 12px rgba(150,160,200,0.06);\n}\n\n.podium-card.rank-3 {\n  background: linear-gradient(145deg, rgba(180,100,0,0.1) 0%, rgba(140,80,0,0.04) 100%);\n  border-color: rgba(180,110,40,0.3);\n  box-shadow: 0 0 12px rgba(160,90,0,0.08);\n}\n\n.podium-medal {\n  font-size: 28px;\n  line-height: 1;\n}\n\n.podium-card.rank-2 .podium-medal,\n.podium-card.rank-3 .podium-medal {\n  font-size: 22px;\n}\n\n.podium-avatar {\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-family: 'Space Grotesk', sans-serif;\n  font-weight: 800;\n  font-size: 14px;\n  color: #010B13;\n  position: relative;\n}\n\n.podium-card.rank-1 .podium-avatar {\n  width: 52px;\n  height: 52px;\n  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);\n  font-size: 16px;\n  box-shadow: 0 0 16px rgba(255,215,0,0.4);\n}\n\n.podium-card.rank-2 .podium-avatar {\n  width: 42px;\n  height: 42px;\n  background: linear-gradient(135deg, #C0C0D0 0%, #8090A0 100%);\n  font-size: 13px;\n}\n\n.podium-card.rank-3 .podium-avatar {\n  width: 38px;\n  height: 38px;\n  background: linear-gradient(135deg, #CD7F32 0%, #A05020 100%);\n  font-size: 12px;\n}\n\n.podium-name {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 11px;\n  font-weight: 700;\n  color: #E2E8F0;\n  text-align: center;\n  max-width: 80px;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.podium-volume {\n  font-family: 'JetBrains Mono', monospace;\n  font-weight: 700;\n  text-align: center;\n  color: #FFD700;\n}\n\n.podium-card.rank-1 .podium-volume { font-size: 13px; }\n.podium-card.rank-2 .podium-volume, .podium-card.rank-3 .podium-volume { font-size: 11px; }\n\n.podium-streak {\n  font-size: 11px;\n  color: #6B8AAA;\n  text-align: center;\n}\n\n/* Table Section */\n.table-section {\n  position: relative;\n  z-index: 1;\n  display: flex;\n  flex-direction: column;\n  gap: 0;\n  border-radius: 20px;\n  overflow: hidden;\n  border: 1px solid #0F2035;\n  background: #060F1C;\n}\n\n.table-header {\n  display: grid;\n  grid-template-columns: 28px 1fr 44px 60px 36px 36px;\n  gap: 4px;\n  padding: 10px 12px;\n  background: rgba(15,32,53,0.6);\n  border-bottom: 1px solid #0F2035;\n}\n\n.table-header span {\n  font-size: 9px;\n  font-weight: 800;\n  color: #4A6380;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n  text-align: center;\n}\n\n.table-header span:nth-child(2) { text-align: left; }\n\n.table-row {\n  display: grid;\n  grid-template-columns: 28px 1fr 44px 60px 36px 36px;\n  gap: 4px;\n  padding: 10px 12px;\n  align-items: center;\n  border-bottom: 1px solid rgba(15,32,53,0.5);\n  transition: background 0.15s;\n}\n\n.table-row:nth-child(even) { background: rgba(6,15,28,0.6); }\n.table-row:nth-child(odd) { background: rgba(13,21,32,0.4); }\n.table-row:last-child { border-bottom: none; }\n\n.rank-num {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 12px;\n  font-weight: 800;\n  color: #FFD700;\n  text-align: center;\n}\n\n.trader-info {\n  display: flex;\n  align-items: center;\n  gap: 7px;\n  min-width: 0;\n}\n\n.trader-mini-avatar {\n  width: 26px;\n  height: 26px;\n  border-radius: 50%;\n  background: linear-gradient(135deg, #0F2035 0%, #1A3050 100%);\n  border: 1px solid #1A3050;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 9px;\n  font-weight: 800;\n  color: #6B8AAA;\n  flex-shrink: 0;\n}\n\n.trader-username {\n  font-size: 12px;\n  font-weight: 600;\n  color: #E2E8F0;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.cell-center {\n  text-align: center;\n  font-size: 11px;\n  color: #6B8AAA;\n  font-family: 'JetBrains Mono', monospace;\n  font-weight: 600;\n}\n\n.cell-volume {\n  text-align: center;\n  font-size: 11px;\n  font-family: 'JetBrains Mono', monospace;\n  font-weight: 700;\n  color: #00D4A0;\n}\n\n.cell-streak {\n  text-align: center;\n  font-size: 10px;\n  font-weight: 600;\n  color: #FF6B35;\n}\n\n.cell-score {\n  text-align: center;\n  font-size: 11px;\n  font-weight: 700;\n  color: #6B8AAA;\n}\n\n/* My Rank Row */\n.my-rank-row {\n  background: rgba(255,215,0,0.05) !important;\n  border: 1px solid rgba(255,215,0,0.2) !important;\n  border-radius: 12px;\n  margin: 8px;\n  padding: 10px 12px !important;\n}\n\n.my-rank-row .trader-username {\n  color: #FFD700;\n}\n\n.my-rank-label {\n  font-size: 9px;\n  color: #FFD700;\n  font-weight: 800;\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n  margin-bottom: 2px;\n}\n</style>\n\n<div class=\"page\" data-kid=\"1\">\n  \n  <div class=\"page-header\" data-kid=\"2\">\n    <div class=\"page-title\" data-kid=\"3\">👑 Leaderboard</div>\n    <div class=\"page-subtitle\" data-kid=\"4\">Top traders this week</div>\n  </div>\n\n  \n  <div class=\"podium-section\" data-kid=\"5\">\n    \n    <div class=\"podium-card rank-2\" data-kid=\"6\">\n      <div class=\"podium-medal\" data-kid=\"7\">🥈</div>\n      <div class=\"podium-avatar\" data-kid=\"8\">SR</div>\n      <div class=\"podium-name\" data-kid=\"9\">@selam_r</div>\n      <div class=\"podium-volume\" data-kid=\"10\">$8,200</div>\n      <div class=\"podium-streak\" data-kid=\"11\">🔥 8d</div>\n    </div>\n    \n    <div class=\"podium-card rank-1\" data-kid=\"12\">\n      <div class=\"podium-medal\" data-kid=\"13\">🥇</div>\n      <div class=\"podium-avatar\" data-kid=\"14\">YB</div>\n      <div class=\"podium-name\" data-kid=\"15\">@yonas_b</div>\n      <div class=\"podium-volume\" data-kid=\"16\">$12,400</div>\n      <div class=\"podium-streak\" data-kid=\"17\">🔥 14d</div>\n    </div>\n    \n    <div class=\"podium-card rank-3\" data-kid=\"18\">\n      <div class=\"podium-medal\" data-kid=\"19\">🥉</div>\n      <div class=\"podium-avatar\" data-kid=\"20\">KA</div>\n      <div class=\"podium-name\" data-kid=\"21\">@kalu_a</div>\n      <div class=\"podium-volume\" data-kid=\"22\">$5,900</div>\n      <div class=\"podium-streak\" data-kid=\"23\">🔥 5d</div>\n    </div>\n  </div>\n\n  \n  <div class=\"table-section\" data-kid=\"24\">\n    <div class=\"table-header\" data-kid=\"25\">\n      <span data-kid=\"26\">#</span>\n      <span data-kid=\"27\">Trader</span>\n      <span data-kid=\"28\">Trades</span>\n      <span data-kid=\"29\">Volume</span>\n      <span data-kid=\"30\">Streak</span>\n      <span data-kid=\"31\">Score</span>\n    </div>\n\n    <div class=\"table-row\" data-kid=\"32\">\n      <div class=\"rank-num\" data-kid=\"33\">4</div>\n      <div class=\"trader-info\" data-kid=\"34\">\n        <div class=\"trader-mini-avatar\" data-kid=\"35\">HF</div>\n        <div class=\"trader-username\" data-kid=\"36\">@hana_f</div>\n      </div>\n      <div class=\"cell-center\" data-kid=\"37\">89</div>\n      <div class=\"cell-volume\" data-kid=\"38\">$4.1k</div>\n      <div class=\"cell-streak\" data-kid=\"39\">🔥3d</div>\n      <div class=\"cell-score\" data-kid=\"40\">96%</div>\n    </div>\n\n    <div class=\"table-row\" data-kid=\"41\">\n      <div class=\"rank-num\" data-kid=\"42\">5</div>\n      <div class=\"trader-info\" data-kid=\"43\">\n        <div class=\"trader-mini-avatar\" data-kid=\"44\">DA</div>\n        <div class=\"trader-username\" data-kid=\"45\">@dawit_a</div>\n      </div>\n      <div class=\"cell-center\" data-kid=\"46\">76</div>\n      <div class=\"cell-volume\" data-kid=\"47\">$3.8k</div>\n      <div class=\"cell-streak\" data-kid=\"48\">🔥2d</div>\n      <div class=\"cell-score\" data-kid=\"49\">94%</div>\n    </div>\n\n    <div class=\"table-row\" data-kid=\"50\">\n      <div class=\"rank-num\" data-kid=\"51\">6</div>\n      <div class=\"trader-info\" data-kid=\"52\">\n        <div class=\"trader-mini-avatar\" data-kid=\"53\">MG</div>\n        <div class=\"trader-username\" data-kid=\"54\">@miriam_g</div>\n      </div>\n      <div class=\"cell-center\" data-kid=\"55\">65</div>\n      <div class=\"cell-volume\" data-kid=\"56\">$3.2k</div>\n      <div class=\"cell-streak\" style=\"color:#4A6380;\" data-kid=\"57\">—</div>\n      <div class=\"cell-score\" data-kid=\"58\">91%</div>\n    </div>\n\n    <div class=\"table-row\" data-kid=\"59\">\n      <div class=\"rank-num\" data-kid=\"60\">7</div>\n      <div class=\"trader-info\" data-kid=\"61\">\n        <div class=\"trader-mini-avatar\" data-kid=\"62\">TM</div>\n        <div class=\"trader-username\" data-kid=\"63\">@tsion_m</div>\n      </div>\n      <div class=\"cell-center\" data-kid=\"64\">52</div>\n      <div class=\"cell-volume\" data-kid=\"65\">$2.7k</div>\n      <div class=\"cell-streak\" data-kid=\"66\">🔥7d</div>\n      <div class=\"cell-score\" data-kid=\"67\">89%</div>\n    </div>\n\n    <div class=\"table-row\" data-kid=\"68\">\n      <div class=\"rank-num\" data-kid=\"69\">8</div>\n      <div class=\"trader-info\" data-kid=\"70\">\n        <div class=\"trader-mini-avatar\" data-kid=\"71\">BW</div>\n        <div class=\"trader-username\" data-kid=\"72\">@bekele_w</div>\n      </div>\n      <div class=\"cell-center\" data-kid=\"73\">44</div>\n      <div class=\"cell-volume\" data-kid=\"74\">$2.1k</div>\n      <div class=\"cell-streak\" style=\"color:#4A6380;\" data-kid=\"75\">—</div>\n      <div class=\"cell-score\" data-kid=\"76\">85%</div>\n    </div>\n\n    \n    <div style=\"padding: 4px 0 8px;\" data-kid=\"77\">\n      <div style=\"display:flex;align-items:center;gap:6px;padding:4px 12px 6px;\" data-kid=\"78\">\n        <div style=\"flex:1;height:1px;background:rgba(255,215,0,0.1);\" data-kid=\"79\"></div>\n        <span style=\"font-size:9px;color:rgba(255,215,0,0.5);font-weight:700;text-transform:uppercase;letter-spacing:0.08em;\" data-kid=\"80\">Your Position</span>\n        <div style=\"flex:1;height:1px;background:rgba(255,215,0,0.1);\" data-kid=\"81\"></div>\n      </div>\n      <div style=\"display:grid;grid-template-columns:28px 1fr 44px 60px 36px 36px;gap:4px;align-items:center;margin:0 8px;padding:10px 12px;background:rgba(255,215,0,0.05);border:1px solid rgba(255,215,0,0.2);border-radius:12px;\" data-kid=\"82\">\n        <div class=\"rank-num\" style=\"color:#FFD700;\" data-kid=\"83\">12</div>\n        <div class=\"trader-info\" data-kid=\"84\">\n          <div class=\"trader-mini-avatar\" style=\"background:linear-gradient(135deg,rgba(255,215,0,0.2),rgba(255,215,0,0.08));border-color:rgba(255,215,0,0.3);color:#FFD700;\" data-kid=\"85\">AT</div>\n          <div class=\"trader-username\" style=\"color:#FFD700;\" data-kid=\"86\">@you</div>\n        </div>\n        <div class=\"cell-center\" style=\"color:#FFE082;\" data-kid=\"87\">22</div>\n        <div class=\"cell-volume\" style=\"color:#FFD700;\" data-kid=\"88\">$980</div>\n        <div class=\"cell-streak\" style=\"color:#4A6380;\" data-kid=\"89\">—</div>\n        <div class=\"cell-score\" style=\"color:#FFD700;\" data-kid=\"90\">72%</div>\n      </div>\n    </div>\n  </div>\n</div>\n",
