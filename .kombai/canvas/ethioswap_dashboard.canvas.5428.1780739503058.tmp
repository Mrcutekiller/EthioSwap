      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n* { box-sizing: border-box; margin: 0; padding: 0; }\n\nbody {\n  font-family: 'Manrope', sans-serif;\n  background: #010B13;\n  color: #E2E8F0;\n  min-height: 100vh;\n}\n\n.page {\n  background: #010B13;\n  min-height: 100vh;\n  padding: 20px 16px 100px;\n  position: relative;\n  overflow: hidden;\n}\n\n.bg-glow {\n  position: absolute;\n  border-radius: 50%;\n  filter: blur(80px);\n  pointer-events: none;\n  z-index: 0;\n  opacity: 0.25;\n}\n.bg-glow-1 {\n  width: 300px; height: 300px;\n  top: -80px; left: -80px;\n  background: radial-gradient(circle, rgba(0,212,160,0.2) 0%, transparent 70%);\n}\n.bg-glow-2 {\n  width: 250px; height: 250px;\n  bottom: 20%; right: -60px;\n  background: radial-gradient(circle, rgba(255,215,0,0.12) 0%, transparent 70%);\n}\n\n.content { position: relative; z-index: 1; }\n\n/* Header */\n.page-header { margin-bottom: 20px; }\n.page-header h1 {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 22px;\n  font-weight: 800;\n  color: #E2E8F0;\n  letter-spacing: -0.03em;\n  margin-bottom: 3px;\n}\n.page-header .subtitle {\n  font-size: 12px;\n  color: #4A6380;\n  font-weight: 500;\n}\n\n/* Filter Bar */\n.filter-bar {\n  display: flex;\n  gap: 8px;\n  overflow-x: auto;\n  padding-bottom: 4px;\n  margin-bottom: 24px;\n  scrollbar-width: none;\n}\n.filter-bar::-webkit-scrollbar { display: none; }\n.filter-pill {\n  flex-shrink: 0;\n  padding: 6px 14px;\n  border-radius: 99px;\n  font-size: 12px;\n  font-weight: 700;\n  cursor: pointer;\n  border: 1px solid #0F2035;\n  background: #060F1C;\n  color: #6B8AAA;\n  transition: all 0.15s;\n  white-space: nowrap;\n  font-family: 'Manrope', sans-serif;\n}\n.filter-pill.active {\n  background: rgba(255,215,0,0.12);\n  border-color: rgba(255,215,0,0.3);\n  color: #FFD700;\n}\n\n/* Timeline */\n.timeline { position: relative; display: flex; flex-direction: column; gap: 0; }\n\n.timeline-track {\n  position: absolute;\n  left: 19px;\n  top: 28px;\n  bottom: 28px;\n  width: 2px;\n  background: linear-gradient(to bottom, rgba(0,212,160,0.5), rgba(0,212,160,0.1) 80%, transparent);\n  z-index: 0;\n}\n\n.timeline-item {\n  display: flex;\n  gap: 14px;\n  padding: 0 0 16px 0;\n  position: relative;\n  z-index: 1;\n}\n.timeline-item:last-child { padding-bottom: 0; }\n\n.tl-icon {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 16px;\n  flex-shrink: 0;\n  border: 2px solid;\n  position: relative;\n  z-index: 2;\n}\n.tl-icon.teal {\n  background: rgba(0,212,160,0.12);\n  border-color: rgba(0,212,160,0.35);\n  color: #00D4A0;\n  box-shadow: 0 0 12px rgba(0,212,160,0.15);\n}\n.tl-icon.gold {\n  background: rgba(255,215,0,0.1);\n  border-color: rgba(255,215,0,0.3);\n  color: #FFD700;\n  box-shadow: 0 0 12px rgba(255,215,0,0.12);\n}\n.tl-icon.red {\n  background: rgba(239,68,68,0.1);\n  border-color: rgba(239,68,68,0.3);\n  color: #EF4444;\n  box-shadow: 0 0 12px rgba(239,68,68,0.12);\n}\n\n.tl-body { flex: 1; }\n\n.tl-card {\n  background: #060F1C;\n  border: 1px solid #0F2035;\n  border-radius: 16px;\n  padding: 12px 14px;\n  transition: border-color 0.15s;\n}\n.tl-card:hover { border-color: #1A2840; }\n\n.tl-row-top {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  margin-bottom: 6px;\n}\n.tl-title {\n  font-size: 13px;\n  font-weight: 700;\n  color: #E2E8F0;\n  font-family: 'Space Grotesk', sans-serif;\n}\n.tl-date {\n  font-size: 10px;\n  color: #4A6380;\n  font-weight: 500;\n  white-space: nowrap;\n  margin-left: 8px;\n}\n\n.tl-amount-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 8px;\n}\n.tl-amount {\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 16px;\n  font-weight: 700;\n}\n.tl-amount.teal { color: #00D4A0; }\n.tl-amount.gold { color: #FFD700; }\n.tl-amount.red { color: #EF4444; }\n\n.status-pill {\n  display: inline-flex;\n  align-items: center;\n  gap: 4px;\n  padding: 3px 9px;\n  border-radius: 99px;\n  font-size: 10px;\n  font-weight: 700;\n  font-family: 'Manrope', sans-serif;\n}\n.status-pill.approved {\n  background: rgba(0,212,160,0.1);\n  border: 1px solid rgba(0,212,160,0.25);\n  color: #00D4A0;\n}\n.status-pill.pending {\n  background: rgba(255,215,0,0.1);\n  border: 1px solid rgba(255,215,0,0.25);\n  color: #FFD700;\n}\n.status-pill.rejected {\n  background: rgba(239,68,68,0.1);\n  border: 1px solid rgba(239,68,68,0.25);\n  color: #EF4444;\n}\n\n.tl-hash-row {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  margin-top: 4px;\n}\n.tl-hash {\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 10px;\n  color: #4A6380;\n}\n.tl-copy-btn {\n  color: #4A6380;\n  font-size: 12px;\n  cursor: pointer;\n}\n.tl-copy-btn:hover { color: #6B8AAA; }\n\n.rejection-reason {\n  margin-top: 6px;\n  font-size: 11px;\n  color: rgba(239,68,68,0.75);\n  display: flex;\n  align-items: center;\n  gap: 4px;\n}\n\n/* Summary Bar */\n.summary-bar {\n  background: #060F1C;\n  border: 1px solid #0F2035;\n  border-radius: 20px;\n  padding: 16px;\n  margin-top: 24px;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n.summary-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 2px;\n}\n.summary-label {\n  font-size: 10px;\n  color: #4A6380;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n}\n.summary-value {\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 14px;\n  font-weight: 700;\n}\n.summary-value.teal { color: #00D4A0; }\n.summary-value.gold { color: #FFD700; }\n.summary-value.white { color: #E2E8F0; }\n\n.summary-divider {\n  width: 1px;\n  height: 32px;\n  background: #0F2035;\n}\n</style>\n\n<div class=\"page\" data-kid=\"1\">\n  <div class=\"bg-glow bg-glow-1\" data-kid=\"2\"></div>\n  <div class=\"bg-glow bg-glow-2\" data-kid=\"3\"></div>\n\n  <div class=\"content\" data-kid=\"4\">\n    \n    <div class=\"page-header\" data-kid=\"5\">\n      <h1 data-kid=\"6\">Transaction History</h1>\n      <p class=\"subtitle\" data-kid=\"7\">24 total records</p>\n    </div>\n\n    \n    <div class=\"filter-bar\" data-kid=\"8\">\n      <button class=\"filter-pill active\" data-kid=\"9\">All</button>\n      <button class=\"filter-pill\" data-kid=\"10\">Deposits</button>\n      <button class=\"filter-pill\" data-kid=\"11\">Withdrawals</button>\n      <button class=\"filter-pill\" data-kid=\"12\">Pending</button>\n      <button class=\"filter-pill\" data-kid=\"13\">Approved</button>\n      <button class=\"filter-pill\" data-kid=\"14\">Rejected</button>\n    </div>\n\n    \n    <div class=\"timeline\" data-kid=\"15\">\n      <div class=\"timeline-track\" data-kid=\"16\"></div>\n\n      \n      <div class=\"timeline-item\" data-kid=\"17\">\n        <div class=\"tl-icon teal\" data-kid=\"18\">\n          <i class=\"ti ti-arrow-down-left\" data-kid=\"19\"></i>\n        </div>\n        <div class=\"tl-body\" data-kid=\"20\">\n          <div class=\"tl-card\" data-kid=\"21\">\n            <div class=\"tl-row-top\" data-kid=\"22\">\n              <span class=\"tl-title\" data-kid=\"23\">Deposit — USDT-TRC20</span>\n              <span class=\"tl-date\" data-kid=\"24\">Jun 5, 2026</span>\n            </div>\n            <div class=\"tl-amount-row\" data-kid=\"25\">\n              <span class=\"tl-amount teal\" data-kid=\"26\">+$250.00</span>\n              <span class=\"status-pill approved\" data-kid=\"27\">✓ Approved</span>\n            </div>\n            <div class=\"tl-hash-row\" data-kid=\"28\">\n              <span class=\"tl-hash\" data-kid=\"29\">0x7a3b...f912</span>\n              <i class=\"ti ti-copy tl-copy-btn\" data-kid=\"30\"></i>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"timeline-item\" data-kid=\"31\">\n        <div class=\"tl-icon gold\" data-kid=\"32\">\n          <i class=\"ti ti-arrow-up-right\" data-kid=\"33\"></i>\n        </div>\n        <div class=\"tl-body\" data-kid=\"34\">\n          <div class=\"tl-card\" data-kid=\"35\">\n            <div class=\"tl-row-top\" data-kid=\"36\">\n              <span class=\"tl-title\" data-kid=\"37\">Withdrawal Request</span>\n              <span class=\"tl-date\" data-kid=\"38\">Jun 4, 2026</span>\n            </div>\n            <div class=\"tl-amount-row\" data-kid=\"39\">\n              <span class=\"tl-amount gold\" data-kid=\"40\">-$100.00</span>\n              <span class=\"status-pill pending\" data-kid=\"41\">⏳ Pending</span>\n            </div>\n            <div class=\"tl-hash-row\" data-kid=\"42\">\n              <span class=\"tl-hash\" data-kid=\"43\">TRC20 · TKm4...9eZ8</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"timeline-item\" data-kid=\"44\">\n        <div class=\"tl-icon red\" data-kid=\"45\">\n          <i class=\"ti ti-arrow-up-right\" data-kid=\"46\"></i>\n        </div>\n        <div class=\"tl-body\" data-kid=\"47\">\n          <div class=\"tl-card\" data-kid=\"48\">\n            <div class=\"tl-row-top\" data-kid=\"49\">\n              <span class=\"tl-title\" data-kid=\"50\">Withdrawal Request</span>\n              <span class=\"tl-date\" data-kid=\"51\">Jun 3, 2026</span>\n            </div>\n            <div class=\"tl-amount-row\" data-kid=\"52\">\n              <span class=\"tl-amount red\" data-kid=\"53\">-$50.00</span>\n              <span class=\"status-pill rejected\" data-kid=\"54\">✗ Rejected</span>\n            </div>\n            <div class=\"rejection-reason\" data-kid=\"55\">\n              <i class=\"ti ti-alert-triangle\" style=\"font-size:11px;\" data-kid=\"56\"></i>\n              Reason: Invalid wallet address\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"timeline-item\" data-kid=\"57\">\n        <div class=\"tl-icon teal\" data-kid=\"58\">\n          <i class=\"ti ti-arrow-down-left\" data-kid=\"59\"></i>\n        </div>\n        <div class=\"tl-body\" data-kid=\"60\">\n          <div class=\"tl-card\" data-kid=\"61\">\n            <div class=\"tl-row-top\" data-kid=\"62\">\n              <span class=\"tl-title\" data-kid=\"63\">Deposit — USDT-ERC20</span>\n              <span class=\"tl-date\" data-kid=\"64\">May 30, 2026</span>\n            </div>\n            <div class=\"tl-amount-row\" data-kid=\"65\">\n              <span class=\"tl-amount teal\" data-kid=\"66\">+$500.00</span>\n              <span class=\"status-pill approved\" data-kid=\"67\">✓ Approved</span>\n            </div>\n            <div class=\"tl-hash-row\" data-kid=\"68\">\n              <span class=\"tl-hash\" data-kid=\"69\">0xb2c1...aa44</span>\n              <i class=\"ti ti-copy tl-copy-btn\" data-kid=\"70\"></i>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"timeline-item\" data-kid=\"71\">\n        <div class=\"tl-icon teal\" data-kid=\"72\">\n          <i class=\"ti ti-arrow-down-left\" data-kid=\"73\"></i>\n        </div>\n        <div class=\"tl-body\" data-kid=\"74\">\n          <div class=\"tl-card\" data-kid=\"75\">\n            <div class=\"tl-row-top\" data-kid=\"76\">\n              <span class=\"tl-title\" data-kid=\"77\">Deposit — USDT-TRC20</span>\n              <span class=\"tl-date\" data-kid=\"78\">May 20, 2026</span>\n            </div>\n            <div class=\"tl-amount-row\" data-kid=\"79\">\n              <span class=\"tl-amount teal\" data-kid=\"80\">+$1,000.00</span>\n              <span class=\"status-pill approved\" data-kid=\"81\">✓ Approved</span>\n            </div>\n            <div class=\"tl-hash-row\" data-kid=\"82\">\n              <span class=\"tl-hash\" data-kid=\"83\">0xf83e...d290</span>\n              <i class=\"ti ti-copy tl-copy-btn\" data-kid=\"84\"></i>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"summary-bar\" data-kid=\"85\">\n      <div class=\"summary-item\" data-kid=\"86\">\n        <span class=\"summary-label\" data-kid=\"87\">Total In</span>\n        <span class=\"summary-value teal\" data-kid=\"88\">+$1,750.00</span>\n      </div>\n      <div class=\"summary-divider\" data-kid=\"89\"></div>\n      <div class=\"summary-item\" data-kid=\"90\">\n        <span class=\"summary-label\" data-kid=\"91\">Total Out</span>\n        <span class=\"summary-value gold\" data-kid=\"92\">-$150.00</span>\n      </div>\n      <div class=\"summary-divider\" data-kid=\"93\"></div>\n      <div class=\"summary-item\" data-kid=\"94\">\n        <span class=\"summary-label\" data-kid=\"95\">Net Balance</span>\n        <span class=\"summary-value white\" data-kid=\"96\">+$1,600.00</span>\n      </div>\n    </div>\n  </div>\n</div>\n",
