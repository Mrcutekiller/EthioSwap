      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body {\n    font-family: 'Manrope', sans-serif;\n    background: #010B13;\n    color: #E2E8F0;\n    min-height: 100vh;\n  }\n\n  /* Radial glow behind header */\n  .header-glow {\n    position: fixed;\n    top: -80px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 800px;\n    height: 200px;\n    background: radial-gradient(ellipse at 50% 0%, rgba(255,215,0,0.06) 0%, transparent 70%);\n    pointer-events: none;\n    z-index: 99;\n  }\n\n  /* TOP HEADER */\n  .top-header {\n    position: sticky;\n    top: 0;\n    height: 72px;\n    background: rgba(6,15,28,0.95);\n    backdrop-filter: blur(24px);\n    -webkit-backdrop-filter: blur(24px);\n    border-bottom: 1px solid #0F2035;\n    z-index: 100;\n    display: flex;\n    align-items: center;\n    padding: 0 32px;\n    gap: 20px;\n  }\n\n  .logo {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    flex-shrink: 0;\n  }\n  .logo-shield {\n    width: 36px;\n    height: 36px;\n    background: linear-gradient(135deg, #FFD700, #FFE082);\n    border-radius: 10px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-family: 'Space Grotesk', sans-serif;\n    font-weight: 900;\n    font-size: 14px;\n    color: #010B13;\n    box-shadow: 0 0 16px rgba(255,215,0,0.4);\n  }\n  .logo-name {\n    font-family: 'Space Grotesk', sans-serif;\n    font-weight: 800;\n    font-size: 18px;\n    background: linear-gradient(135deg, #FFD700, #FFE082);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    background-clip: text;\n  }\n\n  /* DESKTOP NAV */\n  .desktop-nav {\n    display: flex;\n    align-items: center;\n    gap: 4px;\n    flex: 1;\n    justify-content: center;\n  }\n  .nav-btn {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    padding: 7px 13px;\n    border-radius: 10px;\n    font-family: 'Manrope', sans-serif;\n    font-size: 12.5px;\n    font-weight: 600;\n    color: #6B8AAA;\n    background: transparent;\n    border: 1px solid transparent;\n    cursor: pointer;\n    transition: all 0.15s;\n    position: relative;\n    font-size: 13px;\n  }\n  .nav-btn:hover {\n    color: #E2E8F0;\n    background: rgba(15,32,53,0.5);\n  }\n  .nav-btn.active {\n    color: #FFE082;\n    background: rgba(255,215,0,0.08);\n    border-color: rgba(255,215,0,0.18);\n    box-shadow: 0 0 10px rgba(255,215,0,0.08);\n  }\n  .nav-badge {\n    background: #EF4444;\n    color: #fff;\n    border-radius: 99px;\n    min-width: 16px;\n    height: 16px;\n    font-size: 9px;\n    font-weight: 800;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    padding: 0 4px;\n  }\n\n  /* RIGHT SIDE */\n  .header-right {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    flex-shrink: 0;\n  }\n  .balance-display {\n    text-align: right;\n    padding: 0 4px;\n  }\n  .bal-usd {\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 13px;\n    font-weight: 700;\n    color: #FFD700;\n    display: block;\n    line-height: 1.2;\n    text-shadow: 0 0 10px rgba(255,215,0,0.3);\n  }\n  .bal-etb {\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 10px;\n    color: #4A6380;\n    display: block;\n  }\n  .user-capsule {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    background: rgba(15,32,53,0.5);\n    border: 1px solid #0F2035;\n    border-radius: 10px;\n    padding: 6px 12px;\n  }\n  .user-capsule-text {\n    display: flex;\n    flex-direction: column;\n  }\n  .username {\n    font-size: 12px;\n    font-weight: 700;\n    color: #E2E8F0;\n  }\n  .user-role {\n    font-size: 9px;\n    color: #4A6380;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n  }\n  .kyc-badge {\n    background: rgba(0,212,160,0.1);\n    color: #00D4A0;\n    border: 1px solid rgba(0,212,160,0.2);\n    border-radius: 99px;\n    padding: 2px 7px;\n    font-size: 9.5px;\n    font-weight: 700;\n  }\n  .icon-btn {\n    width: 36px;\n    height: 36px;\n    border-radius: 10px;\n    background: rgba(15,32,53,0.5);\n    border: 1px solid #0F2035;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: #6B8AAA;\n    cursor: pointer;\n    position: relative;\n    font-size: 18px;\n  }\n  .notif-dot {\n    position: absolute;\n    top: -3px;\n    right: -3px;\n    width: 10px;\n    height: 10px;\n    background: #EF4444;\n    border-radius: 50%;\n    border: 2px solid #010B13;\n  }\n\n  /* PAGE CONTENT */\n  .page-content {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 32px 24px;\n  }\n\n  /* PAGE HEADER */\n  .page-header {\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-between;\n    margin-bottom: 24px;\n  }\n  .page-title {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 26px;\n    font-weight: 800;\n    color: #E2E8F0;\n  }\n  .page-subtitle {\n    font-size: 13px;\n    color: #4A6380;\n    margin-top: 4px;\n  }\n\n  /* TOGGLE + FILTERS */\n  .controls-row {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    margin-bottom: 24px;\n  }\n  .buy-sell-toggle {\n    display: flex;\n    background: #0D1520;\n    border: 1px solid #0F2035;\n    border-radius: 50px;\n    padding: 4px;\n  }\n  .toggle-btn {\n    padding: 9px 28px;\n    border-radius: 46px;\n    border: none;\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 13px;\n    font-weight: 700;\n    cursor: pointer;\n    color: #4A6380;\n    background: transparent;\n    transition: all 0.2s;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .toggle-btn.buy-active {\n    background: linear-gradient(135deg, rgba(0,212,160,0.2), rgba(0,212,160,0.1));\n    color: #00D4A0;\n    border: 1px solid rgba(0,212,160,0.3);\n    box-shadow: 0 0 15px rgba(0,212,160,0.15);\n  }\n  .filter-chips {\n    display: flex;\n    gap: 8px;\n  }\n  .filter-chip {\n    padding: 8px 16px;\n    border-radius: 99px;\n    border: 1px solid #0F2035;\n    background: #0D1520;\n    font-size: 12px;\n    font-weight: 600;\n    color: #6B8AAA;\n    cursor: pointer;\n    transition: all 0.2s;\n    font-family: 'Manrope', sans-serif;\n  }\n  .filter-chip.active {\n    background: rgba(255,215,0,0.08);\n    border-color: rgba(255,215,0,0.2);\n    color: #FFE082;\n  }\n  .create-btn {\n    margin-left: auto;\n    padding: 9px 20px;\n    border-radius: 50px;\n    border: none;\n    background: linear-gradient(135deg, #FFD700, #FFE082);\n    color: #010B13;\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 13px;\n    font-weight: 700;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    box-shadow: 0 4px 16px rgba(255,215,0,0.3);\n    transition: all 0.2s;\n  }\n  .create-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(255,215,0,0.4); }\n\n  /* LISTINGS GRID */\n  .listings-grid {\n    display: grid;\n    grid-template-columns: repeat(2, 1fr);\n    gap: 16px;\n  }\n\n  .listing-card {\n    background: #060F1C;\n    border: 1px solid #0F2035;\n    border-radius: 20px;\n    padding: 20px;\n    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;\n    position: relative;\n    overflow: hidden;\n  }\n  .listing-card::before {\n    content: '';\n    position: absolute;\n    top: 0; left: 0; right: 0;\n    height: 2px;\n    background: linear-gradient(90deg, transparent, rgba(0,212,160,0.3), transparent);\n    opacity: 0;\n    transition: opacity 0.2s;\n  }\n  .listing-card:hover {\n    transform: translateY(-3px);\n    border-color: rgba(255,215,0,0.1);\n    box-shadow: 0 12px 40px rgba(0,0,0,0.4);\n  }\n  .listing-card:hover::before { opacity: 1; }\n\n  .card-top {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 16px;\n  }\n  .merchant-info {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n  .merchant-avatar {\n    width: 42px;\n    height: 42px;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-family: 'Space Grotesk', sans-serif;\n    font-weight: 700;\n    font-size: 15px;\n    color: #fff;\n    flex-shrink: 0;\n  }\n  .merchant-name {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 15px;\n    font-weight: 700;\n    color: #E2E8F0;\n  }\n  .merchant-sub {\n    font-size: 12px;\n    color: #4A6380;\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    margin-top: 3px;\n  }\n  .rating { color: #FFD700; font-size: 12px; font-weight: 700; }\n  .rep-badge {\n    background: rgba(0,212,160,0.1);\n    color: #00D4A0;\n    border: 1px solid rgba(0,212,160,0.2);\n    border-radius: 99px;\n    padding: 3px 10px;\n    font-size: 11px;\n    font-weight: 700;\n  }\n  .rate-display {\n    background: rgba(15,32,53,0.5);\n    border-radius: 12px;\n    padding: 12px 16px;\n    margin: 12px 0;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n  }\n  .rate-label { font-size: 11px; color: #4A6380; }\n  .rate-value {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 18px;\n    font-weight: 800;\n    color: #FFD700;\n    text-shadow: 0 0 16px rgba(255,215,0,0.25);\n  }\n  .card-footer {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    margin-top: 4px;\n  }\n  .limits-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n  }\n  .limits-text { font-size: 12px; color: #4A6380; }\n  .payment-badges { display: flex; gap: 6px; flex-wrap: wrap; }\n  .badge-cbe { background: rgba(34,197,94,0.12); color: #4ade80; border: 1px solid rgba(34,197,94,0.2); border-radius: 99px; padding: 3px 9px; font-size: 10px; font-weight: 700; }\n  .badge-telebirr { background: rgba(59,130,246,0.12); color: #60a5fa; border: 1px solid rgba(59,130,246,0.2); border-radius: 99px; padding: 3px 9px; font-size: 10px; font-weight: 700; }\n  .badge-dashen { background: rgba(168,85,247,0.12); color: #c084fc; border: 1px solid rgba(168,85,247,0.2); border-radius: 99px; padding: 3px 9px; font-size: 10px; font-weight: 700; }\n\n  .buy-btn {\n    width: 100%;\n    padding: 12px;\n    border-radius: 12px;\n    border: 1px solid rgba(0,212,160,0.25);\n    background: linear-gradient(135deg, rgba(0,212,160,0.15), rgba(0,212,160,0.08));\n    color: #00D4A0;\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 13px;\n    font-weight: 700;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 7px;\n    transition: all 0.2s;\n  }\n  .buy-btn:hover { background: rgba(0,212,160,0.25); box-shadow: 0 4px 16px rgba(0,212,160,0.15); }\n\n  .sell-btn {\n    width: 100%;\n    padding: 12px;\n    border-radius: 12px;\n    border: 1px solid rgba(239,68,68,0.25);\n    background: linear-gradient(135deg, rgba(239,68,68,0.12), rgba(239,68,68,0.06));\n    color: #EF4444;\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 13px;\n    font-weight: 700;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 7px;\n    transition: all 0.2s;\n  }\n  .sell-btn:hover { background: rgba(239,68,68,0.2); }\n</style>\n\n<div class=\"header-glow\" data-kid=\"1\"></div>\n\n\n<header class=\"top-header\" data-kid=\"2\">\n  <div class=\"logo\" data-kid=\"3\">\n    <div class=\"logo-shield\" data-kid=\"4\">ES</div>\n    <span class=\"logo-name\" data-kid=\"5\">EthioSwap</span>\n  </div>\n\n  <nav class=\"desktop-nav\" data-kid=\"6\">\n    <button class=\"nav-btn active\" data-kid=\"7\"><i class=\"ti ti-arrows-exchange\" data-kid=\"8\"></i> Trade</button>\n    <button class=\"nav-btn\" data-kid=\"9\"><i class=\"ti ti-wallet\" data-kid=\"10\"></i> Wallet</button>\n    <button class=\"nav-btn\" data-kid=\"11\"><i class=\"ti ti-messages\" data-kid=\"12\"></i> Trades <span class=\"nav-badge\" data-kid=\"13\">2</span></button>\n    <button class=\"nav-btn\" data-kid=\"14\"><i class=\"ti ti-history\" data-kid=\"15\"></i> History</button>\n    <button class=\"nav-btn\" data-kid=\"16\"><i class=\"ti ti-gift\" data-kid=\"17\"></i> Invite</button>\n    <button class=\"nav-btn\" data-kid=\"18\"><i class=\"ti ti-trophy\" data-kid=\"19\"></i> Ranks</button>\n    <button class=\"nav-btn\" data-kid=\"20\"><i class=\"ti ti-user\" data-kid=\"21\"></i> Profile</button>\n    <button class=\"nav-btn\" data-kid=\"22\"><i class=\"ti ti-settings\" data-kid=\"23\"></i> Settings</button>\n  </nav>\n\n  <div class=\"header-right\" data-kid=\"24\">\n    <div class=\"balance-display\" data-kid=\"25\">\n      <span class=\"bal-usd\" data-kid=\"26\">$1,250.00 USD</span>\n      <span class=\"bal-etb\" data-kid=\"27\">≈ 237,500 ETB</span>\n    </div>\n    <div class=\"user-capsule\" data-kid=\"28\">\n      <div class=\"user-capsule-text\" data-kid=\"29\">\n        <span class=\"username\" data-kid=\"30\">@abebe_t</span>\n        <span class=\"user-role\" data-kid=\"31\">Trader</span>\n      </div>\n      <span class=\"kyc-badge\" data-kid=\"32\">✓ Verified</span>\n    </div>\n    <button class=\"icon-btn\" data-kid=\"33\">\n      <i class=\"ti ti-bell\" style=\"font-size:18px;\" data-kid=\"34\"></i>\n      <span class=\"notif-dot\" data-kid=\"35\"></span>\n    </button>\n    <button class=\"icon-btn\" style=\"color: rgba(239,68,68,0.7); background: rgba(239,68,68,0.06); border-color: rgba(239,68,68,0.15);\" data-kid=\"36\">\n      <i class=\"ti ti-logout\" style=\"font-size:16px;\" data-kid=\"37\"></i>\n    </button>\n  </div>\n</header>\n\n\n<div class=\"page-content\" data-kid=\"38\">\n  <div class=\"page-header\" data-kid=\"39\">\n    <div data-kid=\"40\">\n      <h1 class=\"page-title\" data-kid=\"41\">P2P Marketplace</h1>\n      <p class=\"page-subtitle\" data-kid=\"42\">Buy & Sell Crypto Securely with Escrow Protection</p>\n    </div>\n    <div style=\"display:flex; align-items:center; gap:10px; font-size:12px; color:#4A6380;\" data-kid=\"43\">\n      <span style=\"display:flex; align-items:center; gap:5px;\" data-kid=\"44\">\n        <span style=\"width:8px; height:8px; background:#00D4A0; border-radius:50%; animation: pulse 2s infinite; display:inline-block;\" data-kid=\"45\"></span>\n        847 Active Listings\n      </span>\n    </div>\n  </div>\n\n  <div class=\"controls-row\" data-kid=\"46\">\n    <div class=\"buy-sell-toggle\" data-kid=\"47\">\n      <button class=\"toggle-btn buy-active\" data-kid=\"48\"><i class=\"ti ti-trending-up\" data-kid=\"49\"></i> Buy Crypto</button>\n      <button class=\"toggle-btn\" data-kid=\"50\"><i class=\"ti ti-trending-down\" data-kid=\"51\"></i> Sell Crypto</button>\n    </div>\n    <div class=\"filter-chips\" data-kid=\"52\">\n      <span class=\"filter-chip active\" data-kid=\"53\">All Assets</span>\n      <span class=\"filter-chip\" data-kid=\"54\">USDT</span>\n      <span class=\"filter-chip\" data-kid=\"55\">ETH</span>\n      <span class=\"filter-chip\" data-kid=\"56\">BTC</span>\n    </div>\n    <button class=\"create-btn\" data-kid=\"57\">\n      <i class=\"ti ti-plus\" data-kid=\"58\"></i> Create Offer\n    </button>\n  </div>\n\n  <div class=\"listings-grid\" data-kid=\"59\">\n    \n    <div class=\"listing-card\" data-kid=\"60\">\n      <div class=\"card-top\" data-kid=\"61\">\n        <div class=\"merchant-info\" data-kid=\"62\">\n          <div class=\"merchant-avatar\" style=\"background:linear-gradient(135deg,#1d4ed8,#3b82f6);\" data-kid=\"63\">AT</div>\n          <div data-kid=\"64\">\n            <div class=\"merchant-name\" data-kid=\"65\">Abebe T.</div>\n            <div class=\"merchant-sub\" data-kid=\"66\"><span class=\"rating\" data-kid=\"67\">★ 4.8</span> · 124 trades · 12h avg</div>\n          </div>\n        </div>\n        <span class=\"rep-badge\" data-kid=\"68\">99% Rep</span>\n      </div>\n      <div class=\"rate-display\" data-kid=\"69\">\n        <span class=\"rate-label\" data-kid=\"70\">Exchange Rate</span>\n        <span class=\"rate-value\" data-kid=\"71\">1 USD = 120 ETB</span>\n      </div>\n      <div class=\"card-footer\" data-kid=\"72\">\n        <div class=\"limits-row\" data-kid=\"73\">\n          <span class=\"limits-text\" data-kid=\"74\">Available: <b style=\"color:#E2E8F0\" data-kid=\"75\">1,250 USDT</b> &nbsp;|&nbsp; Min $10 — Max $500</span>\n          <div class=\"payment-badges\" data-kid=\"76\"><span class=\"badge-cbe\" data-kid=\"77\">CBE</span><span class=\"badge-telebirr\" data-kid=\"78\">Telebirr</span></div>\n        </div>\n        <button class=\"buy-btn\" data-kid=\"79\"><i class=\"ti ti-arrows-exchange\" data-kid=\"80\"></i> Buy USDT</button>\n      </div>\n    </div>\n\n    \n    <div class=\"listing-card\" data-kid=\"81\">\n      <div class=\"card-top\" data-kid=\"82\">\n        <div class=\"merchant-info\" data-kid=\"83\">\n          <div class=\"merchant-avatar\" style=\"background:linear-gradient(135deg,#be185d,#ec4899);\" data-kid=\"84\">SM</div>\n          <div data-kid=\"85\">\n            <div class=\"merchant-name\" data-kid=\"86\">Sara M.</div>\n            <div class=\"merchant-sub\" data-kid=\"87\"><span class=\"rating\" data-kid=\"88\">★ 4.6</span> · 87 trades · 1h avg</div>\n          </div>\n        </div>\n        <span class=\"rep-badge\" style=\"background:rgba(255,215,0,0.08);color:#FFE082;border-color:rgba(255,215,0,0.15);\" data-kid=\"89\">97% Rep</span>\n      </div>\n      <div class=\"rate-display\" data-kid=\"90\">\n        <span class=\"rate-label\" data-kid=\"91\">Exchange Rate</span>\n        <span class=\"rate-value\" data-kid=\"92\">1 USD = 119.5 ETB</span>\n      </div>\n      <div class=\"card-footer\" data-kid=\"93\">\n        <div class=\"limits-row\" data-kid=\"94\">\n          <span class=\"limits-text\" data-kid=\"95\">Available: <b style=\"color:#E2E8F0\" data-kid=\"96\">800 USDT</b> &nbsp;|&nbsp; Min $20 — Max $300</span>\n          <div class=\"payment-badges\" data-kid=\"97\"><span class=\"badge-dashen\" data-kid=\"98\">Dashen</span><span class=\"badge-cbe\" style=\"background:rgba(251,191,36,0.12);color:#fbbf24;border-color:rgba(251,191,36,0.2);\" data-kid=\"99\">Awash</span></div>\n        </div>\n        <button class=\"buy-btn\" data-kid=\"100\"><i class=\"ti ti-arrows-exchange\" data-kid=\"101\"></i> Buy USDT</button>\n      </div>\n    </div>\n\n    \n    <div class=\"listing-card\" data-kid=\"102\">\n      <div class=\"card-top\" data-kid=\"103\">\n        <div class=\"merchant-info\" data-kid=\"104\">\n          <div class=\"merchant-avatar\" style=\"background:linear-gradient(135deg,#c2410c,#f97316);\" data-kid=\"105\">YK</div>\n          <div data-kid=\"106\">\n            <div class=\"merchant-name\" data-kid=\"107\">Yonas K.</div>\n            <div class=\"merchant-sub\" data-kid=\"108\"><span class=\"rating\" data-kid=\"109\">★ 4.9</span> · 215 trades · 30m avg</div>\n          </div>\n        </div>\n        <span class=\"rep-badge\" style=\"background:rgba(0,212,160,0.12);color:#34EAC4;border-color:rgba(0,212,160,0.25);box-shadow:0 0 8px rgba(0,212,160,0.1);\" data-kid=\"110\">100% ✓</span>\n      </div>\n      <div class=\"rate-display\" data-kid=\"111\">\n        <span class=\"rate-label\" data-kid=\"112\">Exchange Rate</span>\n        <span class=\"rate-value\" data-kid=\"113\">1 USD = 120.5 ETB</span>\n      </div>\n      <div class=\"card-footer\" data-kid=\"114\">\n        <div class=\"limits-row\" data-kid=\"115\">\n          <span class=\"limits-text\" data-kid=\"116\">Available: <b style=\"color:#E2E8F0\" data-kid=\"117\">2,000 USDT</b> &nbsp;|&nbsp; Min $50 — Max $1,000</span>\n          <div class=\"payment-badges\" data-kid=\"118\"><span class=\"badge-cbe\" data-kid=\"119\">CBE</span></div>\n        </div>\n        <button class=\"buy-btn\" data-kid=\"120\"><i class=\"ti ti-arrows-exchange\" data-kid=\"121\"></i> Buy USDT</button>\n      </div>\n    </div>\n\n    \n    <div class=\"listing-card\" data-kid=\"122\">\n      <div class=\"card-top\" data-kid=\"123\">\n        <div class=\"merchant-info\" data-kid=\"124\">\n          <div class=\"merchant-avatar\" style=\"background:linear-gradient(135deg,#7c3aed,#a78bfa);\" data-kid=\"125\">HF</div>\n          <div data-kid=\"126\">\n            <div class=\"merchant-name\" data-kid=\"127\">Hana F.</div>\n            <div class=\"merchant-sub\" data-kid=\"128\"><span class=\"rating\" data-kid=\"129\">★ 4.7</span> · 56 trades · 2h avg</div>\n          </div>\n        </div>\n        <span class=\"rep-badge\" style=\"background:rgba(168,85,247,0.1);color:#c084fc;border-color:rgba(168,85,247,0.2);\" data-kid=\"130\">98% Rep</span>\n      </div>\n      <div class=\"rate-display\" style=\"background:rgba(239,68,68,0.04);\" data-kid=\"131\">\n        <span class=\"rate-label\" data-kid=\"132\">Exchange Rate</span>\n        <span class=\"rate-value\" style=\"color:#EF4444;text-shadow:0 0 16px rgba(239,68,68,0.25);\" data-kid=\"133\">1 USD = 119 ETB</span>\n      </div>\n      <div class=\"card-footer\" data-kid=\"134\">\n        <div class=\"limits-row\" data-kid=\"135\">\n          <span class=\"limits-text\" data-kid=\"136\">Available: <b style=\"color:#E2E8F0\" data-kid=\"137\">500 USDT</b> &nbsp;|&nbsp; Min $10 — Max $200</span>\n          <div class=\"payment-badges\" data-kid=\"138\"><span class=\"badge-telebirr\" data-kid=\"139\">Telebirr</span></div>\n        </div>\n        <button class=\"sell-btn\" data-kid=\"140\"><i class=\"ti ti-arrows-exchange\" data-kid=\"141\"></i> Sell USDT</button>\n      </div>\n    </div>\n  </div>\n</div>\n",
