ta-kid=\"132\"></rect>\n          <rect x=\"92\" y=\"128\" width=\"6\" height=\"6\" fill=\"#111\" data-kid=\"133\"></rect>\n          <rect x=\"108\" y=\"128\" width=\"6\" height=\"6\" fill=\"#111\" data-kid=\"134\"></rect>\n          <rect x=\"124\" y=\"128\" width=\"6\" height=\"6\" fill=\"#111\" data-kid=\"135\"></rect>\n        </svg>\n        <span class=\"qr-label\" data-kid=\"136\">USDT · TRC20</span>\n      </div>\n    </div>\n\n    \n    <div class=\"addr-box\" data-kid=\"137\">\n      <span class=\"addr-text\" data-kid=\"138\">TKXf7xK9mGhR2PAb3Zq8dNr4Vm5cJw9m3Z</span>\n      <span class=\"copy-icon-btn\" data-kid=\"139\"><i class=\"ti ti-copy\" data-kid=\"140\"></i></span>\n    </div>\n\n    \n    <div class=\"divider-row\" data-kid=\"141\">OR SUBMIT TRANSACTION</div>\n\n    \n    <input class=\"input-field\" type=\"text\" placeholder=\"Enter TxID / Reference Code...\" data-kid=\"142\">\n\n    \n    <div class=\"upload-zone\" data-kid=\"143\">\n      <div class=\"upload-zone-icon\" data-kid=\"144\"><i class=\"ti ti-cloud-upload\" data-kid=\"145\"></i></div>\n      <div class=\"upload-title\" data-kid=\"146\">Drop proof of payment here</div>\n      <div class=\"upload-sub\" data-kid=\"147\">PNG, JPG, PDF up to 10MB</div>\n    </div>\n\n    \n    <div class=\"tg-note\" data-kid=\"148\">\n      <span class=\"tg-note-icon\" data-kid=\"149\"><i class=\"ti ti-brand-telegram\" data-kid=\"150\"></i></span>\n      <span class=\"tg-note-text\" data-kid=\"151\"><b data-kid=\"152\">Telegram OTP required.</b> A 6-digit code will be sent to your connected Telegram bot before submission.</span>\n    </div>\n\n    \n    <button class=\"btn-gold\" data-kid=\"153\">\n      <i class=\"ti ti-send\" style=\"font-size:15px\" data-kid=\"154\"></i>\n      Submit Deposit Request\n    </button>\n\n  </div>\n\n  \n  <div class=\"section-divider\" data-kid=\"155\"><span data-kid=\"156\">Withdraw Preview</span></div>\n  <div class=\"preview-badge\" data-kid=\"157\">\n    <i class=\"ti ti-eye\" style=\"font-size:10px\" data-kid=\"158\"></i>\n    Preview Only\n  </div>\n\n  <div class=\"withdraw-section\" data-kid=\"159\">\n    \n    <div data-kid=\"160\">\n      <div class=\"section-label\" data-kid=\"161\">Amount</div>\n      <div class=\"amount-row\" data-kid=\"162\">\n        <div class=\"amount-input-wrap\" data-kid=\"163\">\n          <input class=\"amount-input\" placeholder=\"0.00\" value=\"250.00\" readonly data-kid=\"164\">\n        </div>\n        <div class=\"currency-toggle\" data-kid=\"165\">\n          <button class=\"cur-btn active\" data-kid=\"166\">USD</button>\n          <button class=\"cur-btn\" data-kid=\"167\">ETB</button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div data-kid=\"168\">\n      <div class=\"section-label\" data-kid=\"169\">Target Wallet Address</div>\n      <input class=\"input-field\" type=\"text\" placeholder=\"Enter destination wallet address...\" data-kid=\"170\">\n    </div>\n\n    \n    <div data-kid=\"171\">\n      <div class=\"section-label\" data-kid=\"172\">6-Digit OTP Code</div>\n      <div class=\"otp-row\" data-kid=\"173\">\n        <div class=\"otp-box\" data-kid=\"174\">•</div>\n        <div class=\"otp-box\" data-kid=\"175\">•</div>\n        <div class=\"otp-box\" data-kid=\"176\">•</div>\n        <div class=\"otp-box\" data-kid=\"177\">•</div>\n        <div class=\"otp-box\" data-kid=\"178\">•</div>\n        <div class=\"otp-box\" data-kid=\"179\">•</div>\n      </div>\n    </div>\n\n    \n    <div class=\"fee-box\" data-kid=\"180\">\n      <div class=\"fee-row\" data-kid=\"181\">\n        <span class=\"fee-label\" data-kid=\"182\">Withdrawal Amount</span>\n        <span class=\"fee-val\" data-kid=\"183\">$250.00</span>\n      </div>\n      <div class=\"fee-row\" data-kid=\"184\">\n        <span class=\"fee-label\" data-kid=\"185\">Platform Fee (1%)</span>\n        <span class=\"fee-val\" style=\"color:#FFD700\" data-kid=\"186\">-$2.50</span>\n      </div>\n      <div class=\"fee-row\" data-kid=\"187\">\n        <span class=\"fee-label\" data-kid=\"188\">Network Fee</span>\n        <span class=\"fee-val\" style=\"color:#FFD700\" data-kid=\"189\">-$1.50</span>\n      </div>\n      <div class=\"fee-sep\" data-kid=\"190\"></div>\n      <div class=\"fee-row\" data-kid=\"191\">\n        <span class=\"fee-total-label\" data-kid=\"192\">You Get</span>\n        <span class=\"fee-total-val\" data-kid=\"193\">$246.00</span>\n      </div>\n    </div>\n\n    \n    <button class=\"btn-teal\" data-kid=\"194\">\n      <i class=\"ti ti-arrow-up-right\" style=\"font-size:15px\" data-kid=\"195\"></i>\n      Withdraw Funds\n    </button>\n\n  </div>\n\n</div>\n",
