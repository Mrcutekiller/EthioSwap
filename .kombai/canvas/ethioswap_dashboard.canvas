      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n* { box-sizing: border-box; margin: 0; padding: 0; }\nbody { font-family: 'Manrope', sans-serif; background: #010B13; color: #E2E8F0; min-height: 100vh; }\n\n.page { background: #010B13; min-height: 100vh; padding: 20px 16px 100px; position: relative; overflow: hidden; }\n\n.bg-glow { position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none; z-index: 0; opacity: 0.22; }\n.bg-glow-1 { width: 280px; height: 280px; top: -60px; right: -60px; background: radial-gradient(circle, rgba(99,102,241,0.25) 0%, transparent 70%); }\n.bg-glow-2 { width: 260px; height: 260px; bottom: 20%; left: -60px; background: radial-gradient(circle, rgba(255,215,0,0.15) 0%, transparent 70%); }\n\n.content { position: relative; z-index: 1; }\n\n.hero-card {\n  position: relative; border-radius: 24px; padding: 22px 20px;\n  overflow: hidden; margin-bottom: 18px;\n  background: linear-gradient(135deg, #060F1C 0%, #0A0E1A 100%);\n  border: 1px solid rgba(99,102,241,0.3);\n  box-shadow: 0 0 30px rgba(99,102,241,0.08), 0 0 60px rgba(255,215,0,0.04);\n}\n.hex-pattern {\n  position: absolute; inset: 0;\n  background-image:\n    repeating-linear-gradient(60deg, transparent, transparent 18px, rgba(99,102,241,0.04) 18px, rgba(99,102,241,0.04) 19px),\n    repeating-linear-gradient(-60deg, transparent, transparent 18px, rgba(99,102,241,0.04) 18px, rgba(99,102,241,0.04) 19px),\n    repeating-linear-gradient(0deg, transparent, transparent 18px, rgba(99,102,241,0.04) 18px, rgba(99,102,241,0.04) 19px);\n  pointer-events: none; z-index: 0;\n}\n.hero-gl-1 { position: absolute; top: -40px; left: -40px; width: 180px; height: 180px; background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%); pointer-events: none; z-index: 0; filter: blur(30px); }\n.hero-gl-2 { position: absolute; top: -20px; right: -30px; width: 150px; height: 150px; background: radial-gradient(circle, rgba(255,215,0,0.12) 0%, transparent 70%); pointer-events: none; z-index: 0; filter: blur(25px); }\n.hero-content { position: relative; z-index: 1; }\n\n.hero-title-row { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }\n.hero-title-row .emoji { font-size: 22px; }\n.hero-title-row h1 { font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 800; color: #E2E8F0; letter-spacing: -0.03em; }\n.hero-subtitle { font-size: 12px; color: #6B8AAA; line-height: 1.5; margin-bottom: 18px; max-width: 280px; }\n\n.ref-link-row { display: flex; gap: 8px; margin-bottom: 16px; align-items: center; }\n.ref-link-input { flex: 1; background: rgba(1,11,19,0.7); border: 1px solid #0F2035; border-radius: 12px; padding: 9px 12px; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #6B8AAA; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n.ref-copy-btn { background: linear-gradient(135deg, #FFD700, #FFE082); color: #010B13; border: none; border-radius: 12px; padding: 9px 14px; font-size: 12px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 5px; font-family: 'Manrope', sans-serif; white-space: nowrap; box-shadow: 0 4px 12px rgba(255,215,0,0.2); }\n\n.social-row { display: flex; gap: 10px; align-items: center; }\n.social-label { font-size: 11px; color: #4A6380; font-weight: 600; }\n.social-btn { width: 36px; height: 36px; border-radius: 50%; border: none; display: flex; align-items: center; justify-content: center; font-size: 16px; cursor: pointer; transition: transform 0.15s; }\n.social-btn:hover { transform: scale(1.08); }\n.social-wa { background: rgba(37,211,102,0.15); color: #25D366; border: 1px solid rgba(37,211,102,0.25); }\n.social-tg { background: rgba(0,136,204,0.15); color: #0088cc; border: 1px solid rgba(0,136,204,0.25); }\n.social-link { background: rgba(255,215,0,0.12); color: #FFD700; border: 1px solid rgba(255,215,0,0.25); }\n\n.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 20px; }\n.stat-tile { border-radius: 18px; padding: 14px 10px; text-align: center; border: 1px solid; }\n.stat-tile.gold-tint { background: linear-gradient(135deg, rgba(255,215,0,0.07), rgba(255,215,0,0.02)); border-color: rgba(255,215,0,0.2); }\n.stat-tile.teal-tint { background: linear-gradient(135deg, rgba(0,212,160,0.07), rgba(0,212,160,0.02)); border-color: rgba(0,212,160,0.2); }\n.stat-tile.indigo-tint { background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(99,102,241,0.02)); border-color: rgba(99,102,241,0.2); }\n.stat-num { font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 800; letter-spacing: -0.04em; display: block; margin-bottom: 2px; }\n.stat-num.gold { color: #FFD700; text-shadow: 0 0 20px rgba(255,215,0,0.25); }\n.stat-num.teal { color: #00D4A0; text-shadow: 0 0 20px rgba(0,212,160,0.2); }\n.stat-num.indigo { color: #818CF8; }\n.stat-label { font-size: 10px; color: #4A6380; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.3; }\n\n.table-section { margin-bottom: 20px; }\n.table-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }\n.table-title { font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 700; color: #E2E8F0; }\n.table-count { font-size: 11px; color: #4A6380; background: #060F1C; border: 1px solid #0F2035; border-radius: 99px; padding: 2px 8px; }\n\n.ref-table { background: #060F1C; border: 1px solid #0F2035; border-radius: 18px; overflow: hidden; }\n.ref-table-head { display: grid; grid-template-columns: 1fr 1fr 80px; padding: 10px 14px; border-bottom: 1px solid #0F2035; background: rgba(255,255,255,0.01); }\n.ref-th { font-size: 10px; font-weight: 700; color: #4A6380; text-transform: uppercase; letter-spacing: 0.06em; }\n\n.ref-row { display: grid; grid-template-columns: 1fr 1fr 80px; padding: 11px 14px; border-bottom: 1px solid rgba(15,32,53,0.5); align-items: center; transition: background 0.12s; }\n.ref-row:last-child { border-bottom: none; }\n.ref-row:nth-child(even) { background: rgba(255,255,255,0.012); }\n.ref-username { font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 600; color: #E2E8F0; }\n.ref-date { font-size: 11px; color: #6B8AAA; }\n.ref-status { display: inline-flex; align-items: center; gap: 3px; padding: 3px 8px; border-radius: 99px; font-size: 10px; font-weight: 700; font-family: 'Manrope', sans-serif; justify-self: start; }\n.ref-status.rewarded { background: rgba(0,212,160,0.1); border: 1px solid rgba(0,212,160,0.25); color: #00D4A0; }\n.ref-status.pending { background: rgba(255,215,0,0.1); border: 1px solid rgba(255,215,0,0.25); color: #FFD700; }\n\n.cta-btn { width: 100%; padding: 15px; background: linear-gradient(135deg, #FFD700 0%, #FFE082 100%); color: #010B13; border: none; border-radius: 16px; font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 800; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; box-shadow: 0 6px 24px rgba(255,215,0,0.25); letter-spacing: -0.01em; }\n</style>\n\n<div class=\"page\" data-kid=\"1\">\n  <div class=\"bg-glow bg-glow-1\" data-kid=\"2\"></div>\n  <div class=\"bg-glow bg-glow-2\" data-kid=\"3\"></div>\n  <div class=\"content\" data-kid=\"4\">\n    <div class=\"hero-card\" data-kid=\"5\">\n      <div class=\"hex-pattern\" data-kid=\"6\"></div>\n      <div class=\"hero-gl-1\" data-kid=\"7\"></div>\n      <div class=\"hero-gl-2\" data-kid=\"8\"></div>\n      <div class=\"hero-content\" data-kid=\"9\">\n        <div class=\"hero-title-row\" data-kid=\"10\">\n          <span class=\"emoji\" data-kid=\"11\">🎁</span>\n          <h1 data-kid=\"12\">Invite &amp; Earn</h1>\n        </div>\n        <p class=\"hero-subtitle\" data-kid=\"13\">Earn 100 points for every friend who completes their first trade on EthioSwap.</p>\n        <div class=\"ref-link-row\" data-kid=\"14\">\n          <div class=\"ref-link-input\" data-kid=\"15\">https://ethioswap.com/r/ABEBE123</div>\n          <button class=\"ref-copy-btn\" data-kid=\"16\"><i class=\"ti ti-copy\" data-kid=\"17\"></i> Copy</button>\n        </div>\n        <div class=\"social-row\" data-kid=\"18\">\n          <span class=\"social-label\" data-kid=\"19\">Share via:</span>\n          <button class=\"social-btn social-wa\" data-kid=\"20\"><i class=\"ti ti-brand-whatsapp\" data-kid=\"21\"></i></button>\n          <button class=\"social-btn social-tg\" data-kid=\"22\"><i class=\"ti ti-brand-telegram\" data-kid=\"23\"></i></button>\n          <button class=\"social-btn social-link\" data-kid=\"24\"><i class=\"ti ti-link\" data-kid=\"25\"></i></button>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"stats-grid\" data-kid=\"26\">\n      <div class=\"stat-tile gold-tint\" data-kid=\"27\">\n        <span class=\"stat-num gold\" data-kid=\"28\">12</span>\n        <div class=\"stat-label\" data-kid=\"29\">Successful Invites</div>\n      </div>\n      <div class=\"stat-tile teal-tint\" data-kid=\"30\">\n        <span class=\"stat-num teal\" data-kid=\"31\">1,240</span>\n        <div class=\"stat-label\" data-kid=\"32\">Points Earned</div>\n      </div>\n      <div class=\"stat-tile indigo-tint\" data-kid=\"33\">\n        <span class=\"stat-num indigo\" data-kid=\"34\">$5.00</span>\n        <div class=\"stat-label\" data-kid=\"35\">Pending Rewards</div>\n      </div>\n    </div>\n\n    <div class=\"table-section\" data-kid=\"36\">\n      <div class=\"table-header-row\" data-kid=\"37\">\n        <span class=\"table-title\" data-kid=\"38\">Your Referrals</span>\n        <span class=\"table-count\" data-kid=\"39\">12 total</span>\n      </div>\n      <div class=\"ref-table\" data-kid=\"40\">\n        <div class=\"ref-table-head\" data-kid=\"41\">\n          <span class=\"ref-th\" data-kid=\"42\">Username</span>\n          <span class=\"ref-th\" data-kid=\"43\">Date</span>\n          <span class=\"ref-th\" data-kid=\"44\">Status</span>\n        </div>\n        <div class=\"ref-row\" data-kid=\"45\">\n          <span class=\"ref-username\" data-kid=\"46\">@tadesse_k</span>\n          <span class=\"ref-date\" data-kid=\"47\">May 2026</span>\n          <span class=\"ref-status rewarded\" data-kid=\"48\">✓ Rewarded</span>\n        </div>\n        <div class=\"ref-row\" data-kid=\"49\">\n          <span class=\"ref-username\" data-kid=\"50\">@mekdes_a</span>\n          <span class=\"ref-date\" data-kid=\"51\">May 2026</span>\n          <span class=\"ref-status rewarded\" data-kid=\"52\">✓ Rewarded</span>\n        </div>\n        <div class=\"ref-row\" data-kid=\"53\">\n          <span class=\"ref-username\" data-kid=\"54\">@belay_m</span>\n          <span class=\"ref-date\" data-kid=\"55\">Apr 2026</span>\n          <span class=\"ref-status rewarded\" data-kid=\"56\">✓ Rewarded</span>\n        </div>\n        <div class=\"ref-row\" data-kid=\"57\">\n          <span class=\"ref-username\" data-kid=\"58\">@yeshi_t</span>\n          <span class=\"ref-date\" data-kid=\"59\">Jun 2026</span>\n          <span class=\"ref-status pending\" data-kid=\"60\">⏳ Pending</span>\n        </div>\n        <div class=\"ref-row\" data-kid=\"61\">\n          <span class=\"ref-username\" data-kid=\"62\">@girma_b</span>\n          <span class=\"ref-date\" data-kid=\"63\">Jun 2026</span>\n          <span class=\"ref-status pending\" data-kid=\"64\">⏳ Pending</span>\n        </div>\n      </div>\n    </div>\n\n    <button class=\"cta-btn\" data-kid=\"65\">\n      <i class=\"ti ti-gift\" style=\"font-size:18px;\" data-kid=\"66\"></i>\n      Claim Pending Rewards ($5.00)\n    </button>\n  </div>\n</div>\n",
