      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n* { box-sizing: border-box; margin: 0; padding: 0; }\n\nbody {\n  font-family: 'Manrope', sans-serif;\n  background: #010B13;\n  color: #E2E8F0;\n  padding-bottom: 32px;\n}\n\n.page {\n  padding: 20px 16px 40px;\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n  min-height: 100vh;\n  position: relative;\n}\n\n.page::before {\n  content: '';\n  position: fixed;\n  top: -100px; left: 50%;\n  transform: translateX(-50%);\n  width: 300px; height: 300px;\n  background: radial-gradient(circle, rgba(0,212,160,0.07) 0%, transparent 70%);\n  pointer-events: none;\n  z-index: 0;\n}\n\n/* Cards */\n.card {\n  background: #060F1C;\n  border: 1px solid #0F2035;\n  border-radius: 24px;\n  padding: 20px;\n  position: relative;\n  z-index: 1;\n}\n\n.section-label {\n  font-size: 10px;\n  font-weight: 800;\n  color: #4A6380;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  margin-bottom: 14px;\n}\n\n/* User Info Header */\n.user-header {\n  background: linear-gradient(145deg, #060F1C 0%, #0A1520 100%);\n  border-color: #0F2035;\n  overflow: hidden;\n}\n\n.user-header::before {\n  content: '';\n  position: absolute;\n  top: -40px; right: -40px;\n  width: 160px; height: 160px;\n  background: radial-gradient(circle, rgba(0,212,160,0.08) 0%, transparent 70%);\n  pointer-events: none;\n}\n\n.user-avatar-wrap {\n  position: relative;\n  width: 60px;\n  height: 60px;\n  flex-shrink: 0;\n}\n\n.rainbow-ring {\n  width: 60px;\n  height: 60px;\n  border-radius: 50%;\n  background: linear-gradient(45deg, #00D4A0, #FFD700, #6366F1, #EC4899, #00D4A0);\n  background-size: 200% 200%;\n  animation: rainbow-rotate 4s linear infinite;\n  padding: 2.5px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n@keyframes rainbow-rotate {\n  0%   { background-position: 0% 50%; }\n  50%  { background-position: 100% 50%; }\n  100% { background-position: 0% 50%; }\n}\n\n.avatar-inner {\n  width: 100%;\n  height: 100%;\n  border-radius: 50%;\n  background: linear-gradient(135deg, #0F2035 0%, #1A3050 100%);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 18px;\n  font-weight: 800;\n  background: linear-gradient(135deg, #FFD700 0%, #00D4A0 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  background-color: #0A1520;\n  border: 2px solid #060F1C;\n}\n\n.kyc-verified-badge {\n  position: absolute;\n  top: -4px;\n  right: -4px;\n  background: rgba(0,212,160,0.15);\n  border: 1px solid rgba(0,212,160,0.4);\n  border-radius: 99px;\n  padding: 2px 7px;\n  font-size: 9px;\n  font-weight: 800;\n  color: #00D4A0;\n  white-space: nowrap;\n}\n\n.user-name {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 20px;\n  font-weight: 800;\n  color: #E2E8F0;\n  letter-spacing: -0.02em;\n  line-height: 1.1;\n}\n\n.user-meta {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  flex-wrap: wrap;\n  margin-top: 3px;\n}\n\n.user-username {\n  font-size: 13px;\n  color: #6B8AAA;\n  font-weight: 500;\n}\n\n.user-rating {\n  font-size: 12px;\n  color: #FFD700;\n  font-weight: 700;\n}\n\n.user-join {\n  font-size: 11px;\n  color: #4A6380;\n}\n\n.loyalty-section {\n  margin-top: 14px;\n}\n\n.loyalty-row {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 6px;\n}\n\n.loyalty-label {\n  font-size: 11px;\n  color: #6B8AAA;\n  font-weight: 600;\n}\n\n.loyalty-pts {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 14px;\n  font-weight: 800;\n  color: #FFD700;\n}\n\n.loyalty-bar {\n  height: 5px;\n  border-radius: 99px;\n  background: #0F2035;\n  overflow: hidden;\n}\n\n.loyalty-fill {\n  height: 100%;\n  width: 62%;\n  background: linear-gradient(90deg, #FFD700, #FFE082);\n  border-radius: 99px;\n  position: relative;\n  overflow: hidden;\n}\n\n.loyalty-fill::after {\n  content: '';\n  position: absolute;\n  top: 0; left: -100%; width: 60%; height: 100%;\n  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);\n  animation: shine 2s ease infinite;\n}\n\n@keyframes shine { to { left: 150%; } }\n\n/* Stats Grid */\n.stats-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 10px;\n  position: relative;\n  z-index: 1;\n}\n\n.stat-tile {\n  background: #060F1C;\n  border: 1px solid #0F2035;\n  border-radius: 18px;\n  padding: 14px 16px;\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.stat-tile-label {\n  font-size: 10px;\n  font-weight: 700;\n  color: #4A6380;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n}\n\n.stat-tile-value {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 26px;\n  font-weight: 800;\n  line-height: 1.1;\n  letter-spacing: -0.03em;\n}\n\n.gold-val { color: #FFD700; }\n.teal-val { color: #00D4A0; }\n.orange-val { color: #FF6B35; }\n\n/* KYC Wizard Card */\n.kyc-card { position: relative; z-index: 1; }\n\n.kyc-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 16px;\n}\n\n.kyc-title {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 15px;\n  font-weight: 800;\n  color: #E2E8F0;\n}\n\n.kyc-steps {\n  display: flex;\n  flex-direction: column;\n  gap: 0;\n}\n\n.kyc-step {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 10px 0;\n  position: relative;\n}\n\n.kyc-step:not(:last-child)::after {\n  content: '';\n  position: absolute;\n  left: 12px;\n  top: 100%;\n  width: 2px;\n  height: 10px;\n  background: #0F2035;\n  z-index: 0;\n}\n\n.kyc-step.done .kyc-step:not(:last-child)::after {\n  background: rgba(0,212,160,0.3);\n}\n\n.step-dot {\n  width: 26px;\n  height: 26px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 12px;\n  font-weight: 700;\n  flex-shrink: 0;\n  border: 2px solid #0F2035;\n  background: #0A1520;\n  color: #4A6380;\n  z-index: 1;\n}\n\n.step-dot.done {\n  background: rgba(0,212,160,0.15);\n  border-color: rgba(0,212,160,0.4);\n  color: #00D4A0;\n}\n\n.step-label {\n  font-size: 13px;\n  color: #6B8AAA;\n  font-weight: 500;\n}\n\n.step-dot.done + .step-label { color: #00D4A0; font-weight: 600; }\n\n.verified-banner {\n  margin-top: 14px;\n  background: linear-gradient(135deg, rgba(0,212,160,0.12) 0%, rgba(0,180,135,0.06) 100%);\n  border: 1px solid rgba(0,212,160,0.3);\n  border-radius: 14px;\n  padding: 12px 16px;\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.verified-icon {\n  font-size: 22px;\n}\n\n.verified-text {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 14px;\n  font-weight: 800;\n  color: #00D4A0;\n}\n\n/* Unverified state */\n.unverified-section {\n  margin-top: 16px;\n  border-top: 1px solid #0F2035;\n  padding-top: 16px;\n}\n\n.unverified-label {\n  font-size: 10px;\n  font-weight: 800;\n  color: #4A6380;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  margin-bottom: 12px;\n}\n\n.start-kyc-btn {\n  width: 100%;\n  padding: 14px;\n  border-radius: 14px;\n  background: linear-gradient(135deg, #FFD700, #FFA500);\n  color: #010B13;\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 14px;\n  font-weight: 800;\n  border: none;\n  cursor: pointer;\n  margin-top: 14px;\n  box-shadow: 0 4px 20px rgba(255,215,0,0.3);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 8px;\n}\n\n/* Telegram Card */\n.tg-card { position: relative; z-index: 1; }\n\n.tg-header {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  margin-bottom: 14px;\n}\n\n.tg-icon-wrap {\n  width: 38px;\n  height: 38px;\n  border-radius: 10px;\n  background: rgba(42,171,238,0.1);\n  border: 1px solid rgba(42,171,238,0.2);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 18px;\n}\n\n.tg-title {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 14px;\n  font-weight: 800;\n  color: #E2E8F0;\n}\n\n.tg-subtitle {\n  font-size: 11px;\n  color: #4A6380;\n}\n\n.tg-connected-row {\n  background: rgba(0,212,160,0.04);\n  border: 1px solid rgba(0,212,160,0.15);\n  border-radius: 12px;\n  padding: 12px 14px;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n}\n\n.tg-connected-status {\n  font-size: 12px;\n  font-weight: 700;\n  color: #00D4A0;\n}\n\n.tg-chat-id {\n  font-size: 10px;\n  color: #4A6380;\n  font-family: 'JetBrains Mono', monospace;\n}\n\n.tg-disconnect {\n  font-size: 11px;\n  color: #4A6380;\n  text-decoration: underline;\n  cursor: pointer;\n}\n\n.tg-connect-btn {\n  width: 100%;\n  padding: 12px;\n  border-radius: 12px;\n  background: linear-gradient(135deg, #FFD700, #FFE082);\n  color: #010B13;\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 13px;\n  font-weight: 800;\n  border: none;\n  cursor: pointer;\n  margin-top: 8px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 6px;\n}\n\n/* Badges */\n.badges-grid {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 10px;\n  position: relative;\n  z-index: 1;\n}\n\n.badge-tile {\n  background: #060F1C;\n  border: 1px solid #0F2035;\n  border-radius: 16px;\n  padding: 12px 8px 10px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 5px;\n}\n\n.badge-tile.locked {\n  opacity: 0.38;\n  filter: grayscale(0.8);\n}\n\n.badge-emoji { font-size: 24px; }\n\n.badge-name {\n  font-size: 9px;\n  font-weight: 700;\n  color: #6B8AAA;\n  text-align: center;\n}\n\n.badges-card { position: relative; z-index: 1; }\n</style>\n\n<div class=\"page\" data-kid=\"1\">\n\n  \n  <div class=\"card user-header\" data-kid=\"2\">\n    <div style=\"display:flex;align-items:flex-start;gap:14px;position:relative;\" data-kid=\"3\">\n      <div class=\"user-avatar-wrap\" data-kid=\"4\">\n        <div class=\"rainbow-ring\" data-kid=\"5\">\n          <div class=\"avatar-inner\" data-kid=\"6\">AT</div>\n        </div>\n      </div>\n      <div style=\"flex:1;min-width:0;\" data-kid=\"7\">\n        <div class=\"user-name\" data-kid=\"8\">Abebe Tadesse</div>\n        <div class=\"user-meta\" data-kid=\"9\">\n          <span class=\"user-username\" data-kid=\"10\">@abebe_t</span>\n          <span class=\"user-rating\" data-kid=\"11\">4.8 ★</span>\n          <span class=\"user-join\" data-kid=\"12\">· Joined May 2026</span>\n        </div>\n      </div>\n      <span class=\"kyc-verified-badge\" data-kid=\"13\">✓ Verified</span>\n    </div>\n    <div class=\"loyalty-section\" data-kid=\"14\">\n      <div class=\"loyalty-row\" data-kid=\"15\">\n        <span class=\"loyalty-label\" data-kid=\"16\">Loyalty Points · Silver Tier</span>\n        <span class=\"loyalty-pts\" data-kid=\"17\">1,240 pts</span>\n      </div>\n      <div class=\"loyalty-bar\" data-kid=\"18\">\n        <div class=\"loyalty-fill\" data-kid=\"19\"></div>\n      </div>\n      <div style=\"display:flex;justify-content:flex-end;margin-top:4px;\" data-kid=\"20\">\n        <span style=\"font-size:9px;color:#4A6380;\" data-kid=\"21\">620 pts to Gold Tier</span>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"stats-grid\" data-kid=\"22\">\n    <div class=\"stat-tile\" data-kid=\"23\">\n      <div class=\"stat-tile-label\" data-kid=\"24\">Total Trades</div>\n      <div class=\"stat-tile-value gold-val\" data-kid=\"25\">47</div>\n    </div>\n    <div class=\"stat-tile\" data-kid=\"26\">\n      <div class=\"stat-tile-label\" data-kid=\"27\">Trade Volume</div>\n      <div class=\"stat-tile-value teal-val\" style=\"font-size:22px;\" data-kid=\"28\">$9,280</div>\n    </div>\n    <div class=\"stat-tile\" data-kid=\"29\">\n      <div class=\"stat-tile-label\" data-kid=\"30\">Reputation</div>\n      <div class=\"stat-tile-value gold-val\" data-kid=\"31\">99%</div>\n    </div>\n    <div class=\"stat-tile\" data-kid=\"32\">\n      <div class=\"stat-tile-label\" data-kid=\"33\">Active Streak</div>\n      <div class=\"stat-tile-value orange-val\" style=\"font-size:18px;\" data-kid=\"34\">🔥 7d</div>\n    </div>\n  </div>\n\n  \n  <div class=\"card kyc-card\" data-kid=\"35\">\n    <div class=\"kyc-header\" data-kid=\"36\">\n      <div class=\"kyc-title\" data-kid=\"37\">Identity Verification</div>\n      <span style=\"background:rgba(0,212,160,0.1);border:1px solid rgba(0,212,160,0.3);border-radius:99px;padding:3px 10px;font-size:10px;font-weight:800;color:#00D4A0;\" data-kid=\"38\">✓ Approved</span>\n    </div>\n    <div class=\"kyc-steps\" data-kid=\"39\">\n      <div class=\"kyc-step\" data-kid=\"40\">\n        <div class=\"step-dot done\" data-kid=\"41\">✓</div>\n        <div class=\"step-label\" data-kid=\"42\">Account Created</div>\n      </div>\n      <div class=\"kyc-step\" data-kid=\"43\">\n        <div class=\"step-dot done\" data-kid=\"44\">✓</div>\n        <div class=\"step-label\" data-kid=\"45\">ID / Passport Uploaded</div>\n      </div>\n      <div class=\"kyc-step\" data-kid=\"46\">\n        <div class=\"step-dot done\" data-kid=\"47\">✓</div>\n        <div class=\"step-label\" data-kid=\"48\">Selfie Verified</div>\n      </div>\n      <div class=\"kyc-step\" data-kid=\"49\">\n        <div class=\"step-dot done\" data-kid=\"50\">✓</div>\n        <div class=\"step-label\" data-kid=\"51\">Admin Approved</div>\n      </div>\n    </div>\n    <div class=\"verified-banner\" data-kid=\"52\">\n      <span class=\"verified-icon\" data-kid=\"53\">✅</span>\n      <div data-kid=\"54\">\n        <div class=\"verified-text\" data-kid=\"55\">Identity Verified</div>\n        <div style=\"font-size:11px;color:#6B8AAA;margin-top:1px;\" data-kid=\"56\">You can trade freely on EthioSwap</div>\n      </div>\n    </div>\n\n    \n    <div class=\"unverified-section\" data-kid=\"57\">\n      <div class=\"unverified-label\" data-kid=\"58\">⬇ Unverified State Preview</div>\n      <div class=\"kyc-steps\" data-kid=\"59\">\n        <div class=\"kyc-step\" data-kid=\"60\">\n          <div class=\"step-dot done\" data-kid=\"61\">✓</div>\n          <div class=\"step-label\" data-kid=\"62\">Account Created</div>\n        </div>\n        <div class=\"kyc-step\" data-kid=\"63\">\n          <div class=\"step-dot\" style=\"color:#4A6380;\" data-kid=\"64\">2</div>\n          <div class=\"step-label\" style=\"color:#4A6380;\" data-kid=\"65\">ID / Passport Upload</div>\n        </div>\n        <div class=\"kyc-step\" data-kid=\"66\">\n          <div class=\"step-dot\" style=\"color:#4A6380;\" data-kid=\"67\">3</div>\n          <div class=\"step-label\" style=\"color:#4A6380;\" data-kid=\"68\">Selfie Verification</div>\n        </div>\n        <div class=\"kyc-step\" data-kid=\"69\">\n          <div class=\"step-dot\" style=\"color:#4A6380;\" data-kid=\"70\">4</div>\n          <div class=\"step-label\" style=\"color:#4A6380;\" data-kid=\"71\">Admin Approval</div>\n        </div>\n      </div>\n      <button class=\"start-kyc-btn\" data-kid=\"72\">🪪 Start Identity Verification →</button>\n    </div>\n  </div>\n\n  \n  <div class=\"card tg-card\" data-kid=\"73\">\n    <div class=\"tg-header\" data-kid=\"74\">\n      <div class=\"tg-icon-wrap\" data-kid=\"75\">✈️</div>\n      <div data-kid=\"76\">\n        <div class=\"tg-title\" data-kid=\"77\">Telegram Bot</div>\n        <div class=\"tg-subtitle\" data-kid=\"78\">Receive alerts & OTP codes</div>\n      </div>\n    </div>\n    \n    <div class=\"tg-connected-row\" data-kid=\"79\">\n      <div data-kid=\"80\">\n        <div class=\"tg-connected-status\" data-kid=\"81\">🟢 Connected</div>\n        <div class=\"tg-chat-id\" data-kid=\"82\">Chat ID: 123456789</div>\n      </div>\n      <span class=\"tg-disconnect\" data-kid=\"83\">Disconnect</span>\n    </div>\n    \n    <button class=\"tg-connect-btn\" style=\"margin-top:12px;background:rgba(255,215,0,0.08);color:#FFD700;border:1px solid rgba(255,215,0,0.2);\" data-kid=\"84\">\n      🔌 Connect Telegram Bot\n    </button>\n  </div>\n\n  \n  <div class=\"card badges-card\" data-kid=\"85\">\n    <div class=\"section-label\" data-kid=\"86\">Badges & Achievements</div>\n    <div class=\"badges-grid\" data-kid=\"87\">\n      <div class=\"badge-tile\" data-kid=\"88\">\n        <div class=\"badge-emoji\" data-kid=\"89\">🥉</div>\n        <div class=\"badge-name\" data-kid=\"90\">Bronze</div>\n      </div>\n      <div class=\"badge-tile locked\" data-kid=\"91\">\n        <div class=\"badge-emoji\" data-kid=\"92\">🥈</div>\n        <div class=\"badge-name\" data-kid=\"93\">Silver</div>\n      </div>\n      <div class=\"badge-tile locked\" data-kid=\"94\">\n        <div class=\"badge-emoji\" data-kid=\"95\">🥇</div>\n        <div class=\"badge-name\" data-kid=\"96\">Gold</div>\n      </div>\n      <div class=\"badge-tile locked\" data-kid=\"97\">\n        <div class=\"badge-emoji\" data-kid=\"98\">💎</div>\n        <div class=\"badge-name\" data-kid=\"99\">Diamond</div>\n      </div>\n      <div class=\"badge-tile\" data-kid=\"100\">\n        <div class=\"badge-emoji\" data-kid=\"101\">✅</div>\n        <div class=\"badge-name\" data-kid=\"102\">Verified</div>\n      </div>\n      <div class=\"badge-tile\" data-kid=\"103\">\n        <div class=\"badge-emoji\" data-kid=\"104\">🔥</div>\n        <div class=\"badge-name\" data-kid=\"105\">7d Streak</div>\n      </div>\n      <div class=\"badge-tile locked\" data-kid=\"106\">\n        <div class=\"badge-emoji\" data-kid=\"107\">⚡</div>\n        <div class=\"badge-name\" data-kid=\"108\">30d Streak</div>\n      </div>\n      <div class=\"badge-tile locked\" data-kid=\"109\">\n        <div class=\"badge-emoji\" data-kid=\"110\">👑</div>\n        <div class=\"badge-name\" data-kid=\"111\">Legend</div>\n      </div>\n    </div>\n  </div>\n\n</div>\n",
