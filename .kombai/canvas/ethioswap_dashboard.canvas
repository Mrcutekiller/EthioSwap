      "html": "\n<style data-kid=\"0\">\n@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700;800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap');\n@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n* { box-sizing: border-box; margin: 0; padding: 0; }\n\nbody {\n  background: #010B13;\n  color: #E2E8F0;\n  font-family: 'Manrope', sans-serif;\n  min-height: 100vh;\n  font-size: 14px;\n  -webkit-font-smoothing: antialiased;\n}\n\n.wallet-wrap {\n  background: #010B13;\n  min-height: 100vh;\n  padding: 16px 16px 40px;\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n  max-width: 375px;\n  margin: 0 auto;\n}\n\n/* Hero Balance Card */\n.hero-card {\n  background: linear-gradient(135deg, rgba(10,20,40,0.98) 0%, rgba(6,15,28,0.98) 60%, rgba(20,16,6,0.98) 100%);\n  border: 1.5px solid rgba(255,215,0,0.28);\n  border-radius: 28px;\n  padding: 22px 20px 18px;\n  position: relative;\n  overflow: hidden;\n  box-shadow: 0 0 40px rgba(255,215,0,0.08), 0 8px 32px rgba(0,0,0,0.5);\n}\n\n.hero-card::before {\n  content: '';\n  position: absolute;\n  top: -60px; right: -60px;\n  width: 180px; height: 180px;\n  background: radial-gradient(circle, rgba(255,215,0,0.14) 0%, transparent 70%);\n  pointer-events: none;\n}\n\n.hero-card::after {\n  content: '';\n  position: absolute;\n  bottom: -40px; left: -20px;\n  width: 140px; height: 140px;\n  background: radial-gradient(circle, rgba(0,212,160,0.09) 0%, transparent 70%);\n  pointer-events: none;\n}\n\n.eyebrow {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 10px;\n  font-weight: 700;\n  color: #FFD700;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  margin-bottom: 6px;\n  opacity: 0.85;\n}\n\n.balance-main {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 36px;\n  font-weight: 800;\n  color: #fff;\n  letter-spacing: -0.03em;\n  line-height: 1;\n  margin-bottom: 12px;\n}\n\n.balance-sub-row {\n  display: flex;\n  gap: 0;\n  margin-bottom: 14px;\n}\n\n.balance-sub {\n  display: flex;\n  align-items: center;\n  gap: 5px;\n  flex: 1;\n}\n\n.balance-sub-divider {\n  width: 1px;\n  background: rgba(255,255,255,0.08);\n  margin: 0 12px;\n}\n\n.sub-label {\n  font-size: 10px;\n  color: #4A6380;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n  font-weight: 600;\n  display: block;\n  margin-bottom: 2px;\n}\n\n.sub-val-gold {\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 13px;\n  font-weight: 700;\n  color: #FFD700;\n}\n\n.sub-val-teal {\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 13px;\n  font-weight: 700;\n  color: #00D4A0;\n}\n\n.hero-sep {\n  height: 1px;\n  background: rgba(255,255,255,0.07);\n  margin-bottom: 14px;\n}\n\n.addr-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 8px;\n}\n\n.addr-label {\n  font-size: 10px;\n  color: #4A6380;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n  font-weight: 600;\n}\n\n.addr-val {\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 11px;\n  color: #6B8AAA;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n\n.addr-val .copy-btn {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 22px; height: 22px;\n  border-radius: 6px;\n  background: rgba(255,255,255,0.05);\n  border: 1px solid rgba(255,255,255,0.1);\n  cursor: pointer;\n  color: #6B8AAA;\n  font-size: 11px;\n  transition: all 0.2s;\n}\n\n.id-val {\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 13px;\n  font-weight: 700;\n  color: #FFD700;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n\n/* Sub tabs */\n.sub-tabs {\n  display: flex;\n  background: rgba(6,15,28,0.9);\n  border: 1px solid #0F2035;\n  border-radius: 16px;\n  padding: 4px;\n  gap: 2px;\n}\n\n.sub-tab {\n  flex: 1;\n  padding: 9px 4px;\n  border-radius: 12px;\n  border: none;\n  font-family: 'Manrope', sans-serif;\n  font-size: 12px;\n  font-weight: 700;\n  cursor: pointer;\n  transition: all 0.2s;\n  color: #4A6380;\n  background: transparent;\n  text-align: center;\n}\n\n.sub-tab.active {\n  background: rgba(255,215,0,0.12);\n  color: #FFD700;\n  box-shadow: 0 0 0 1.5px rgba(255,215,0,0.3), 0 2px 8px rgba(255,215,0,0.12);\n}\n\n/* Deposit view */\n.deposit-section {\n  display: flex;\n  flex-direction: column;\n  gap: 14px;\n}\n\n.network-pills {\n  display: flex;\n  gap: 8px;\n}\n\n.net-pill {\n  padding: 7px 14px;\n  border-radius: 99px;\n  font-size: 12px;\n  font-weight: 700;\n  font-family: 'Space Grotesk', sans-serif;\n  border: 1.5px solid #0F2035;\n  background: rgba(6,15,28,0.8);\n  color: #4A6380;\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.net-pill.active {\n  background: rgba(255,215,0,0.12);\n  border-color: rgba(255,215,0,0.45);\n  color: #FFD700;\n  box-shadow: 0 0 12px rgba(255,215,0,0.15);\n}\n\n/* QR Card */\n.qr-card {\n  background: #fff;\n  border-radius: 20px;\n  padding: 16px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 10px;\n  box-shadow: 0 0 0 1px rgba(255,215,0,0.18), 0 8px 24px rgba(255,215,0,0.1), 0 2px 8px rgba(0,0,0,0.3);\n  margin: 0 auto;\n  width: 180px;\n}\n\n.qr-inner {\n  width: 140px;\n  height: 140px;\n  display: grid;\n  grid-template-columns: repeat(14, 1fr);\n  grid-template-rows: repeat(14, 1fr);\n  gap: 0.5px;\n}\n\n.qr-pix {\n  background: #111;\n}\n\n.qr-label {\n  font-size: 9px;\n  color: #333;\n  font-weight: 700;\n  letter-spacing: 0.06em;\n  text-transform: uppercase;\n  font-family: 'JetBrains Mono', monospace;\n}\n\n.addr-box {\n  background: rgba(6,15,28,0.9);\n  border: 1px solid #0F2035;\n  border-radius: 14px;\n  padding: 11px 14px;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.addr-text {\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 12px;\n  color: #6B8AAA;\n  flex: 1;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.copy-icon-btn {\n  width: 28px; height: 28px;\n  border-radius: 8px;\n  background: rgba(255,215,0,0.1);\n  border: 1px solid rgba(255,215,0,0.2);\n  display: flex; align-items: center; justify-content: center;\n  color: #FFD700;\n  font-size: 13px;\n  cursor: pointer;\n  flex-shrink: 0;\n  margin-left: 10px;\n}\n\n.divider-row {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  color: #4A6380;\n  font-size: 10px;\n  font-weight: 700;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n}\n\n.divider-row::before,\n.divider-row::after {\n  content: '';\n  flex: 1;\n  height: 1px;\n  background: rgba(255,255,255,0.07);\n}\n\n.input-field {\n  width: 100%;\n  background: rgba(6,15,28,0.9);\n  border: 1.5px solid #0F2035;\n  border-radius: 14px;\n  padding: 13px 16px;\n  color: #E2E8F0;\n  font-family: 'Manrope', sans-serif;\n  font-size: 13px;\n  outline: none;\n  transition: border-color 0.2s;\n}\n\n.input-field::placeholder {\n  color: #4A6380;\n}\n\n.upload-zone {\n  border: 2px dashed rgba(255,215,0,0.2);\n  border-radius: 18px;\n  padding: 20px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 8px;\n  background: rgba(255,215,0,0.02);\n  cursor: pointer;\n}\n\n.upload-zone-icon {\n  width: 40px; height: 40px;\n  border-radius: 12px;\n  background: rgba(255,215,0,0.1);\n  display: flex; align-items: center; justify-content: center;\n  font-size: 18px;\n  color: #FFD700;\n}\n\n.upload-title {\n  font-size: 13px;\n  font-weight: 700;\n  color: #6B8AAA;\n}\n\n.upload-sub {\n  font-size: 11px;\n  color: #4A6380;\n}\n\n.tg-note {\n  background: rgba(0,212,160,0.06);\n  border: 1px solid rgba(0,212,160,0.2);\n  border-radius: 14px;\n  padding: 12px 14px;\n  display: flex;\n  gap: 10px;\n  align-items: flex-start;\n}\n\n.tg-note-icon {\n  font-size: 16px;\n  color: #00D4A0;\n  flex-shrink: 0;\n  margin-top: 1px;\n}\n\n.tg-note-text {\n  font-size: 12px;\n  color: #6B8AAA;\n  line-height: 1.5;\n}\n\n.tg-note-text b {\n  color: #00D4A0;\n}\n\n.btn-gold {\n  width: 100%;\n  background: linear-gradient(135deg, #FFD700 0%, #FFE082 100%);\n  color: #0A0C12;\n  border: none;\n  border-radius: 14px;\n  padding: 15px;\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 14px;\n  font-weight: 700;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 8px;\n  box-shadow: 0 4px 20px rgba(255,215,0,0.25);\n}\n\n/* Withdraw preview */\n.withdraw-section {\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.section-label {\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 11px;\n  font-weight: 700;\n  color: #4A6380;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  margin-bottom: 2px;\n}\n\n.amount-row {\n  display: flex;\n  gap: 8px;\n}\n\n.amount-input-wrap {\n  flex: 1;\n  position: relative;\n}\n\n.amount-input {\n  width: 100%;\n  background: rgba(6,15,28,0.9);\n  border: 1.5px solid #0F2035;\n  border-radius: 14px;\n  padding: 13px 16px;\n  color: #E2E8F0;\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 15px;\n  font-weight: 700;\n  outline: none;\n}\n\n.amount-input::placeholder { color: #4A6380; }\n\n.currency-toggle {\n  display: flex;\n  background: rgba(6,15,28,0.9);\n  border: 1.5px solid #0F2035;\n  border-radius: 14px;\n  padding: 4px;\n  align-items: center;\n}\n\n.cur-btn {\n  padding: 6px 10px;\n  border-radius: 10px;\n  border: none;\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 11px;\n  font-weight: 700;\n  cursor: pointer;\n  transition: all 0.15s;\n  color: #4A6380;\n  background: transparent;\n}\n\n.cur-btn.active {\n  background: rgba(255,215,0,0.15);\n  color: #FFD700;\n}\n\n/* OTP boxes */\n.otp-row {\n  display: flex;\n  gap: 6px;\n}\n\n.otp-box {\n  flex: 1;\n  aspect-ratio: 1;\n  background: rgba(6,15,28,0.9);\n  border: 1.5px solid #0F2035;\n  border-radius: 12px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-family: 'JetBrains Mono', monospace;\n  font-size: 18px;\n  font-weight: 700;\n  color: #4A6380;\n}\n\n.fee-box {\n  background: rgba(0,212,160,0.05);\n  border: 1px solid rgba(0,212,160,0.18);\n  border-radius: 14px;\n  padding: 12px 14px;\n  display: flex;\n  flex-direction: column;\n  gap: 6px;\n}\n\n.fee-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-size: 12px;\n}\n\n.fee-label { color: #6B8AAA; }\n\n.fee-val { \n  font-family: 'JetBrains Mono', monospace;\n  font-weight: 600;\n  color: #E2E8F0;\n}\n\n.fee-sep { height: 1px; background: rgba(0,212,160,0.12); }\n\n.fee-total-label { font-size: 13px; font-weight: 700; color: #E2E8F0; }\n\n.fee-total-val { \n  font-family: 'JetBrains Mono', monospace;\n  font-size: 15px;\n  font-weight: 800;\n  color: #00D4A0;\n}\n\n.btn-teal {\n  width: 100%;\n  background: linear-gradient(135deg, #00856A 0%, #00D4A0 100%);\n  color: #040A0A;\n  border: none;\n  border-radius: 14px;\n  padding: 15px;\n  font-family: 'Space Grotesk', sans-serif;\n  font-size: 14px;\n  font-weight: 700;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 8px;\n  box-shadow: 0 4px 20px rgba(0,212,160,0.2);\n}\n\n.preview-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  padding: 5px 12px;\n  background: rgba(99,102,241,0.1);\n  border: 1px solid rgba(99,102,241,0.2);\n  border-radius: 99px;\n  font-size: 10px;\n  font-weight: 700;\n  color: #818CF8;\n  letter-spacing: 0.06em;\n  text-transform: uppercase;\n  margin-bottom: 10px;\n}\n\n.section-divider {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  margin: 4px 0;\n}\n\n.section-divider span {\n  font-size: 11px;\n  font-weight: 700;\n  color: #4A6380;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n  white-space: nowrap;\n}\n\n.section-divider::before,\n.section-divider::after {\n  content: '';\n  flex: 1;\n  height: 1px;\n  background: rgba(255,255,255,0.06);\n}\n</style