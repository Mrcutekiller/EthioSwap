      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n</style>\n\n<div style=\"font-family:'Manrope',sans-serif;background:#010B13;min-height:100vh;color:#e2e8f0;position:relative;padding-bottom:70px;\" data-kid=\"1\">\n\n  \n  <nav style=\"background:rgba(1,11,19,0.92);backdrop-filter:blur(16px);border-bottom:1px solid #1a2840;padding:0 24px;height:60px;display:flex;align-items:center;gap:16px;position:sticky;top:0;z-index:50;\" data-kid=\"2\">\n    \n    <div style=\"display:flex;align-items:center;gap:8px;min-width:160px;\" data-kid=\"3\">\n      <div style=\"width:32px;height:32px;background:linear-gradient(135deg,#FFD700,#f5a623);border-radius:8px;display:flex;align-items:center;justify-content:center;\" data-kid=\"4\">\n        <i class=\"ti ti-shield-check\" style=\"color:#010B13;font-size:18px;\" data-kid=\"5\"></i>\n      </div>\n      <span style=\"font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:18px;color:#FFD700;letter-spacing:-0.3px;\" data-kid=\"6\">EthioSwap</span>\n    </div>\n\n    \n    <div style=\"flex:1;max-width:400px;position:relative;\" data-kid=\"7\">\n      <i class=\"ti ti-search\" style=\"position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#4a6380;font-size:16px;\" data-kid=\"8\"></i>\n      <input type=\"text\" placeholder=\"Search trades, users...\" style=\"width:100%;background:#0d1520;border:1px solid #1a2840;border-radius:24px;padding:8px 16px 8px 36px;color:#94a3b8;font-size:14px;outline:none;font-family:'Manrope',sans-serif;\" data-kid=\"9\">\n    </div>\n\n    <div style=\"flex:1;\" data-kid=\"10\"></div>\n\n    \n    <div style=\"background:#0d1520;border:1px solid #1a2840;border-radius:20px;padding:6px 14px;display:flex;align-items:center;gap:6px;\" data-kid=\"11\">\n      <i class=\"ti ti-wallet\" style=\"color:#00d4a0;font-size:15px;\" data-kid=\"12\"></i>\n      <span style=\"font-size:13px;font-weight:600;color:#e2e8f0;\" data-kid=\"13\">ETB 24,500</span>\n    </div>\n\n    \n    <div style=\"position:relative;width:38px;height:38px;background:#0d1520;border:1px solid #1a2840;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;\" data-kid=\"14\">\n      <i class=\"ti ti-bell\" style=\"color:#94a3b8;font-size:18px;\" data-kid=\"15\"></i>\n      <span style=\"position:absolute;top:4px;right:4px;width:16px;height:16px;background:#FFD700;border-radius:50%;font-size:10px;font-weight:700;color:#010B13;display:flex;align-items:center;justify-content:center;\" data-kid=\"16\">3</span>\n    </div>\n\n    \n    <div style=\"display:flex;align-items:center;gap:10px;cursor:pointer;\" data-kid=\"17\">\n      <img src=\"https://i.pravatar.cc/36?u=biruk\" decoding=\"async\" loading=\"lazy\" style=\"width:36px;height:36px;border-radius:50%;border:2px solid #FFD700;\" alt=\"Biruk T.\" data-kid=\"18\">\n      <span style=\"font-size:14px;font-weight:600;color:#e2e8f0;\" data-kid=\"19\">Biruk T.</span>\n      <i class=\"ti ti-chevron-down\" style=\"color:#4a6380;font-size:14px;\" data-kid=\"20\"></i>\n    </div>\n  </nav>\n\n  \n  <div style=\"display:grid;grid-template-columns:260px 1fr 280px;gap:20px;padding:20px 24px;min-height:calc(100vh - 130px);\" data-kid=\"21\">\n\n    \n    <div style=\"display:flex;flex-direction:column;gap:16px;\" data-kid=\"22\">\n\n      \n      <div style=\"background:linear-gradient(145deg,rgba(13,21,32,0.9),rgba(0,73,83,0.3));border:1px solid #1e3a5f;border-radius:16px;padding:20px;text-align:center;position:relative;overflow:hidden;\" data-kid=\"23\">\n        <div style=\"position:absolute;top:-30px;right:-30px;width:100px;height:100px;background:radial-gradient(circle,rgba(0,212,160,0.15),transparent);pointer-events:none;\" data-kid=\"24\"></div>\n        \n        \n        <div style=\"display:flex;justify-content:center;margin-bottom:12px;\" data-kid=\"25\">\n          <div style=\"position:relative;width:80px;height:80px;\" data-kid=\"26\">\n            <svg width=\"80\" height=\"80\" viewBox=\"0 0 80 80\" style=\"position:absolute;top:0;left:0;\" data-kid=\"27\">\n              <defs data-kid=\"28\">\n                <clipPath id=\"hexClip\" data-kid=\"29\">\n                  <polygon points=\"40,4 72,22 72,58 40,76 8,58 8,22\" data-kid=\"30\"></polygon>\n                </clipPath>\n              </defs>\n              <polygon points=\"40,4 72,22 72,58 40,76 8,58 8,22\" fill=\"none\" stroke=\"#FFD700\" stroke-width=\"2\" data-kid=\"31\"></polygon>\n              <image href=\"https://i.pravatar.cc/80?u=biruk47\" x=\"8\" y=\"8\" width=\"64\" height=\"64\" clip-path=\"url(#hexClip)\" decoding=\"async\" loading=\"lazy\" data-kid=\"32\"></image>\n            </svg>\n          </div>\n        </div>\n\n        <div style=\"font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:16px;color:#fff;margin-bottom:6px;\" data-kid=\"33\">Biruk T.</div>\n        \n        <div style=\"display:flex;justify-content:center;gap:6px;margin-bottom:10px;flex-wrap:wrap;\" data-kid=\"34\">\n          <span style=\"background:linear-gradient(135deg,#FFD700,#f5a623);color:#010B13;font-size:11px;font-weight:700;padding:3px 8px;border-radius:12px;\" data-kid=\"35\">🏅 Gold Trader</span>\n          <span style=\"background:rgba(0,212,160,0.15);color:#00d4a0;border:1px solid #00d4a0;font-size:11px;font-weight:600;padding:3px 8px;border-radius:12px;\" data-kid=\"36\">✓ Verified</span>\n        </div>\n\n        \n        <div style=\"display:flex;align-items:center;justify-content:center;gap:4px;margin-bottom:14px;\" data-kid=\"37\">\n          <span style=\"color:#FFD700;font-size:14px;\" data-kid=\"38\">★★★★★</span>\n          <span style=\"font-size:13px;font-weight:700;color:#fff;\" data-kid=\"39\">4.8</span>\n          <span style=\"font-size:12px;color:#4a6380;\" data-kid=\"40\">(127 trades)</span>\n        </div>\n\n        \n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:0;\" data-kid=\"41\">\n          <div style=\"background:rgba(255,215,0,0.05);border:1px solid rgba(255,215,0,0.15);border-radius:10px;padding:8px;text-align:center;\" data-kid=\"42\">\n            <div style=\"font-size:16px;font-weight:700;color:#FFD700;\" data-kid=\"43\">127</div>\n            <div style=\"font-size:10px;color:#4a6380;\" data-kid=\"44\">Trades</div>\n          </div>\n          <div style=\"background:rgba(0,212,160,0.05);border:1px solid rgba(0,212,160,0.15);border-radius:10px;padding:8px;text-align:center;\" data-kid=\"45\">\n            <div style=\"font-size:16px;font-weight:700;color:#00d4a0;\" data-kid=\"46\">98%</div>\n            <div style=\"font-size:10px;color:#4a6380;\" data-kid=\"47\">Success</div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div style=\"background:#0d1520;border:1px solid #1a2840;border-radius:14px;padding:16px;\" data-kid=\"48\">\n        <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:10px;\" data-kid=\"49\">\n          <i class=\"ti ti-gift\" style=\"color:#FFD700;font-size:16px;\" data-kid=\"50\"></i>\n          <span style=\"font-size:13px;font-weight:600;color:#94a3b8;\" data-kid=\"51\">Referral Code</span>\n        </div>\n        <div style=\"background:#060f1c;border:1px solid rgba(255,215,0,0.2);border-radius:8px;padding:8px 12px;display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;\" data-kid=\"52\">\n          <span style=\"font-size:12px;font-weight:600;color:#FFD700;letter-spacing:0.5px;\" data-kid=\"53\">ETHIOSWAP-BIRUK47</span>\n          <i class=\"ti ti-copy\" style=\"color:#4a6380;font-size:14px;cursor:pointer;\" data-kid=\"54\"></i>\n        </div>\n        <button style=\"width:100%;background:linear-gradient(135deg,rgba(255,215,0,0.1),rgba(255,215,0,0.05));border:1px solid rgba(255,215,0,0.3);color:#FFD700;font-size:12px;font-weight:600;padding:8px;border-radius:8px;cursor:pointer;font-family:'Manrope',sans-serif;\" data-kid=\"55\">\n          <i class=\"ti ti-share\" style=\"font-size:13px;margin-right:4px;\" data-kid=\"56\"></i>Share & Earn\n        </button>\n      </div>\n\n      \n      <div style=\"background:#0d1520;border:1px solid #1a2840;border-radius:14px;padding:14px;\" data-kid=\"57\">\n        <div style=\"font-size:12px;font-weight:600;color:#4a6380;margin-bottom:10px;text-transform:uppercase;letter-spacing:0.5px;\" data-kid=\"58\">Achievements</div>\n        <div style=\"display:flex;gap:10px;flex-wrap:wrap;\" data-kid=\"59\">\n          <div style=\"width:40px;height:40px;background:linear-gradient(135deg,rgba(255,215,0,0.2),rgba(245,166,35,0.1));border:1px solid rgba(255,215,0,0.3);border-radius:10px;display:flex;align-items:center;justify-content:center;\" title=\"First Trade\" data-kid=\"60\">\n            <i class=\"ti ti-trophy\" style=\"color:#FFD700;font-size:18px;\" data-kid=\"61\"></i>\n          </div>\n          <div style=\"width:40px;height:40px;background:linear-gradient(135deg,rgba(0,212,160,0.2),rgba(0,212,160,0.1));border:1px solid rgba(0,212,160,0.3);border-radius:10px;display:flex;align-items:center;justify-content:center;\" title=\"100 Trades\" data-kid=\"62\">\n            <i class=\"ti ti-star\" style=\"color:#00d4a0;font-size:18px;\" data-kid=\"63\"></i>\n          </div>\n          <div style=\"width:40px;height:40px;background:linear-gradient(135deg,rgba(99,102,241,0.2),rgba(99,102,241,0.1));border:1px solid rgba(99,102,241,0.3);border-radius:10px;display:flex;align-items:center;justify-content:center;\" title=\"Verified KYC\" data-kid=\"64\">\n            <i class=\"ti ti-shield-check\" style=\"color:#818cf8;font-size:18px;\" data-kid=\"65\"></i>\n          </div>\n          <div style=\"width:40px;height:40px;background:rgba(30,58,95,0.5);border:1px dashed #1e3a5f;border-radius:10px;display:flex;align-items:center;justify-content:center;\" data-kid=\"66\">\n            <i class=\"ti ti-lock\" style=\"color:#2a4a6a;font-size:18px;\" data-kid=\"67\"></i>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div style=\"display:flex;flex-direction:column;gap:20px;\" data-kid=\"68\">\n\n      \n      <div style=\"display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;\" data-kid=\"69\">\n        \n        <div style=\"background:linear-gradient(135deg,#0d1520,#0f1e30);border:1px solid rgba(255,215,0,0.25);border-radius:16px;padding:18px;position:relative;overflow:hidden;\" data-kid=\"70\">\n          <div style=\"position:absolute;top:-10px;right:-10px;width:70px;height:70px;background:radial-gradient(circle,rgba(255,215,0,0.1),transparent);pointer-events:none;\" data-kid=\"71\"></div>\n          <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:10px;\" data-kid=\"72\">\n            <div style=\"width:32px;height:32px;background:rgba(255,215,0,0.15);border-radius:8px;display:flex;align-items:center;justify-content:center;\" data-kid=\"73\">\n              <i class=\"ti ti-currency-ethereum\" style=\"color:#FFD700;font-size:18px;\" data-kid=\"74\"></i>\n            </div>\n            <span style=\"font-size:12px;color:#4a6380;\" data-kid=\"75\">ETH Balance</span>\n          </div>\n          <div style=\"font-family:'Space Grotesk',sans-serif;font-size:24px;font-weight:700;color:#FFD700;\" data-kid=\"76\">0.482</div>\n          <div style=\"font-size:12px;color:#4a6380;margin-top:2px;\" data-kid=\"77\">≈ ETB 130,714</div>\n          <div style=\"margin-top:10px;display:flex;gap:6px;\" data-kid=\"78\">\n            <button style=\"background:rgba(255,215,0,0.15);border:1px solid rgba(255,215,0,0.3);color:#FFD700;font-size:11px;font-weight:600;padding:4px 10px;border-radius:6px;cursor:pointer;font-family:'Manrope',sans-serif;\" data-kid=\"79\">Deposit</button>\n            <button style=\"background:transparent;border:1px solid #1a2840;color:#94a3b8;font-size:11px;font-weight:600;padding:4px 10px;border-radius:6px;cursor:pointer;font-family:'Manrope',sans-serif;\" data-kid=\"80\">Withdraw</button>\n          </div>\n        </div>\n\n        \n        <div style=\"background:linear-gradient(135deg,#0d1520,#0a1a1f);border:1px solid rgba(0,212,160,0.25);border-radius:16px;padding:18px;position:relative;overflow:hidden;\" data-kid=\"81\">\n          <div style=\"position:absolute;top:-10px;right:-10px;width:70px;height:70px;background:radial-gradient(circle,rgba(0,212,160,0.1),transparent);pointer-events:none;\" data-kid=\"82\"></div>\n          <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:10px;\" data-kid=\"83\">\n            <div style=\"width:32px;height:32px;background:rgba(0,212,160,0.15);border-radius:8px;display:flex;align-items:center;justify-content:center;\" data-kid=\"84\">\n              <i class=\"ti ti-coin\" style=\"color:#00d4a0;font-size:18px;\" data-kid=\"85\"></i>\n            </div>\n            <span style=\"font-size:12px;color:#4a6380;\" data-kid=\"86\">ETB Balance</span>\n          </div>\n          <div style=\"font-family:'Space Grotesk',sans-serif;font-size:24px;font-weight:700;color:#00d4a0;\" data-kid=\"87\">24,500</div>\n          <div style=\"font-size:12px;color:#4a6380;margin-top:2px;\" data-kid=\"88\">≈ $180.15 USD</div>\n          <div style=\"margin-top:10px;display:flex;gap:6px;\" data-kid=\"89\">\n            <button style=\"background:rgba(0,212,160,0.15);border:1px solid rgba(0,212,160,0.3);color:#00d4a0;font-size:11px;font-weight:600;padding:4px 10px;border-radius:6px;cursor:pointer;font-family:'Manrope',sans-serif;\" data-kid=\"90\">Add Funds</button>\n            <button style=\"background:transparent;border:1px solid #1a2840;color:#94a3b8;font-size:11px;font-weight:600;padding:4px 10px;border-radius:6px;cursor:pointer;font-family:'Manrope',sans-serif;\" data-kid=\"91\">Send</button>\n          </div>\n        </div>\n\n        \n        <div style=\"background:linear-gradient(135deg,#0d1520,#1a120a);border:1px solid rgba(245,158,11,0.25);border-radius:16px;padding:18px;position:relative;overflow:hidden;\" data-kid=\"92\">\n          <div style=\"position:absolute;top:-10px;right:-10px;width:70px;height:70px;background:radial-gradient(circle,rgba(245,158,11,0.1),transparent);pointer-events:none;\" data-kid=\"93\"></div>\n          <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:10px;\" data-kid=\"94\">\n            <div style=\"width:32px;height:32px;background:rgba(245,158,11,0.15);border-radius:8px;display:flex;align-items:center;justify-content:center;\" data-kid=\"95\">\n              <i class=\"ti ti-lock\" style=\"color:#f59e0b;font-size:18px;\" data-kid=\"96\"></i>\n            </div>\n            <span style=\"font-size:12px;color:#4a6380;\" data-kid=\"97\">In Escrow</span>\n          </div>\n          <div style=\"font-family:'Space Grotesk',sans-serif;font-size:24px;font-weight:700;color:#f59e0b;\" data-kid=\"98\">0.030</div>\n          <div style=\"font-size:12px;color:#4a6380;margin-top:2px;\" data-kid=\"99\">ETH locked in active trade</div>\n          <div style=\"margin-top:10px;\" data-kid=\"100\">\n            <span style=\"background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.3);color:#f59e0b;font-size:11px;font-weight:600;padding:4px 10px;border-radius:6px;\" data-kid=\"101\">2 Active Trades</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div style=\"background:#0d1520;border:1px solid #1a2840;border-radius:16px;padding:20px;\" data-kid=\"102\">\n        <div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;\" data-kid=\"103\">\n          <div style=\"display:flex;align-items:center;gap:10px;\" data-kid=\"104\">\n            <span style=\"font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:700;color:#fff;\" data-kid=\"105\">Active Trades</span>\n            <span style=\"background:rgba(0,212,160,0.15);border:1px solid rgba(0,212,160,0.3);color:#00d4a0;font-size:12px;font-weight:700;padding:2px 8px;border-radius:12px;\" data-kid=\"106\">2</span>\n          </div>\n          <button style=\"background:transparent;border:1px solid #1a2840;color:#94a3b8;font-size:12px;padding:6px 14px;border-radius:8px;cursor:pointer;font-family:'Manrope',sans-serif;\" data-kid=\"107\">View All</button>\n        </div>\n\n        \n        <div style=\"background:#060f1c;border:1px solid rgba(245,158,11,0.2);border-left:3px solid #f59e0b;border-radius:12px;padding:14px 16px;margin-bottom:10px;display:flex;align-items:center;gap:14px;\" data-kid=\"108\">\n          <img src=\"https://i.pravatar.cc/36?u=abebe\" decoding=\"async\" loading=\"lazy\" style=\"width:40px;height:40px;border-radius:50%;border:2px solid rgba(245,158,11,0.4);\" alt=\"Abebe\" data-kid=\"109\">\n          <div style=\"flex:1;\" data-kid=\"110\">\n            <div style=\"display:flex;align-items:center;gap:8px;margin-bottom:3px;\" data-kid=\"111\">\n              <span style=\"font-size:14px;font-weight:600;color:#fff;\" data-kid=\"112\">Abebe K.</span>\n              <span style=\"font-size:11px;color:#4a6380;font-family:'Space Grotesk',sans-serif;\" data-kid=\"113\">#TRD-2847</span>\n            </div>\n            <div style=\"font-size:12px;color:#4a6380;\" data-kid=\"114\">Selling <span style=\"color:#FFD700;font-weight:600;\" data-kid=\"115\">0.030 ETH</span> · ETB 8,142 · Telebirr</div>\n          </div>\n          <div style=\"text-align:right;\" data-kid=\"116\">\n            <span style=\"display:inline-block;background:rgba(245,158,11,0.15);border:1px solid rgba(245,158,11,0.4);color:#f59e0b;font-size:11px;font-weight:700;padding:3px 8px;border-radius:8px;margin-bottom:8px;\" data-kid=\"117\">⏳ AWAITING PAYMENT</span>\n            <div style=\"display:flex;gap:6px;justify-content:flex-end;\" data-kid=\"118\">\n              <button style=\"ba