      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  .sidebar-nav::-webkit-scrollbar { width: 4px; }\n  .sidebar-nav::-webkit-scrollbar-track { background: transparent; }\n  .sidebar-nav::-webkit-scrollbar-thumb { background: var(--k-color-border); border-radius: 10px; }\n\n  @keyframes pulse-red {\n    0%, 100% { opacity: 1; transform: scale(1); }\n    50% { opacity: 0.6; transform: scale(1.1); }\n  }\n\n  .notif-pulse { animation: pulse-red 2s infinite; }\n  \n  .nav-item-active {\n    color: var(--k-color-bg-page) !important;\n    background: linear-gradient(90deg, var(--k-color-primary), #f0b800);\n    font-weight: 700;\n  }\n  \n  .nav-item-active i { color: var(--k-color-bg-page) !important; }\n\n  .kpi-card::before {\n    content: '';\n    position: absolute;\n    top: 0; left: 0; right: 0;\n    height: 3px;\n    border-radius: 14px 14px 0 0;\n  }\n</style>\n\n<div class=\"flex h-screen overflow-hidden bg-[var(--k-color-bg-page)] text-[var(--k-color-text-primary)] font-[var(--k-font-family-body)]\" data-kid=\"1\">\n  \n  <aside class=\"w-[240px] flex flex-col bg-[var(--k-color-bg-surface)] border-r border-[var(--k-color-border)] h-full\" data-kid=\"2\">\n    \n    <div class=\"p-5 pb-4 border-b border-[var(--k-color-border)]\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2 font-[var(--k-font-family-heading)] text-lg font-bold text-[var(--k-color-primary)]\" data-kid=\"4\">\n        <i class=\"ti ti-shield-check text-xl\" data-kid=\"5\"></i>\n        EthioSwap Admin\n      </div>\n      <div class=\"mt-1 inline-block text-[10px] font-bold text-[var(--k-color-secondary)] bg-[var(--k-color-secondary)]/10 border border-[var(--k-color-secondary)]/30 px-1.5 py-0.5 rounded\" data-kid=\"6\">\n        COMMAND CENTER\n      </div>\n    </div>\n\n    \n    <div class=\"p-4 flex items-center gap-3 border-b border-[var(--k-color-border)]\" data-kid=\"7\">\n      <img src=\"https://i.pravatar.cc/36?u=admin_ethioswap\" class=\"w-9 h-9 rounded-full border-2 border-[var(--k-color-primary)]\" decoding=\"async\" loading=\"lazy\" alt=\"Admin\" data-kid=\"8\">\n      <div data-kid=\"9\">\n        <div class=\"text-[13px] font-bold\" data-kid=\"10\">@admin_ethioswap</div>\n        <div class=\"text-[11px] text-[var(--k-color-primary)]\" data-kid=\"11\">Super Admin</div>\n      </div>\n    </div>\n\n    \n    <nav class=\"flex-1 overflow-y-auto py-3 sidebar-nav\" data-kid=\"12\">\n      <div class=\"text-[10px] font-extrabold uppercase tracking-widest text-[var(--k-color-text-muted)] px-5 mb-2\" data-kid=\"13\">Management</div>\n      \n      <div class=\"space-y-0.5\" data-kid=\"14\">\n        <a href=\"#\" class=\"flex items-center gap-3 px-5 py-2.5 text-[13px] font-semibold nav-item-active rounded-r-lg mr-4\" data-kid=\"15\">\n          <i class=\"ti ti-layout-dashboard text-[17px]\" data-kid=\"16\"></i>\n          Dashboard\n        </a>\n        \n        <a href=\"#\" class=\"flex items-center gap-3 px-5 py-2.5 text-[13px] font-medium text-[var(--k-color-text-secondary)] hover:bg-white/5 transition-all group\" data-kid=\"17\">\n          <i class=\"ti ti-users text-[17px] group-hover:text-[var(--k-color-text-primary)]\" data-kid=\"18\"></i>\n          Users\n          <span class=\"ml-auto bg-[var(--k-color-error)] text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full min-w-[18px] text-center\" data-kid=\"19\">128</span>\n        </a>\n\n        <a href=\"#\" class=\"flex items-center gap-3 px-5 py-2.5 text-[13px] font-medium text-[var(--k-color-text-secondary)] hover:bg-white/5 transition-all group\" data-kid=\"20\">\n          <i class=\"ti ti-id-badge text-[17px] group-hover:text-[var(--k-color-text-primary)]\" data-kid=\"21\"></i>\n          KYC\n 