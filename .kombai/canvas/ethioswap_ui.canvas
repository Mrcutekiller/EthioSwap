      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n</style>\n\n<div class=\"font-[Manrope,sans-serif] bg-[#010B13] text-white overflow-x-hidden\" style=\"font-family:'Manrope',sans-serif;\" data-kid=\"1\">\n\n  \n  <nav class=\"fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b border-white/5\" style=\"background:rgba(1,11,19,0.85);\" data-kid=\"2\">\n    <div class=\"max-w-[1280px] mx-auto px-8 py-4 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"w-9 h-9 rounded-xl flex items-center justify-center\" style=\"background:linear-gradient(135deg,#FFD700,#FFA500);\" data-kid=\"5\">\n          <i class=\"ti ti-shield-check text-[#010B13] text-lg font-bold\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"text-xl font-bold tracking-tight\" style=\"font-family:'Space Grotesk',sans-serif;color:#FFD700;\" data-kid=\"7\">EthioSwap</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 text-sm font-medium text-white/70\" data-kid=\"8\">\n        <a href=\"#\" class=\"hover:text-white\" data-kid=\"9\">Home</a>\n        <a href=\"#\" class=\"hover:text-white\" data-kid=\"10\">Markets</a>\n        <a href=\"#\" class=\"hover:text-white\" data-kid=\"11\">P2P Trade</a>\n        <a href=\"#\" class=\"hover:text-white\" data-kid=\"12\">How It Works</a>\n      </div>\n      <div class=\"flex items-center gap-3\" data-kid=\"13\">\n        <button class=\"text-sm text-white/70 hover:text-white px-4 py-2\" data-kid=\"14\">Sign In</button>\n        <button class=\"text-sm font-semibold px-5 py-2.5 rounded-full\" style=\"background:linear-gradient(135deg,#FFD700,#FFA500);color:#010B13;\" data-kid=\"15\">Get Started</button>\n      </div>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative min-h-screen flex items-center pt-20 overflow-hidden\" style=\"background:#010B13;\" data-kid=\"16\">\n    \n    <div class=\"absolute inset-0 pointer-events-none\" data-kid=\"17\">\n      <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[700px] rounded-full opacity-20\" style=\"background:radial-gradient(ellipse,#00d4a0 0%,transparent 70%);\" data-kid=\"18\"></div>\n      <div class=\"absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-10\" style=\"background:radial-gradient(ellipse,#FFD700 0%,transparent 65%);\" data-kid=\"19\"></div>\n      \n      <div class=\"absolute inset-0 opacity-[0.04]\" style=\"background-image:linear-gradient(#00d4a0 1px,transparent 1px),linear-gradient(90deg,#00d4a0 1px,transparent 1px);background-size:60px 60px;\" data-kid=\"20\"></div>\n    </div>\n\n    <div class=\"max-w-[1280px] mx-auto px-8 w-full grid grid-cols-2 gap-16 items-center relative z-10\" data-kid=\"21\">\n      \n      <div class=\"hero-left\" data-kid=\"22\">\n        <div class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-semibold mb-6 border\" style=\"background:rgba(0,212,160,0.1);border-color:rgba(0,212,160,0.3);color:#00d4a0;\" data-kid=\"23\">\n          <span class=\"w-2 h-2 rounded-full animate-pulse\" style=\"background:#00d4a0;\" data-kid=\"24\"></span>\n          Live Trading — 847 active trades now\n        </div>\n        <h1 class=\"text-[62px] font-extrabold leading-tight mb-6\" style=\"font-family:'Space Grotesk',sans-serif;line-height:1.1;\" data-kid=\"25\">\n          Secure P2P Crypto<br data-kid=\"26\">\n          <span style=\"background:linear-gradient(90deg,#FFD700,#00d4a0);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;\" data-kid=\"27\">Trading in Ethiopia</span>\n        </h1>\n        <p class=\"text-lg text-white/60 mb-8 leading-relaxed max-w-lg\" data-kid=\"28\">\n          Buy and sell Ethereum directly with other Ethiopians. Protected by smart escrow, verified identities, and instant Telebirr/CBE bank payments.\n        </p>\n        <div class=\"flex items-center gap-4\" data-kid=\"29\">\n          <button class=\"flex items-center gap-2 px-7 py-4 rounded-full font-bold text-base\" style=\"background:linear-gradient(135deg,#FFD700,#FFA500);color:#010B13;\" data-kid=\"30\">\n            Start Trading <i class=\"ti ti-arrow-right\" data-kid=\"31\"></i>\n          </button>\n          <button class=\"flex items-center gap-2 px-7 py-4 rounded-full font-semibold text-base border\" style=\"border-color:#00d4a0;color:#00d4a0;background:rgba(0,212,160,0.06);\" data-kid=\"32\">\n            <i class=\"ti ti-player-play\" data-kid=\"33\"></i> How It Works\n          </button>\n        </div>\n        \n        <div class=\"flex items-center gap-6 mt-10\" data-kid=\"34\">\n          <div class=\"flex items-center gap-2 text-white/50 text-sm\" data-kid=\"35\">\n            <i class=\"ti ti-shield-check text-[#00d4a0]\" data-kid=\"36\"></i> Escrow Protected\n          </div>\n          <div class=\"flex items-center gap-2 text-white/50 text-sm\" data-kid=\"37\">\n            <i class=\"ti ti-certificate text-[#FFD700]\" data-kid=\"38\"></i> KYC Verified\n          </div>\n          <div class=\"flex items-center gap-2 text-white/50 text-sm\" data-kid=\"39\">\n            <i class=\"ti ti-lock text-[#00d4a0]\" data-kid=\"40\"></i> 256-bit Secure\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"hero-right relative flex justify-center items-center\" data-kid=\"41\">\n        \n        <div class=\"absolute inset-0 rounded-3xl opacity-30 blur-3xl\" style=\"background:radial-gradient(circle,#FFD700 0%,#00d4a0 50%,transparent 70%);\" data-kid=\"42\"></div>\n        \n        <div class=\"relative rounded-3xl overflow-hidden border\" style=\"border-color:rgba(255,215,0,0.2);background:#0d1520;width:420px;\" data-kid=\"43