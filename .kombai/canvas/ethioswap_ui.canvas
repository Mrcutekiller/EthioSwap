           <tr data-kid=\"166\">\n                <td data-kid=\"167\">\n                  <div class=\"user-cell\" data-kid=\"168\">\n                    <img src=\"https://i.pravatar.cc/28?u=kyc2\" class=\"user-avatar\" decoding=\"async\" loading=\"lazy\" alt data-kid=\"169\">\n                    <div data-kid=\"170\">\n                      <div class=\"user-name\" data-kid=\"171\">Tigist Haile</div>\n                      <div class=\"user-email\" data-kid=\"172\">tigist.h@gmail.com</div>\n                    </div>\n                  </div>\n                </td>\n                <td data-kid=\"173\">5h ago</td>\n                <td data-kid=\"174\">Passport</td>\n                <td data-kid=\"175\"><span class=\"status-pill under-review\" data-kid=\"176\">Reviewing</span></td>\n                <td data-kid=\"177\">\n                  <div class=\"action-btns\" data-kid=\"178\">\n                    <button class=\"btn-approve\" data-kid=\"179\"><i class=\"ti ti-check\" data-kid=\"180\"></i> Approve</button>\n                    <button class=\"btn-reject\" data-kid=\"181\"><i class=\"ti ti-x\" data-kid=\"182\"></i> Reject</button>\n                  </div>\n                </td>\n              </tr>\n              <tr data-kid=\"183\">\n                <td data-kid=\"184\">\n                  <div class=\"user-cell\" data-kid=\"185\">\n                    <img src=\"https://i.pravatar.cc/28?u=kyc3\" class=\"user-avatar\" decoding=\"async\" loading=\"lazy\" alt data-kid=\"186\">\n                    <div data-kid=\"187\">\n                      <div class=\"user-name\" data-kid=\"188\">Dawit Bekele</div>\n                      <div class=\"user-email\" data-kid=\"189\">dawit.b@ethio.net</div>\n                    </div>\n                  </div>\n                </td>\n                <td data-kid=\"190\">1d ago</td>\n                <td data-kid=\"191\">Driver's License</td>\n                <td data-kid=\"192\"><span class=\"status-pill pending\" data-kid=\"193\">Pending</span></td>\n                <td data-kid=\"194\">\n                  <div class=\"action-btns\" data-kid=\"195\">\n                    <button class=\"btn-approve\" data-kid=\"196\"><i class=\"ti ti-check\" data-kid=\"197\"></i> Approve</button>\n                    <button class=\"btn-reject\" data-kid=\"198\"><i class=\"ti ti-x\" data-kid=\"199\"></i> Reject</button>\n                  </div>\n                </td>\n              </tr>\n              <tr data-kid=\"200\">\n                <td data-kid=\"201\">\n                  <div class=\"user-cell\" data-kid=\"202\">\n                    <img src=\"https://i.pravatar.cc/28?u=kyc4\" class=\"user-avatar\" decoding=\"async\" loading=\"lazy\" alt data-kid=\"203\">\n                    <div data-kid=\"204\">\n                      <div class=\"user-name\" data-kid=\"205\">Hana Tesfaye</div>\n                      <div class=\"user-email\" data-kid=\"206\">hana.t@outlook.com</div>\n                    </div>\n                  </div>\n                </td>\n                <td data-kid=\"207\">1d ago</td>\n                <td data-kid=\"208\">National ID</td>\n                <td data-kid=\"209\"><span class=\"status-pill pending\" data-kid=\"210\">Pending</span></td>\n                <td data-kid=\"211\">\n                  <div class=\"action-btns\" data-kid=\"212\">\n                    <button class=\"btn-approve\" data-kid=\"213\"><i class=\"ti ti-check\" data-kid=\"214\"></i> Approve</button>\n                    <button class=\"btn-reject\" data-kid=\"215\"><i class=\"ti ti-x\" data-kid=\"216\"></i> Reject</button>\n                  </div>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n\n        \n        <div class=\"table-card\" data-kid=\"217\">\n          <div class=\"table-header\" data-kid=\"218\">\n            <div class=\"table-title\" data-kid=\"219\">\n              <i class=\"ti ti-alert-triangle\" data-kid=\"220\"></i>\n              Active Disputes\n              <span class=\"table-count\" style=\"background:rgba(239,68,68,0.1); color:#ef4444;\" data-kid=\"221\">4 open</span>\n            </div>\n            <button class=\"btn-view-all\" data-kid=\"222\">View All →</button>\n          </div>\n          <table class=\"data-table\" data-kid=\"223\">\n            <thead data-kid=\"224\">\n              <tr data-kid=\"225\">\n                <th data-kid=\"226\">Trade ID</th>\n                <th data-kid=\"227\">Amount</th>\n                <th data-kid=\"228\">Reason</th>\n                <th data-kid=\"229\">Status</th>\n                <th data-kid=\"230\">Action</th>\n              </tr>\n            </thead>\n            <tbody data-kid=\"231\">\n              <tr data-kid=\"232\">\n                <td data-kid=\"233\"><span class=\"tx-id\" data-kid=\"234\">#TRD-2847</span></td>\n                <td data-kid=\"235\"><span class=\"amount-cell\" data-kid=\"236\">0.12 ETH</span></td>\n                <td style=\"color:#e2e8f0;\" data-kid=\"237\">No payment received</td>\n                <td data-kid=\"238\"><span class=\"status-pill disputed\" data-kid=\"239\">Escalated</span></td>\n                <td data-kid=\"240\"><button class=\"btn-view\" data-kid=\"241\"><i class=\"ti ti-eye\" data-kid=\"242\"></i> View</button></td>\n              </tr>\n              <tr data-kid=\"243\">\n                <td data-kid=\"244\"><span class=\"tx-id\" data-kid=\"245\">#TRD-2831</span></td>\n                <td data-kid=\"246\"><span class=\"amount-cell\" data-kid=\"247\">0.05 ETH</span></td>\n                <td style=\"color:#e2e8f0;\" data-kid=\"248\">Wrong amount sent</td>\n                <td data-kid=\"249\"><span class=\"status-pill under-review\" data-kid=\"250\">Reviewing</span></td>\n                <td data-kid=\"251\"><button class=\"btn-view\" data-kid=\"252\"><i class=\"ti ti-eye\" data-kid=\"253\"></i> View</button></td>\n              </tr>\n              <tr data-kid=\"254\">\n                <td data-kid=\"255\"><span class=\"tx-id\" data-kid=\"256\">#TRD-2819</span></td>\n                <td data-kid=\"257\"><span class=\"amount-cell\" data-kid=\"258\">0.25 ETH</span></td>\n                <td style=\"color:#e2e8f0;\" data-kid=\"259\">Payment proof missing</td>\n                <td data-kid=\"260\"><span class=\"status-pill disputed\" data-kid=\"261\">Escalated</span></td>\n                <td data-kid=\"262\"><button class=\"btn-view\" data-kid=\"263\"><i class=\"ti ti-eye\" data-kid=\"264\"></i> View</button></td>\n              </tr>\n              <tr data-kid=\"265\">\n                <td data-kid=\"266\"><span class=\"tx-id\" data-kid=\"267\">#TRD-2804</span></td>\n                <td data-kid=\"268\"><span class=\"amount-cell\" data-kid=\"269\">0.08 ETH</span></td>\n                <td style=\"color:#e2e8f0;\" data-kid=\"270\">Seller unresponsive</td>\n                <td data-kid=\"271\"><span class=\"status-pill resolved\" data-kid=\"272\">Resolved</span></td>\n                <td data-kid=\"273\"><button class=\"btn-view\" data-kid=\"274\"><i class=\"ti ti-eye\" data-kid=\"275\"></i> View</button></td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<style data-kid=\"276\">\n  @keyframes pulse {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.4; }\n  }\n</style>\n\n<script data-kid=\"277\">\n  // Volume Area Chart\n  const vCtx = document.getElementById('volumeChart').getContext('2d');\n  const gradient = vCtx.createLinearGradient(0, 0, 0, 160);\n  gradient.addColorStop(0, 'rgba(0,212,160,0.3)');\n  gradient.addColorStop(1, 'rgba(0,212,160,0.01)');\n\n  new Chart(vCtx, {\n    type: 'line',\n    data: {\n      labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],\n      datasets: [{\n        label: 'Volume (USD)',\n        data: [28400, 35200, 31800, 42100, 38600, 44900, 48290],\n        fill: true,\n        backgroundColor: gradient,\n        borderColor: '#FFD700',\n        borderWidth: 2.5,\n        pointBackgroundColor: '#FFD700',\n        pointBorderColor: '#010B13',\n        pointBorderWidth: 2,\n        pointRadius: 4,\n        pointHoverRadius: 6,\n        tension: 0.4,\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: true,\n      plugins: {\n        legend: { display: false },\n        tooltip: {\n          backgroundColor: '#0d1520',\n          borderColor: '#1a2840',\n          borderWidth: 1,\n          titleColor: '#FFD700',\n          bodyColor: '#8aaccc',\n          callbacks: {\n            label: ctx => ' $' + ctx.raw.toLocaleString()\n          }\n        }\n      },\n      scales: {\n        x: {\n          grid: { color: 'rgba(15,32,53,0.8)', drawBorder: false },\n          ticks: { color: '#4a6380', font: { size: 11, family: 'Manrope' } }\n        },\n        y: {\n          grid: { color: 'rgba(15,32,53,0.8)', drawBorder: false },\n          ticks: {\n            color: '#4a6380',\n            font: { size: 11, family: 'Manrope' },\n            callback: v => '$' + (v/1000).toFixed(0) + 'k'\n          }\n        }\n      }\n    }\n  });\n\n  // Donut Chart\n  const dCtx = document.getElementById('donutChart').getContext('2d');\n  new Chart(dCtx, {\n    type: 'doughnut',\n    data: {\n      labels: ['Completed', 'Pending', 'Disputed'],\n      datasets: [{\n        data: [78, 16, 6],\n        backgroundColor: ['#00d4a0', '#f59e0b', '#ef4444'],\n        borderColor: '#0d1520',\n        borderWidth: 3,\n        hoverBorderWidth: 0,\n      }]\n    },\n    options: {\n      responsive: true,\n      maintainAspectRatio: true,\n      cutout: '72%',\n      plugins: {\n        legend: { display: false },\n        tooltip: {\n          backgroundColor: '#0d1520',\n          borderColor: '#1a2840',\n          borderWidth: 1,\n          titleColor: '#e2e8f0',\n          bodyColor: '#8aaccc',\n        }\n      }\n    }\n  });\n</script>\n",
