      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    background: #010B13;\n    font-family: 'Manrope', sans-serif;\n    color: #e2e8f0;\n    min-height: 100vh;\n    overflow: hidden;\n  }\n\n  .navbar {\n    background: rgba(13, 21, 32, 0.95);\n    backdrop-filter: blur(12px);\n    border-bottom: 1px solid #1a2840;\n    padding: 0 24px;\n    height: 60px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    position: sticky;\n    top: 0;\n    z-index: 100;\n  }\n  .logo {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-family: 'Space Grotesk', sans-serif;\n    font-weight: 700;\n    font-size: 20px;\n    color: #FFD700;\n  }\n  .logo i { font-size: 22px; }\n  .nav-right { display: flex; align-items: center; gap: 16px; }\n  .nav-balance {\n    background: rgba(0, 212, 160, 0.1);\n    border: 1px solid rgba(0, 212, 160, 0.3);\n    color: #00d4a0;\n    padding: 6px 14px;\n    border-radius: 20px;\n    font-size: 13px;\n    font-weight: 600;\n  }\n  .nav-icon-btn {\n    width: 36px; height: 36px;\n    display: flex; align-items: center; justify-content: center;\n    background: #0d1520;\n    border: 1px solid #1a2840;\n    border-radius: 8px;\n    color: #94a3b8;\n    cursor: pointer;\n    position: relative;\n  }\n  .nav-icon-btn .badge {\n    position: absolute; top: -4px; right: -4px;\n    background: #ef4444; color: white;\n    width: 16px; height: 16px;\n    border-radius: 50%;\n    font-size: 9px;\n    display: flex; align-items: center; justify-content: center;\n    font-weight: 700;\n  }\n  .nav-avatar {\n    width: 34px; height: 34px;\n    border-radius: 50%;\n    border: 2px solid #FFD700;\n    overflow: hidden;\n  }\n  .nav-avatar img { width: 100%; height: 100%; object-fit: cover; }\n\n  .trade-room-body {\n    display: flex;\n    height: calc(100vh - 60px);\n    overflow: hidden;\n  }\n\n  /* LEFT SIDEBAR */\n  .trades-sidebar {\n    width: 260px;\n    flex-shrink: 0;\n    background: #060f1c;\n    border-right: 1px solid #1a2840;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n  }\n  .sidebar-header {\n    padding: 16px 16px 12px;\n    border-bottom: 1px solid #1a2840;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n  }\n  .sidebar-header h3 {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 14px;\n    font-weight: 600;\n    color: #e2e8f0;\n  }\n  .sidebar-badge {\n    background: rgba(0, 212, 160, 0.15);\n    color: #00d4a0;\n    font-size: 11px;\n    font-weight: 700;\n    padding: 2px 8px;\n    border-radius: 10px;\n  }\n  .trades-list { overflow-y: auto; flex: 1; padding: 8px 0; }\n\n  .trade-row {\n    padding: 12px 16px;\n    cursor: pointer;\n    border-left: 3px solid transparent;\n    position: relative;\n    transition: background 0.15s;\n  }\n  .trade-row:hover { background: rgba(255,255,255,0.03); }\n  .trade-row.active {\n    border-left-color: #00d4a0;\n    background: rgba(0, 212, 160, 0.07);\n  }\n  .trade-row-top {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    margin-bottom: 6px;\n  }\n  .trade-avatar {\n    width: 32px; height: 32px;\n    border-radius: 50%;\n    overflow: hidden;\n    flex-shrink: 0;\n  }\n  .trade-avatar img { width: 100%; height: 100%; object-fit: cover; }\n  .trade-row-info { flex: 1; min-width: 0; }\n  .trade-partner {\n    font-size: 13px;\n    font-weight: 600;\n    color: #e2e8f0;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n  }\n  .trade-id {\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 10px;\n    color: #4a6380;\n    margin-top: 1px;\n  }\n  .trade-row-bottom {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding-left: 42px;\n  }\n  .trade-amount { font-size: 12px; font-weight: 600; color: #94a3b8; }\n  .trade-time { font-size: 10px; color: #4a6380; }\n  .status-pill {\n    display: inline-flex;\n    align-items: center;\n    padding: 2px 8px;\n    border-radius: 10px;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.3px;\n  }\n  .status-awaiting { background: rgba(245,158,11,0.15); color: #f59e0b; }\n  .status-inprogress { background: rgba(0,212,160,0.15); color: #00d4a0; }\n  .status-completed { background: rgba(34,197,94,0.15); color: #22c55e; }\n  .status-disputed { background: rgba(239,68,68,0.15); color: #ef4444; }\n\n  /* CENTER PANEL */\n  .trade-center {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    overflow-y: auto;\n    padding: 24px;\n    gap: 20px;\n    border-right: 1px solid #1a2840;\n  }\n\n  .trade-header {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    flex-wrap: wrap;\n  }\n  .trade-header-left { display: flex; align-items: center; gap: 12px; }\n  .trade-title {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 20px;\n    font-weight: 700;\n    color: #fff;\n  }\n  .trade-title span {\n    font-family: 'JetBrains Mono', monospace;\n    color: #FFD700;\n  }\n\n  .timer-wrap {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    margin-left: auto;\n  }\n  .timer-ring {\n    position: relative;\n    width: 52px; height: 52px;\n    display: flex; align-items: center; justify-content: center;\n  }\n  .timer-ring svg {\n    position: absolute; top: 0; left: 0;\n    transform: rotate(-90deg);\n  }\n  .timer-ring .ring-bg { fill: none; stroke: #1a2840; stroke-width: 3; }\n  .timer-ring .ring-fill {\n    fill: none; stroke: #ef4444; stroke-width: 3;\n    stroke-dasharray: 138;\n    stroke-dashoffset: 35;\n    stroke-linecap: round;\n    animation: pulse-ring 2s ease-in-out infinite;\n  }\n  @keyframes pulse-ring {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.5; }\n  }\n  .timer-value {\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 16px;\n    font-weight: 700;\n    color: #ef4444;\n    z-index: 1;\n    position: relative;\n  }\n  .timer-label { font-size: 12px; color: #94a3b8; }\n\n  .trade-status-pill {\n    padding: 6px 14px;\n    border-radius: 20px;\n    font-size: 12px;\n    font-weight: 700;\n    letter-spacing: 0.5px;\n    background: rgba(245,158,11,0.15);\n    color: #f59e0b;\n    border: 1px solid rgba(245,158,11,0.3);\n  }\n\n  .trade-info-grid {\n    display: grid;\n    grid-template-columns: repeat(5, 1fr);\n    gap: 12px;\n  }\n  .info-card {\n    background: #0d1520;\n    border: 1px solid #1a2840;\n    border-radius: 12px;\n    padding: 14px 16px;\n  }\n  .info-label { font-size: 11px; color: #4a6380; font-weight: 500; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }\n  .info-value { font-size: 15px; font-weight: 700; color: #e2e8f0; }\n  .info-value.gold { color: #FFD700; }\n  .info-value.teal { color: #00d4a0; }\n  .info-value .sub { font-size: 11px; color: #94a3b8; font-weight: 400; margin-left: 4px; }\n\n  /* Escrow steps */\n  .escrow-steps {\n    background: #0d1520;\n    border: 1px solid #1a2840;\n    border-radius: 14px;\n    padding: 20px 28px;\n  }\n  .escrow-steps-title {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 13px;\n    font-weight: 600;\n    color: #94a3b8;\n    margin-bottom: 20px;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n  }\n  .steps-track {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    position: relative;\n  }\n  .steps-track::before {\n    content: '';\n    position: absolute;\n    top: 19px;\n    left: 48px;\n    right: 48px;\n    height: 2px;\n    background: #1a2840;\n    z-index: 0;\n  }\n  .step-item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 10px;\n    z-index: 1;\n    flex: 1;\n  }\n  .step-circle {\n    width: 38px; height: 38px;\n    border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    font-size: 15px;\n    font-weight: 700;\n    font-family: 'Space Grotesk', sans-serif;\n    position: relative;\n  }\n  .step-circle.done {\n    background: #00d4a0;\n    color: #010B13;\n  }\n  .step-circle.active {\n    background: rgba(0,212,160,0.15);\n    border: 2px solid #00d4a0;\n    color: #00d4a0;\n    box-shadow: 0 0 16px rgba(0,212,160,0.4);\n  }\n  .step-circle.pending {\n    background: #1a2840;\n    border: 2px solid #2a3850;\n    color: #4a6380;\n  }\n  .step-label {\n    font-size: 12px;\n    font-weight: 600;\n    color: #94a3b8;\n    text-align: center;\n    max-width: 90px;\n  }\n  .step-label.active-label { color: #00d4a0; }\n  .step-connector {\n    flex: 1;\n    height: 2px;\n    margin-top: -20px;\n    position: relative;\n    z-index: 0;\n  }\n  .step-connector.done-line { background: #00d4a0; }\n  .step-connector.pending-line { background: #1a2840; }\n\n  /* Payment instructions */\n  .payment-box {\n    background: rgba(255, 215, 0, 0.04);\n    border: 1px solid rgba(255, 215, 0, 0.3);\n    border-radius: 14px;\n    padding: 18px 22px;\n  }\n  .payment-box-title {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 13px;\n    font-weight: 700;\n    color: #FFD700;\n    margin-bottom: 12px;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n  }\n  .payment-detail-row {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    padding: 8px 0;\n    border-bottom: 1px solid rgba(255,215,0,0.1);\n  }\n  .payment-detail-row:last-child { border-bottom: none; padding-bottom: 0; }\n  .payment-detail-label { font-size: 12px; color: #94a3b8; width: 120px; flex-shrink: 0; }\n  .payment-detail-value { font-size: 13px; font-weight: 600; color: #e2e8f0; }\n  .copy-btn {\n    margin-left: auto;\n    background: rgba(255,215,0,0.1);\n    border: 1px solid rgba(255,215,0,0.2);\n    color: #FFD700;\n    font-size: 11px;\n    padding: 3px 10px;\n    border-radius: 6px;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    gap: 4px;\n    font-weight: 600;\n  }\n\n  /* Action buttons */\n  .action-row {\n    display: flex;\n    gap: 12px;\n    align-items: center;\n  }\n  .btn-paid {\n    flex: 1;\n    background: linear-gradient(135deg, #FFD700, #f59e0b);\n    color: #010B13;\n    border: none;\n    border-radius: 12px;\n    padding: 14px 24px;\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 15px;\n    font-weight: 700;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    box-shadow: 0 4px 20px rgba(255,215,0,0.25);\n  }\n  .btn-cancel {\n    background: transparent;\n    border: 1.5px solid rgba(239,68,68,0.5);\n    color: #ef4444;\n    border-radius: 10px;\n    padding: 12px 20px;\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 13px;\n    font-weight: 600;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    white-space: nowrap;\n  }\n  .btn-dispute {\n    background: transparent;\n    border: 1.5px solid rgba(245,158,11,0.5);\n    color: #f59e0b;\n    border-radius: 10px;\n    padding: 12px 20px;\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 13px;\n    font-weight: 600;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    white-space: nowrap;\n  }\n\n  /* RIGHT CHAT */\n  .chat-panel {\n    width: 340px;\n    flex-shrink: 0;\n    background: #060f1c;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n  }\n  .chat-header {\n    padding: 16px 20px;\n    border-bottom: 1px solid #1a2840;\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n  .chat-avatar {\n    width: 38px; height: 38px;\n    border-radius: 50%;\n    overflow: hidden;\n    position: relative;\n    flex-shrink: 0;\n  }\n  .chat-avatar img { width: 100%; height: 100%; object-fit: cover; }\n  .online-dot {\n    position: absolute;\n    bottom: 1px; right: 1px;\n    width: 10px; height: 10px;\n    background: #22c55e;\n    border-radius: 50%;\n    border: 2px solid #060f1c;\n  }\n  .chat-partner-name {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 14px;\n    font-weight: 600;\n    color: #e2e8f0;\n  }\n  .chat-partner-status { font-size: 11px; color: #22c55e; margin-top: 1px; }\n  .chat-actions { margin-left: auto; display: flex; gap: 8px; }\n  .chat-action-btn {\n    width: 32px; height: 32px;\n    background: #0d1520;\n    border: 1px solid #1a2840;\n    border-radius: 8px;\n    display: flex; align-items: center; justify-content: center;\n    color: #94a3b8;\n    font-size: 15px;\n    cursor: pointer;\n  }\n\n  .chat-messages {\n    flex: 1;\n    overflow-y: auto;\n    padding: 16px;\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n  }\n\n  .system-pill {\n    align-self: center;\n    background: rgba(255,215,0,0.06);\n    border: 1px solid rgba(255,215,0,0.25);\n    color: #FFD700;\n    font-size: 11px;\n    font-weight: 600;\n    padding: 6px 14px;\n    border-radius: 20px;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    max-width: 100%;\n    text-align: center;\n  }\n\n  .msg { display: flex; flex-direction: column; max-width: 85%; }\n  .msg.own { align-self: flex-end; align-items: flex-end; }\n  .msg.theirs { align-self: flex-start; align-items: flex-start; }\n\n  .msg-bubble {\n    padding: 10px 14px;\n    border-radius: 14px;\n    font-size: 13px;\n    line-height: 1.5;\n  }\n  .msg.own .msg-bubble {\n    background: linear-gradient(135deg, #00d4a0, #00b88a);\n    color: #010B13;\n    border-bottom-right-radius: 4px;\n  }\n  .msg.theirs .msg-bubble {\n    background: #1a2840;\n    color: #e2e8f0;\n    border-bottom-left-radius: 4px;\n  }\n  .msg-time {\n    font-size: 10px;\n    color: #4a6380;\n    margin-top: 3px;\n    padding: 0 4px;\n  }\n\n  .chat-input-area {\n    padding: 14px 16px;\n    border-top: 1px solid #1a2840;\n    display: flex;\n    gap: 10px;\n    align-items: center;\n  }\n  .chat-input {\n    flex: 1;\n    background: #0d1520;\n    border: 1px solid #1a2840;\n    border-radius: 10px;\n    padding: 10px 14px;\n    color: #e2e8f0;\n    font-family: 'Manrope', sans-serif;\n    font-size: 13px;\n    outline: none;\n  }\n  .chat-input::placeholder { color: #4a6380; }\n  .chat-send-btn {\n    width: 40px; height: 40px;\n    background: linear-gradient(135deg, #FFD700, #f59e0b);\n    border: none;\n    border-radius: 10px;\n    display: flex; align-items: center; justify-content: center;\n    color: #010B13;\n    font-size: 17px;\n    cursor: pointer;\n    flex-shrink: 0;\n  }\n\n  .chat-messages::-webkit-scrollbar { width: 4px; }\n  .chat-messages::-webkit-scrollbar-track { background: transparent; }\n  .chat-messages::-webkit-scrollbar-thumb { background: #1a2840; border-radius: 4px; }\n\n  .trades-list::-webkit-scrollbar { width: 4px; }\n  .trades-list::-webkit-scrollbar-track { background: transparent; }\n  .trades-list::-webkit-scrollbar-thumb { background: #1a2840; border-radius: 4px; }\n</style>\n\n\n<div class=\"navbar\" data-kid=\"1\">\n  <div class=\"logo\" data-kid=\"2\">\n    <i class=\"ti ti-shield-check\" data-kid=\"3\"></i>\n    EthioSwap\n  </div>\n  <div class=\"nav-right\" data-kid=\"4\">\n    <div class=\"nav-balance\" data-kid=\"5\">ETB 24,500</div>\n    <div class=\"nav-icon-btn\" data-kid=\"6\">\n      <i class=\"ti ti-bell\" style=\"font-size:17px;\" data-kid=\"7\"></i>\n      <div class=\"badge\" data-kid=\"8\">3</div>\n    </div>\n    <div class=\"nav-avatar\" data-kid=\"9\">\n      <img src=\"https://i.pravatar.cc/34?u=biruk47\" alt=\"Avatar\" loading=\"lazy\" decoding=\"async\" data-kid=\"10\">\n    </div>\n    <span style=\"font-family:'Space Grotesk',sans-serif;font-size:13px;font-weight:600;color:#e2e8f0;\" data-kid=\"11\">Biruk T.</span>\n  </div>\n</div>\n\n\n<div class=\"trade-room-body\" data-kid=\"12\">\n\n  \n  <div class=\"trades-sidebar\" data-kid=\"13\">\n    <div class=\"sidebar-header\" data-kid=\"14\">\n      <h3 data-kid=\"15\">Active Trades</h3>\n      <span class=\"sidebar-badge\" data-kid=\"16\">4</span>\n    </div>\n    <div class=\"trades-list\" data-kid=\"17\">\n\n      \n      <div class=\"trade-row active\" data-kid=\"18\">\n        <div class=\"trade-row-top\" data-kid=\"19\">\n          <div class=\"trade-avatar\" data-kid=\"20\">\n            <img src=\"https://i.pravatar.cc/32?u=abebe1\" alt=\"A\" loading=\"lazy\" decoding=\"async\" data-kid=\"21\">\n          </div>\n          <div class=\"trade-row-info\" data-kid=\"22\">\n            <div class=\"trade-partner\" data-kid=\"23\">Abebe M.</div>\n            <div class=\"trade-id\" data-kid=\"24\">#TRD-2847</div>\n          </div>\n          <span class=\"status-pill status-awaiting\" data-kid=\"25\">AWAITING</span>\n        </div>\n        <div class=\"trade-row-bottom\" data-kid=\"26\">\n          <span class=\"trade-amount\" data-kid=\"27\">0.045 ETH</span>\n          <span class=\"trade-time\" data-kid=\"28\">14 min left</span>\n        </div>\n      </div>\n\n      \n      <div class=\"trade-row\" data-kid=\"29\">\n        <div class=\"trade-row-top\" data-kid=\"30\">\n          <div class=\"trade-avatar\" data-kid=\"31\">\n            <img src=\"https://i.pravatar.cc/32?u=tigist2\" alt=\"T\" loading=\"lazy\" decoding=\"async\" data-kid=\"32\">\n          </div>\n          <div class=\"trade-row-info\" data-kid=\"33\">\n            <div class=\"trade-partner\" data-kid=\"34\">Tigist W.</div>\n            <div class=\"trade-id\" data-kid=\"35\">#TRD-2843</div>\n          </div>\n          <span class=\"status-pill status-inprogress\" data-kid=\"36\">IN PROGRESS</span>\n        </div>\n        <div class=\"trade-row-bottom\" data-kid=\"37\">\n          <span class=\"trade-amount\" data-kid=\"38\">0.12 ETH</span>\n          <span class=\"trade-time\" data-kid=\"39\">2h ago</span>\n        </div>\n      </div>\n\n      \n      <div class=\"trade-row\" data-kid=\"40\">\n        <div class=\"trade-row-top\" data-kid=\"41\">\n          <div class=\"trade-avatar\" data-kid=\"42\">\n            <img src=\"https://i.pravatar.cc/32?u=solomon3\" alt=\"S\" loading=\"lazy\" decoding=\"async\" data-kid=\"43\">\n          </div>\n          <div class=\"trade-row-info\" data-kid=\"44\">\n            <div class=\"trade-partner\" data-kid=\"45\">Solomon G.</div>\n            <div class=\"trade-id\" data-kid=\"46\">#TRD-2831</div>\n          </div>\n          <span class=\"status-pill status-completed\" data-kid=\"47\">DONE</span>\n        </div>\n        <div class=\"trade-row-bottom\" data-kid=\"48\">\n          <span class=\"trade-amount\" data-kid=\"49\">0.08 ETH</span>\n          <span class=\"trade-time\" data-kid=\"50\">5h ago</span>\n        </div>\n      </div>\n\n      \n      <div class=\"trade-row\" data-kid=\"51\">\n        <div class=\"trade-row-top\" data-kid=\"52\">\n          <div class=\"trade-avatar\" data-kid=\"53\">\n            <img src=\"https://i.pravatar.cc/32?u=mekdes4\" alt=\"M\" loading=\"lazy\" decoding=\"async\" data-kid=\"54\">\n          </div>\n          <div class=\"trade-row-info\" data-kid=\"55\">\n            <div class=\"trade-partner\" data-kid=\"56\">Mekdes A.</div>\n            <div class=\"trade-id\" data-kid=\"57\">#TRD-2819</div>\n          </div>\n          <span class=\"status-pill status-disputed\" data-kid=\"58\">DISPUTED</span>\n        </div>\n        <div class=\"trade-row-bottom\" data-kid=\"59\">\n          <span class=\"trade-amount\" data-kid=\"60\">0.032 ETH</span>\n          <span class=\"trade-time\" data-kid=\"61\">1d ago</span>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  \n  <div class=\"trade-center\" data-kid=\"62\">\n\n    \n    <div class=\"trade-header\" data-kid=\"63\">\n      <div class=\"trade-header-left\" data-kid=\"64\">\n        <div class=\"trade-title\" data-kid=\"65\">Trade <span data-kid=\"66\">#TRD-2847</span></div>\n        <span class=\"trade-status-pill\" data-kid=\"67\">⏳ AWAITING PAYMENT</span>\n      </div>\n      <div class=\"timer-wrap\" data-kid=\"68\">\n        <div style=\"text-align:right;\" data-kid=\"69\">\n          <div style=\"font-size:11px;color:#94a3b8;margin-bottom:2px;\" data-kid=\"70\">Time Remaining</div>\n          <div style=\"font-family:'JetBrains Mono',monospace;font-size:22px;font-weight:700;color:#ef4444;line-height:1;\" data-kid=\"71\">14:32</div>\n        </div>\n        <div class=\"timer-ring\" data-kid=\"72\">\n          <svg width=\"52\" height=\"52\" viewBox=\"0 0 52 52\" data-kid=\"73\">\n            <circle class=\"ring-bg\" cx=\"26\" cy=\"26\" r=\"22\" data-kid=\"74\"></circle>\n            <circle class=\"ring-fill\" cx=\"26\" cy=\"26\" r=\"22\" data-kid=\"75\"></circle>\n          </svg>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"trade-info-grid\" data-kid=\"76\">\n      <div class=\"info-card\" data-kid=\"77\">\n        <div class=\"info-label\" data-kid=\"78\">ETH Amount</div>\n        <div class=\"info-value gold\" data-kid=\"79\">0.045 <span class=\"sub\" data-kid=\"80\">ETH</span></div>\n      </div>\n      <div class=\"info-card\" data-kid=\"81\">\n        <div class=\"info-label\" data-kid=\"82\">ETB Value</div>\n        <div class=\"info-value teal\" data-kid=\"83\">12,420 <span class=\"sub\" data-kid=\"84\">ETB</span></div>\n      </div>\n      <div class=\"info-card\" data-kid=\"85\">\n        <div class=\"info-label\" data-kid=\"86\">Buyer</div>\n        <div class=\"info-value\" style=\"display:flex;align-items:center;gap:6px;\" data-kid=\"87\">\n          <img src=\"https://i.pravatar.cc/20?u=biruk47\" style=\"width:20px;height:20px;border-radius:50%;\" loading=\"lazy\" decoding=\"async\" alt=\"B\" data-kid=\"88\">\n          Biruk T.\n        </div>\n      </div>\n      <div class=\"info-card\" data-kid=\"89\">\n        <div class=\"info-label\" data-kid=\"90\">Seller</div>\n        <div class=\"info-value\" style=\"display:flex;align-items:center;gap:6px;\" data-kid=\"91\">\n          <img src=\"https://i.pravatar.cc/20?u=abebe1\" style=\"width:20px;height:20px;border-radius:50%;\" loading=\"lazy\" decoding=\"async\" alt=\"A\" data-kid=\"92\">\n          Abebe M.\n        </div>\n      </div>\n      <div class=\"info-card\" data-kid=\"93\">\n        <div class=\"info-label\" data-kid=\"94\">Payment</div>\n        <div class=\"info-value\" style=\"display:flex;align-items:center;gap:6px;font-size:13px;\" data-kid=\"95\">\n          <i class=\"ti ti-device-mobile\" style=\"color:#00d4a0;font-size:16px;\" data-kid=\"96\"></i>\n          Telebirr\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"escrow-steps\" data-kid=\"97\">\n      <div class=\"escrow-steps-title\" data-kid=\"98\">Escrow Progress</div>\n      <div style=\"display:flex;align-items:center;\" data-kid=\"99\">\n\n        <div class=\"step-item\" data-kid=\"100\">\n          <div class=\"step-circle done\" data-kid=\"101\">\n            <i class=\"ti ti-check\" style=\"font-size:16px;\" data-kid=\"102\"></i>\n          </div>\n          <div class=\"step-label\" data-kid=\"103\">Order Created</div>\n        </div>\n\n        <div style=\"flex:1;height:2px;background:#00d4a0;margin-top:-28px;\" data-kid=\"104\"></div>\n\n        <div class=\"step-item\" data-kid=\"105\">\n          <div class=\"step-circle active\" data-kid=\"106\">2</div>\n          <div class=\"step-label active-label\" data-kid=\"107\">Payment Sent</div>\n        </div>\n\n        <div style=\"flex:1;height:2px;background:#1a2840;margin-top:-28px;\" data-kid=\"108\"></div>\n\n        <div class=\"step-item\" data-kid=\"109\">\n          <div class=\"step-circle pending\" data-kid=\"110\">3</div>\n          <div class=\"step-label\" data-kid=\"111\">Crypto Released</div>\n        </div>\n\n      </div>\n    </div>\n\n    \n    <div class=\"payment-box\" data-kid=\"112\">\n      <div class=\"payment-box-title\" data-kid=\"113\">\n        <i class=\"ti ti-info-circle\" data-kid=\"114\"></i>\n        Payment Instructions\n      </div>\n      <div class=\"payment-detail-row\" data-kid=\"115\">\n        <span class=\"payment-detail-label\" data-kid=\"116\">Method</span>\n        <span class=\"payment-detail-value\" data-kid=\"117\">Telebirr</span>\n      </div>\n      <div class=\"payment-detail-row\" data-kid=\"118\">\n        <span class=\"payment-detail-label\" data-kid=\"119\">Amount to Send</span>\n        <span class=\"payment-detail-value\" style=\"color:#FFD700;font-size:15px;\" data-kid=\"120\">ETB 12,420.00</span>\n        <div class=\"copy-btn\" data-kid=\"121\"><i class=\"ti ti-copy\" style=\"font-size:12px;\" data-kid=\"122\"></i> Copy</div>\n      </div>\n      <div class=\"payment-detail-row\" data-kid=\"123\">\n        <span class=\"payment-detail-label\" data-kid=\"124\">Recipient Name</span>\n        <span class=\"payment-detail-value\" data-kid=\"125\">Abebe Mengistu</span>\n      </div>\n      <div class=\"payment-detail-row\" data-kid=\"126\">\n        <span class=\"payment-detail-label\" data-kid=\"127\">Phone Number</span>\n        <span class=\"payment-detail-value\" style=\"font-family:'JetBrains Mono',monospace;\" data-kid=\"128\">+251912345678</span>\n        <div class=\"copy-btn\" data-kid=\"129\"><i class=\"ti ti-copy\" style=\"font-size:12px;\" data-kid=\"130\"></i> Copy</div>\n      </div>\n      <div style=\"margin-top:12px;font-size:11px;color:#f59e0b;display:flex;align-items:center;gap:6px;\" data-kid=\"131\">\n        <i class=\"ti ti-alert-triangle\" data-kid=\"132\"></i>\n        Do not close this page until you have sent payment and confirmed in chat.\n      </div>\n    </div>\n\n    \n    <div class=\"action-row\" data-kid=\"133\">\n      <button class=\"btn-paid\" data-kid=\"134\">\n        <i class=\"ti ti-check\" style=\"font-size:18px;\" data-kid=\"135\"></i>\n        I Have Paid — Notify Seller\n      </button>\n      <button class=\"btn-cancel\" data-kid=\"136\">\n        <i class=\"ti ti-x\" style=\"font-size:14px;\" data-kid=\"137\"></i>\n        Cancel Trade\n      </button>\n      <button class=\"btn-dispute\" data-kid=\"138\">\n        <i class=\"ti ti-alert-circle\" style=\"font-size:14px;\" data-kid=\"139\"></i>\n        Open Dispute\n      </button>\n    </div>\n\n  </div>\n\n  \n  <div class=\"chat-panel\" data-kid=\"140\">\n    <div class=\"chat-header\" data-kid=\"141\">\n      <div class=\"chat-avatar\" data-kid=\"142\">\n        <img src=\"https://i.pravatar.cc/38?u=abebe1\" alt=\"Abebe\" loading=\"lazy\" decoding=\"async\" data-kid=\"143\">\n        <div class=\"online-dot\" data-kid=\"144\"></div>\n      </div>\n      <div data-kid=\"145\">\n        <div class=\"chat-partner-name\" data-kid=\"146\">Abebe M.</div>\n        <div class=\"chat-partner-status\" data-kid=\"147\">● Online</div>\n      </div>\n      <div class=\"chat-actions\" data-kid=\"148\">\n        <div class=\"chat-action-btn\" data-kid=\"149\"><i class=\"ti ti-phone\" style=\"font-size:14px;\" data-kid=\"150\"></i></div>\n        <div class=\"chat-action-btn\" data-kid=\"151\"><i class=\"ti ti-dots-vertical\" style=\"font-size:14px;\" data-kid=\"152\"></i></div>\n      </div>\n    </div>\n\n    <div class=\"chat-messages\" data-kid=\"153\">\n\n      \n      <div class=\"system-pill\" data-kid=\"154\">\n        <i class=\"ti ti-lock\" style=\"font-size:12px;\" data-kid=\"155\"></i>\n        Escrow activated — 0.045 ETH locked safely\n      </div>\n\n      \n      <div class=\"msg theirs\" data-kid=\"156\">\n        <div class=\"msg-bubble\" data-kid=\"157\">Hello! I'm ready. Please send ETB 12,420 to my Telebirr number as shown in the instructions.</div>\n        <div class=\"msg-time\" data-kid=\"158\">10:14 AM</div>\n      </div>\n\n      \n      <div class=\"msg own\" data-kid=\"159\">\n        <div class=\"msg-bubble\" data-kid=\"160\">Got it, I'll send the payment right now. Give me 2 minutes.</div>\n        <div class=\"msg-time\" data-kid=\"161\">10:15 AM</div>\n      </div>\n\n      \n      <div class=\"msg theirs\" data-kid=\"162\">\n        <div class=\"msg-bubble\" data-kid=\"163\">No problem, take your time. Timer shows 14 minutes remaining.</div>\n        <div class=\"msg-time\" data-kid=\"164\">10:15 AM</div>\n      </div>\n\n      \n      <div class=\"system-pill\" data-kid=\"165\">\n        <i class=\"ti ti-clock\" style=\"font-size:12px;\" data-kid=\"166\"></i>\n        Trade timer started — 15 minutes to complete payment\n      </div>\n\n      \n      <div class=\"msg own\" data-kid=\"167\">\n        <div class=\"msg-bubble\" data-kid=\"168\">Payment sent! Screenshot attached. Please check and confirm.</div>\n        <div class=\"msg-time\" data-kid=\"169\">10:18 AM</div>\n      </div>\n\n      \n      <div class=\"msg theirs\" data-kid=\"170\">\n        <div class=\"msg-bubble\" data-kid=\"171\">Checking now... one moment please 🔍</div>\n        <div class=\"msg-time\" data-kid=\"172\">10:18 AM</div>\n      </div>\n\n    </div>\n\n    <div class=\"chat-input-area\" data-kid=\"173\">\n      <input type=\"text\" class=\"chat-input\" placeholder=\"Type a message...\" data-kid=\"174\">\n      <button class=\"chat-send-btn\" data-kid=\"175\">\n        <i class=\"ti ti-send\" style=\"font-size:16px;\" data-kid=\"176\"></i>\n      </button>\n    </div>\n  </div>\n\n</div>\n",
