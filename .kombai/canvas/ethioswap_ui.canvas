      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: 'Manrope', sans-serif;\n    background: #010B13;\n    color: #e2e8f0;\n    display: flex;\n    height: 100vh;\n    overflow: hidden;\n  }\n\n  /* ─── SIDEBAR ─────────────────────────────────────────── */\n  .sidebar {\n    width: 220px;\n    min-width: 220px;\n    background: #060f1c;\n    border-right: 1px solid #0f2035;\n    display: flex;\n    flex-direction: column;\n    padding: 0;\n    height: 100vh;\n    overflow-y: auto;\n  }\n\n  .sidebar-logo {\n    padding: 20px 18px 16px;\n    border-bottom: 1px solid #0f2035;\n  }\n\n  .sidebar-logo .logo-text {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 18px;\n    font-weight: 700;\n    color: #FFD700;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n\n  .sidebar-logo .logo-text i { font-size: 20px; }\n\n  .sidebar-logo .admin-badge {\n    font-size: 10px;\n    font-weight: 600;\n    color: #00d4a0;\n    background: rgba(0,212,160,0.1);\n    border: 1px solid rgba(0,212,160,0.3);\n    padding: 2px 6px;\n    border-radius: 4px;\n    margin-top: 4px;\n    display: inline-block;\n  }\n\n  .sidebar-profile {\n    padding: 16px 18px;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    border-bottom: 1px solid #0f2035;\n  }\n\n  .sidebar-profile img {\n    width: 36px;\n    height: 36px;\n    border-radius: 50%;\n    border: 2px solid #FFD700;\n  }\n\n  .sidebar-profile .name {\n    font-size: 13px;\n    font-weight: 600;\n    color: #e2e8f0;\n  }\n\n  .sidebar-profile .role {\n    font-size: 11px;\n    color: #FFD700;\n  }\n\n  .sidebar-nav {\n    padding: 12px 0;\n    flex: 1;\n  }\n\n  .nav-section-label {\n    font-size: 10px;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n    color: #2a4060;\n    padding: 8px 18px 4px;\n  }\n\n  .nav-item {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    padding: 10px 18px;\n    cursor: pointer;\n    font-size: 13px;\n    font-weight: 500;\n    color: #6b8aaa;\n    border-radius: 0;\n    position: relative;\n  }\n\n  .nav-item:hover { color: #c0cfe0; background: rgba(255,255,255,0.03); }\n\n  .nav-item.active {\n    color: #010B13;\n    background: linear-gradient(90deg, #FFD700, #f0b800);\n    border-radius: 8px;\n    margin: 0 10px;\n    padding: 10px 14px;\n    font-weight: 700;\n  }\n\n  .nav-item.active i { color: #010B13; }\n\n  .nav-item i { font-size: 17px; width: 20px; text-align: center; }\n\n  .nav-badge {\n    margin-left: auto;\n    background: #ef4444;\n    color: white;\n    font-size: 10px;\n    font-weight: 700;\n    padding: 2px 6px;\n    border-radius: 10px;\n    min-width: 18px;\n    text-align: center;\n  }\n\n  .nav-badge.amber { background: #f59e0b; }\n\n  .sidebar-bottom {\n    padding: 12px 0;\n    border-top: 1px solid #0f2035;\n  }\n\n  .nav-item.logout { color: #ef4444; }\n  .nav-item.logout:hover { background: rgba(239,68,68,0.08); color: #ef4444; }\n\n  /* ─── MAIN CONTENT ─────────────────────────────────────── */\n  .main {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n    background: #010B13;\n  }\n\n  .topbar {\n    padding: 14px 24px;\n    border-bottom: 1px solid #0f2035;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    background: #010B13;\n    flex-shrink: 0;\n  }\n\n  .topbar-title {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 20px;\n    font-weight: 700;\n    color: #e2e8f0;\n  }\n\n  .topbar-title span { color: #FFD700; }\n\n  .topbar-right {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n\n  .topbar-time {\n    font-size: 12px;\n    color: #4a6380;\n    font-family: 'Space Grotesk', sans-serif;\n  }\n\n  .topbar-bell {\n    position: relative;\n    width: 34px;\n    height: 34px;\n    border-radius: 8px;\n    background: #0d1520;\n    border: 1px solid #1a2840;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n  }\n\n  .topbar-bell i { font-size: 16px; color: #6b8aaa; }\n\n  .notif-dot {\n    position: absolute;\n    top: 6px;\n    right: 7px;\n    width: 7px;\n    height: 7px;\n    border-radius: 50%;\n    background: #ef4444;\n    border: 1.5px solid #010B13;\n  }\n\n  .content-area {\n    flex: 1;\n    overflow-y: auto;\n    padding: 20px 24px;\n    display: flex;\n    flex-direction: column;\n    gap: 20px;\n  }\n\n  /* ─── KPI CARDS ─────────────────────────────────────────── */\n  .kpi-row {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 16px;\n  }\n\n  .kpi-card {\n    background: #0d1520;\n    border: 1px solid #1a2840;\n    border-radius: 14px;\n    padding: 18px 20px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .kpi-card::before {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 3px;\n    border-radius: 14px 14px 0 0;\n  }\n\n  .kpi-card.teal::before { background: linear-gradient(90deg, #00d4a0, #00b8a0); }\n  .kpi-card.gold::before { background: linear-gradient(90deg, #FFD700, #f0b800); }\n  .kpi-card.amber::before { background: linear-gradient(90deg, #f59e0b, #d97706); }\n  .kpi-card.red::before { background: linear-gradient(90deg, #ef4444, #dc2626); }\n\n  .kpi-top {\n    display: flex;\n    align-items: flex-start;\n    justify-content: space-between;\n    margin-bottom: 12px;\n  }\n\n  .kpi-icon {\n    width: 38px;\n    height: 38px;\n    border-radius: 10px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 18px;\n  }\n\n  .kpi-icon.teal { background: rgba(0,212,160,0.1); color: #00d4a0; }\n  .kpi-icon.gold { background: rgba(255,215,0,0.1); color: #FFD700; }\n  .kpi-icon.amber { background: rgba(245,158,11,0.1); color: #f59e0b; }\n  .kpi-icon.red { background: rgba(239,68,68,0.1); color: #ef4444; }\n\n  .kpi-trend {\n    font-size: 11px;\n    font-weight: 600;\n    padding: 3px 7px;\n    border-radius: 6px;\n  }\n\n  .kpi-trend.up { background: rgba(0,212,160,0.1); color: #00d4a0; }\n  .kpi-trend.down { background: rgba(239,68,68,0.1); color: #ef4444; }\n\n  .kpi-value {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 28px;\n    font-weight: 800;\n    color: #f0f6ff;\n    line-height: 1;\n    margin-bottom: 4px;\n  }\n\n  .kpi-label {\n    font-size: 12px;\n    color: #4a6380;\n    font-weight: 500;\n  }\n\n  .kpi-sub {\n    font-size: 11px;\n    color: #2a4060;\n    margin-top: 8px;\n    padding-top: 8px;\n    border-top: 1px solid #0f2035;\n  }\n\n  /* ─── CHARTS ROW ─────────────────────────────────────────── */\n  .charts-row {\n    display: grid;\n    grid-template-columns: 1.6fr 1fr;\n    gap: 16px;\n  }\n\n  .chart-card {\n    background: #0d1520;\n    border: 1px solid #1a2840;\n    border-radius: 14px;\n    padding: 20px;\n  }\n\n  .chart-header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 16px;\n  }\n\n  .chart-title {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    color: #c8d8ec;\n  }\n\n  .chart-subtitle {\n    font-size: 11px;\n    color: #4a6380;\n    margin-top: 2px;\n  }\n\n  .chart-period-btns {\n    display: flex;\n    gap: 6px;\n  }\n\n  .period-btn {\n    font-size: 11px;\n    font-weight: 600;\n    padding: 4px 10px;\n    border-radius: 6px;\n    border: none;\n    cursor: pointer;\n    background: transparent;\n    color: #4a6380;\n  }\n\n  .period-btn.active {\n    background: rgba(255,215,0,0.12);\n    color: #FFD700;\n  }\n\n  .chart-wrap { position: relative; }\n  .chart-wrap canvas { max-height: 160px !important; }\n  .donut-wrap { position: relative; }\n  .donut-wrap canvas { max-height: 160px !important; }\n\n  .donut-legend {\n    display: flex;\n    gap: 14px;\n    flex-wrap: wrap;\n    margin-top: 12px;\n  }\n\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-size: 12px;\n    color: #6b8aaa;\n  }\n\n  .legend-dot {\n    width: 9px;\n    height: 9px;\n    border-radius: 50%;\n    flex-shrink: 0;\n  }\n\n  /* ─── TABLES ─────────────────────────────────────────────── */\n  .tables-row {\n    display: grid;\n    grid-template-columns: 1.1fr 1fr;\n    gap: 16px;\n  }\n\n  .table-card {\n    background: #0d1520;\n    border: 1px solid #1a2840;\n    border-radius: 14px;\n    overflow: hidden;\n  }\n\n  .table-header {\n    padding: 16px 20px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    border-bottom: 1px solid #0f2035;\n  }\n\n  .table-title {\n    font-family: 'Space Grotesk', sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    color: #c8d8ec;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n\n  .table-title i { font-size: 16px; color: #FFD700; }\n\n  .table-count {\n    background: rgba(255,215,0,0.1);\n    color: #FFD700;\n    font-size: 11px;\n    font-weight: 700;\n    padding: 3px 8px;\n    border-radius: 20px;\n  }\n\n  .btn-view-all {\n    font-size: 12px;\n    color: #00d4a0;\n    background: transparent;\n    border: none;\n    cursor: pointer;\n    font-weight: 600;\n  }\n\n  .data-table {\n    width: 100%;\n    border-collapse: collapse;\n  }\n\n  .data-table th {\n    font-size: 10px;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.8px;\n    color: #2a4060;\n    padding: 10px 16px;\n    text-align: left;\n    background: #060f1c;\n    border-bottom: 1px solid #0f2035;\n  }\n\n  .data-table td {\n    padding: 11px 16px;\n    font-size: 12px;\n    color: #8aaccc;\n    border-bottom: 1px solid rgba(15,32,53,0.6);\n    vertical-align: middle;\n  }\n\n  .data-table tr:last-child td { border-bottom: none; }\n  .data-table tr:hover td { background: rgba(255,255,255,0.02); }\n\n  .user-cell {\n    display: flex;\n    align-items: center;\n    gap: 9px;\n  }\n\n  .user-avatar {\n    width: 28px;\n    height: 28px;\n    border-radius: 50%;\n    object-fit: cover;\n    border: 1.5px solid #1a2840;\n  }\n\n  .user-name {\n    font-size: 13px;\n    font-weight: 600;\n    color: #c8d8ec;\n  }\n\n  .user-email { font-size: 11px; color: #4a6380; }\n\n  .status-pill {\n    display: inline-flex;\n    align-items: center;\n    gap: 5px;\n    padding: 4px 10px;\n    border-radius: 20px;\n    font-size: 11px;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.4px;\n  }\n\n  .status-pill.pending { background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.25); }\n  .status-pill.under-review { background: rgba(99,102,241,0.12); color: #818cf8; border: 1px solid rgba(99,102,241,0.25); }\n  .status-pill.approved { background: rgba(0,212,160,0.1); color: #00d4a0; border: 1px solid rgba(0,212,160,0.2); }\n  .status-pill.disputed { background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }\n  .status-pill.resolved { background: rgba(0,212,160,0.08); color: #00d4a0; border: 1px solid rgba(0,212,160,0.15); }\n\n  .action-btns { display: flex; gap: 6px; }\n\n  .btn-approve, .btn-reject, .btn-view {\n    padding: 5px 12px;\n    border: none;\n    border-radius: 7px;\n    font-size: 11px;\n    font-weight: 700;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    gap: 4px;\n  }\n\n  .btn-approve { background: rgba(0,212,160,0.15); color: #00d4a0; border: 1px solid rgba(0,212,160,0.25); }\n  .btn-reject { background: rgba(239,68,68,0.12); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }\n  .btn-view { background: rgba(255,215,0,0.1); color: #FFD700; border: 1px solid rgba(255,215,0,0.2);