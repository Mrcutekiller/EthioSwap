      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .ticket-stub {\n    position: relative;\n    background: var(--k-color-bg-surface-hover);\n    border: 1px solid var(--k-color-border-hover);\n    border-radius: var(--k-radius-lg);\n    overflow: hidden;\n  }\n\n  .ticket-stub::before,\n  .ticket-stub::after {\n    content: '';\n    position: absolute;\n    width: 24px;\n    height: 24px;\n    background: var(--k-color-bg-page);\n    border: 1px solid var(--k-color-border);\n    border-radius: 50%;\n    top: 50%;\n    transform: translateY(-50%);\n    z-index: 10;\n  }\n\n  .ticket-stub::before { left: -13px; }\n  .ticket-stub::after { right: -13px; }\n\n  .nav-pill-active {\n    background: linear-gradient(90deg, var(--k-color-primary), #f0b800);\n    color: var(--k-color-bg-page);\n    font-weight: 700;\n    box-shadow: 0 4px 15px rgba(255, 215, 0, 0.2);\n  }\n\n  .nav-pill-inactive {\n    background: var(--k-color-bg-surface-hover);\n    border: 1px solid var(--k-color-border-hover);\n    color: var(--k-color-text-secondary);\n  }\n\n  .hexagon-avatar {\n    clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);\n  }\n\n  .glow-gold {\n    box-shadow: 0 0 20px rgba(255, 215, 0, 0.15);\n  }\n\n  .dashed-line {\n    border-right: 1px dashed var(--k-color-border);\n  }\n\n  .buy-sell-toggle {\n    background: var(--k-color-bg-surface);\n    border: 1px solid var(--k-color-border);\n  }\n\n  .active-buy {\n    background: var(--k-color-bg-surface-hover);\n    color: var(--k-color-primary);\n    border: 1px solid rgba(255, 215, 0, 0.2);\n  }\n</style>\n\n<div class=\"min-h-screen bg-[var(--k-color-bg-page)] text-[var(--k-color-text-primary)] font-[var(--k-font-family-body)] selection:bg-[var(--k-color-primary)] selection:text-black\" data-kid=\"1\">\n  \n  \n  <header class=\"sticky top-0 z-50 w-full border-b border-[var(--k-color-border)] bg-[var(--k-color-bg-page)]/80 backdrop-blur-xl\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto px-8 h-20 flex items-center justify-between\" data-kid=\"3\">\n      \n      <div class=\"flex items-center gap-3\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[var(--k-color-primary)] rounded-lg flex items-center justify-center glow-gold\" data-kid=\"5\">\n          <i class=\"ti ti-shield-check text-[#010B13] text-2xl\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"text-2xl font-bold font-[var(--k-font-family-heading)] tracking-tight\" data-kid=\"7\">EthioSwap</span>\n      </div>\n\n      \n      <div class=\"hidden md:flex items-center gap-4\" data-kid=\"8\">\n        <div class=\"bg-[var(--k-color-bg-surface-hover)] border border-[var(--k-color-border-hover)] px-5 py-2 rounded-xl flex flex-col items-center\" data-kid=\"9\">\n          <span class=\"text-[var(--k-color-text-muted)] text-[10px] uppercase tracking-widest font-extrabold mb-0.5\" data-kid=\"10\">Live Balance</span>\n          <div class=\"flex items-center gap-3 font-mono\" data-kid=\"11\">\n            <span class=\"text-[var(--k-color-primary)] text-lg font-bold\" data-kid=\"12\">$2,847.50 USD</span>\n            <span class=\"text-[var(--k-color-text-muted)] opacity-50\" data-kid=\"13\">≈</span>\n            <span class=\"text-[var(--k-color-text-primary)] font-medium\" data-kid=\"14\">541,025 ETB</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"flex items-center gap-4\" data-kid=\"15\">\n        <div class=\"relative w-10 h-10 flex items-center justify-center bg-[var(--k-color-bg-surface-hover)] border border-[var(--k-color-border-hover)] rounded-lg cursor-pointer hover:border-[var(--k-color-primary)]/40 transition-all\" data-kid=\"16\">\n          <i class=\"ti ti-bell text-[var(--k-color-text-secondary)] text-xl\" data-kid=\"17\"></i>\n          <span class=\"absolute top-2.5 right-3 w-1.5 h-1.5 rounded-full bg-[var(--k-color-error)] border border-[var(--k-color-bg-page)]\" data-kid=\"18\"></span>\n        </div>\n        <button class=\"flex items-center gap-2 px-4 py-2 rounded-lg bg-[var(--k-color-error)]/10 text-[var(--k-color-error)] border border-[var(--k-color-error)]/20 hover:bg-[var(--k-color-error)]/20 transition-all font-bold text-sm\" data-kid=\"19\">\n          <i class=\"ti ti-logout text-lg\" data-kid=\"20\"></i>\n          <span data-kid=\"21\">Logout</span>\n        </button>\n      </div>\n    </div>\n  </header>\n\n  \n  <nav class=\"max-w-7xl mx-auto px-8 mt-8\" data-kid=\"22\">\n    <div class=\"flex flex-wrap items-center gap-3 bg-[var(--k-color-bg-surface)] p-2 rounded-2xl border border-[var(--k-color-border)]\" data-kid=\"23\">\n      <button class=\"nav-pill-active px-6 py-2.5 rounded-xl flex items-center gap-2 font-semibold\" data-kid=\"24\">\n        <i class=\"ti ti-shopping-cart text-xl\" data-kid=\"25\"></i>\n        <span data-kid=\"26\">Marketplace</span>\n      </button>\n      <button class=\"nav-pill-inactive px-6 py-2.5 rounded-xl flex items-center gap-2 font-bold hover:bg-white/5 transition-all\" data-kid=\"27\">\n        <i class=\"ti ti-wallet text-xl\" data-kid=\"28\"></i>\n        <span data-kid=\"29\">Wallet</span>\n      </button>\n      <button class=\"nav-pill-inactive px-6 py-2.5 rounded-xl flex items-center gap-2 font-bold hover:bg-white/5 transition-all relative\" data-kid=\"30\">\n        <i class=\"ti ti-shield-lock text-xl\" data-kid=\"31\"></i>\n        <span data-kid=\"32\">Active Trades</span>\n        <span class=\"ml-1 px-1.5 py-0.5 bg-[var(--k-color-primary)] text-black text-[10px] font-bold rounded\" data-kid=\"33\">3</span>\n      </button>\n      <button class=\"nav-pill-inactive px-6 py-2.5 rounded-xl flex items-center gap-2 font-bold hover:bg-white/5 transition-all\" data-kid=\"34\">\n        <i class=\"ti ti-history text-xl\" data-kid=\"35\"></i>\n        <span data-kid=\"36\">History</span>\n      </button>\n      <button class=\"nav-pill-inactive px-6 py-2.5 rounded-xl flex items-center gap-2 font-bold hover:bg-white/5 transition-all\" data-kid=\"37\">\n        <i class=\"ti ti-gift text-xl\" data-kid=\"38\"></i>\n        <span data-kid=\"39\">Invite & Earn</span>\n      </button>\n      <button class=\"nav-pill-inactive px-6 py-2.5 rounded-xl flex items-center gap-2 font-bold hover:bg-white/5 transition-all\" data-kid=\"40\">\n        <i class=\"ti ti-award text-xl\" data-kid=\"41\"></i>\n        <span data-kid=\"42\">Ranks</span>\n      </button>\n      <button class=\"nav-pill-inactive px-6 py-2.5 rounded-xl flex items-center gap-2 font-bold hover:bg-white/5 transition-all\" data-kid=\"43\">\n        <i class=\"ti ti-user text-xl\" data-kid=\"44\"></i>\n        <span data-kid=\"45\">Profile</span>\n      </button>\n    </div>\n  </nav>\n\n  \n  <main class=\"max-w-7xl mx-auto px-8 py-12\" data-kid=\"46\">\n    \n    \n    <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12\" data-kid=\"47\">\n      <div class=\"buy-sell-toggle p-1.5 rounded-xl flex items-center gap-1 w-fit\" data-kid=\"48\">\n        <button class=\"active-buy px-10 py-2.5 rounded-lg font-extrabold text-sm uppercase tracking-widest\" data-kid=\"49\">BUY</button>\n        <button class=\"px-10 py-2.5 rounded-lg text-[var(--k-color-text-secondary)] font-bold text-sm hover:text-[var(--k-color-text-primary)] transition-all uppercase tracking-widest\" data-kid=\"50\">SELL</button>\n      </div>\n\n      <div class=\"flex flex-wrap items-center gap-3\" data-kid=\"51\">\n        <div class=\"relative\" data-kid=\"52\">\n          <select class=\"appearance-none bg-[var(--k-color-bg-surface-hover)] border border-[var(--k-color-border-hover)] text-sm font-bold px-5 py-3 pr-12 rounded-xl focus:outline-none focus:border-[var(--k-color-primary)]/50 hover:transition-all\" data-kid=\"53\">\n            <option data-kid=\"54\">All Payment Methods</option>\n            <option data-kid=\"55\">Commercial Bank of Ethiopia (CBE)</option>\n            <option data-kid=\"56\">Telebirr</option>\n            <option data-kid=\"57\">Bank of Abyssinia</option>\n          </select>\n          <i class=\"ti ti-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-[var(--k-color-text-muted)] pointer-events-none\" data-kid=\"58\"></i>\n        </div>\n        <div class=\"relative\" data-kid=\"59\">\n          <input type=\"text\" placeholder=\"Amount (ETB)\" class=\"bg-[var(--k-color-bg-surface-hover)] border border-[var(--k-color-border-hover)] text-sm font-bold px-5 py-3 rounded-xl focus:outline-none focus:border-[var(--k-color-primary)]/50 transition-all placeholder:text-[var(--k-color-text-muted)] w-48\" data-kid=\"60\">\n        </div>\n        <button class=\"w-12 h-12 rounded-xl bg-[var(--k-color-bg-surface-hover)] border border-[var(--k-color-border-hover)] flex items-center justify-center hover:border-[var(--k-color-primary)]/30 transition-all\" data-kid=\"61\">\n          <i class=\"ti ti-adjustments-horizontal text-xl text-[var(--k-color-text-secondary)]\" data-kid=\"62\"></i>\n        </button>\n      </div>\n    </div>\n\n    \n    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\" data-kid=\"63\">\n      \n      \n      <div class=\"ticket-stub group hover:border-[var(--k-color-primary)]/30 transition-all\" data-kid=\"64\">\n        <div class=\"flex h-full\" data-kid=\"65\">\n          \n          <div class=\"w-1/3 p-6 dashed-line flex flex-col items-center justify-center text-center\" data-kid=\"66\">\n            <div class=\"relative mb-3\" data-kid=\"67\">\n              <div class=\"w-16 h-16 bg-gradient-to-br from-[var(--k-color-bg-surface)] to-[var(--k-color-border)] hexagon-avatar flex items-center justify-center border border-[var(--k-color-primary)]/20\" data-kid=\"68\">\n                <img src=\"https://i.pravatar.cc/100?u=abebe\" alt=\"Avatar\" class=\"w-14 h-14 hexagon-avatar object-cover\" data-kid=\"69\">\n              </div>\n              <div class=\"absolute -bottom-1 -right-1 w-5 h-5 bg-[var(--k-color-secondary)] rounded-full border-2 border-[var(--k-color-bg-page)] flex items-center justify-center\" data-kid=\"70\">\n                <i class=\"ti ti-check text-[10px] text-black font-bold\" data-kid=\"71\"></i>\n              </div>\n            </div>\n            <h3 class=\"font-bold text-sm mb-1\" data-kid=\"72\">Abebe_Ethio</h3>\n            <div class=\"flex items-center gap-0.5 text-[var(--k-color-primary)] mb-1\" data-kid=\"73\">\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"74\"></i>\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"75\"></i>\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"76\"></i>\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"77\"></i>\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"78\"></i>\n            </div>\n            <span class=\"text-[10px] text-[var(--k-color-text-muted)] font-extrabold uppercase tracking-tight\" data-kid=\"79\">98% (420 Trades)</span>\n          </div>\n\n          \n          <div class=\"flex-1 p-6 flex flex-col justify-between\" data-kid=\"80\">\n            <div data-kid=\"81\">\n              <div class=\"flex items-center justify-between mb-2\" data-kid=\"82\">\n                <span class=\"text-[var(--k-color-text-muted)] text-[10px] font-extrabold uppercase tracking-widest\" data-kid=\"83\">Rate</span>\n                <span class=\"px-2 py-0.5 bg-[var(--k-color-secondary)]/10 text-[var(--k-color-secondary)] text-[9px] font-extrabold rounded uppercase border border-[var(--k-color-secondary)]/20\" data-kid=\"84\">BEST PRICE</span>\n              </div>\n              <div class=\"font-mono flex items-baseline gap-1 mb-4\" data-kid=\"85\">\n                <span class=\"text-3xl font-extrabold text-[var(--k-color-primary)]\" data-kid=\"86\">124.50</span>\n                <span class=\"text-xs text-[var(--k-color-text-muted)] font-bold\" data-kid=\"87\">ETB/USD</span>\n              </div>\n              <div class=\"space-y-1.5 mb-6 text-[11px]\" data-kid=\"88\">\n                <div class=\"flex justify-between\" data-kid=\"89\">\n                  <span class=\"text-[var(--k-color-text-muted)] font-bold\" data-kid=\"90\">LIMITS</span>\n                  <span class=\"font-extrabold\" data-kid=\"91\">5,000 - 150k ETB</span>\n                </div>\n                <div class=\"flex justify-between\" data-kid=\"92\">\n                  <span class=\"text-[var(--k-color-text-muted)] font-bold\" data-kid=\"93\">PAYMENT</span>\n                  <span class=\"font-extrabold text-[var(--k-color-secondary)]\" data-kid=\"94\">TELEBIRR, CBE</span>\n                </div>\n              </div>\n            </div>\n            <button class=\"w-full py-3 bg-[var(--k-color-primary)] text-[var(--k-color-bg-page)] font-extrabold rounded-xl hover:opacity-90 transition-all uppercase tracking-widest text-xs\" data-kid=\"95\">\n              BUY USDT\n            </button>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"ticket-stub group hover:border-[var(--k-color-primary)]/30 transition-all\" data-kid=\"96\">\n        <div class=\"flex h-full\" data-kid=\"97\">\n          <div class=\"w-1/3 p-6 dashed-line flex flex-col items-center justify-center text-center\" data-kid=\"98\">\n            <div class=\"relative mb-3\" data-kid=\"99\">\n              <div class=\"w-16 h-16 bg-gradient-to-br from-[var(--k-color-bg-surface)] to-[var(--k-color-border)] hexagon-avatar flex items-center justify-center border border-[var(--k-color-primary)]/20\" data-kid=\"100\">\n                <img src=\"https://i.pravatar.cc/100?u=selam\" alt=\"Avatar\" class=\"w-14 h-14 hexagon-avatar object-cover\" data-kid=\"101\">\n              </div>\n            </div>\n            <h3 class=\"font-bold text-sm mb-1\" data-kid=\"102\">Selam_Crypto</h3>\n            <div class=\"flex items-center gap-0.5 text-[var(--k-color-primary)] mb-1\" data-kid=\"103\">\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"104\"></i>\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"105\"></i>\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"106\"></i>\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"107\"></i>\n              <i class=\"ti ti-star-half-filled text-[10px]\" data-kid=\"108\"></i>\n            </div>\n            <span class=\"text-[10px] text-[var(--k-color-text-muted)] font-extrabold uppercase tracking-tight\" data-kid=\"109\">94% (128 Trades)</span>\n          </div>\n          <div class=\"flex-1 p-6 flex flex-col justify-between\" data-kid=\"110\">\n            <div data-kid=\"111\">\n              <div class=\"flex items-center justify-between mb-2\" data-kid=\"112\">\n                <span class=\"text-[var(--k-color-text-muted)] text-[10px] font-extrabold uppercase tracking-widest\" data-kid=\"113\">Rate</span>\n              </div>\n              <div class=\"font-mono flex items-baseline gap-1 mb-4\" data-kid=\"114\">\n                <span class=\"text-3xl font-extrabold text-[var(--k-color-primary)]\" data-kid=\"115\">125.10</span>\n                <span class=\"text-xs text-[var(--k-color-text-muted)] font-bold\" data-kid=\"116\">ETB/USD</span>\n              </div>\n              <div class=\"space-y-1.5 mb-6 text-[11px]\" data-kid=\"117\">\n                <div class=\"flex justify-between\" data-kid=\"118\">\n                  <span class=\"text-[var(--k-color-text-muted)] font-bold\" data-kid=\"119\">LIMITS</span>\n                  <span class=\"font-extrabold\" data-kid=\"120\">10k - 500k ETB</span>\n                </div>\n                <div class=\"flex justify-between\" data-kid=\"121\">\n                  <span class=\"text-[var(--k-color-text-muted)] font-bold\" data-kid=\"122\">PAYMENT</span>\n                  <span class=\"font-extrabold text-[var(--k-color-secondary)]\" data-kid=\"123\">ABYSSINIA, CBE</span>\n                </div>\n              </div>\n            </div>\n            <button class=\"w-full py-3 bg-[var(--k-color-primary)] text-[var(--k-color-bg-page)] font-extrabold rounded-xl hover:opacity-90 transition-all uppercase tracking-widest text-xs\" data-kid=\"124\">\n              BUY USDT\n            </button>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"ticket-stub group hover:border-[var(--k-color-primary)]/30 transition-all\" data-kid=\"125\">\n        <div class=\"flex h-full\" data-kid=\"126\">\n          <div class=\"w-1/3 p-6 dashed-line flex flex-col items-center justify-center text-center\" data-kid=\"127\">\n            <div class=\"relative mb-3\" data-kid=\"128\">\n              <div class=\"w-16 h-16 bg-gradient-to-br from-[var(--k-color-bg-surface)] to-[var(--k-color-border)] hexagon-avatar flex items-center justify-center border border-[var(--k-color-primary)]/20\" data-kid=\"129\">\n                <img src=\"https://i.pravatar.cc/100?u=merchant\" alt=\"Avatar\" class=\"w-14 h-14 hexagon-avatar object-cover\" data-kid=\"130\">\n              </div>\n              <div class=\"absolute -bottom-1 -right-1 w-5 h-5 bg-indigo-500 rounded-full border-2 border-[var(--k-color-bg-page)] flex items-center justify-center\" data-kid=\"131\">\n                <i class=\"ti ti-crown text-[10px] text-white\" data-kid=\"132\"></i>\n              </div>\n            </div>\n            <h3 class=\"font-bold text-sm mb-1\" data-kid=\"133\">EthioMerchant</h3>\n            <div class=\"flex items-center gap-0.5 text-[var(--k-color-primary)] mb-1\" data-kid=\"134\">\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"135\"></i>\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"136\"></i>\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"137\"></i>\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"138\"></i>\n              <i class=\"ti ti-star-filled text-[10px]\" data-kid=\"139\"></i>\n            </div>\n            <span class=\"text-[10px] text-[var(--k-color-text-muted)] font-extrabold uppercase tracking-tight\" data-kid=\"140\">100% (2.4k Trades)</span>\n          </div>\n          <div class=\"flex-1 p-6 flex flex-col justify-between\" data-kid=\"141\">\n            <div data-kid=\"142\">\n              <div class=\"flex items-center justify-between mb-2\" data-kid=\"143\">\n                <span class=\"text-[var(--k-color-text-muted)] text-[10px] font-extrabold uppercase tracking-widest\" data-kid=\"144\">Rate</span>\n                <span class=\"px-2 py-0.5 bg-indigo-500/10 text-indigo-400 text-[9px] font-extrabold rounded uppercase border border-indigo-500/20\" data-kid=\"145\">VERIFIED</span>\n              </div>\n              <div class=\"font-mono flex items-baseline gap-1 mb-4\" data-kid=\"146\">\n                <span class=\"text-3xl font-extrabold text-[var(--k-color-primary)]\" data-kid=\"147\">126.00</span>\n                <span class=\"text-xs text-[var(--k-color-text-muted)] font-bold\" data-kid=\"148\">ETB/USD</span>\n              </div>\n              <div class=\"space-y-1.5 mb-6 text-[11px]\" data-kid=\"149\">\n                <div class=\"flex justify-between\" data-kid=\"150\">\n                  <span class=\"text-[var(--k-color-text-muted)] font-bold\" data-kid=\"151\">LIMITS</span>\n                  <span class=\"font-extrabold\" data-kid=\"152\">100 - 1M ETB</span>\n                </div>\n                <div class=\"flex justify-between\" data-kid=\"153\">\n                  <span class=\"text-[var(--k-color-text-muted)] font-bold\" data-kid=\"154\">PAYMENT</span>\n                  <span class=\"font-extrabold text-[var(--k-color-secondary)]\" data-kid=\"155\">ALL LOCAL BANKS</span>\n                </div>\n              </div>\n            </div>\n            <button class=\"w-full py-3 bg-[var(--k-color-primary)] text-[var(--k-color-bg-page)] font-extrabold rounded-xl hover:opacity-90 transition-all uppercase tracking-widest text-xs\" data-kid=\"156\">\n              BUY USDT\n            </button>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </main>\n\n  \n  <div class=\"md:hidden fixed bottom-6 left-6 right-6 z-50\" data-kid=\"157\">\n    <div class=\"bg-[var(--k-color-bg-surface)]/90 backdrop-blur-xl border border-[var(--k-color-border)] p-2 rounded-2xl flex items-center justify-around shadow-2xl\" data-kid=\"158\">\n      <button class=\"flex flex-col items-center gap-1 text-[var(--k-color-primary)]\" data-kid=\"159\">\n        <i class=\"ti ti-shopping-cart text-2xl\" data-kid=\"160\"></i>\n        <span class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"161\">Trade</span>\n      </button>\n      <button class=\"flex flex-col items-center gap-1 text-[var(--k-color-text-secondary)]\" data-kid=\"162\">\n        <i class=\"ti ti-wallet text-2xl\" data-kid=\"163\"></i>\n        <span class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"164\">Wallet</span>\n      </button>\n      <button class=\"flex flex-col items-center gap-1 text-[var(--k-color-text-secondary)] relative\" data-kid=\"165\">\n        <i class=\"ti ti-shield-lock text-2xl\" data-kid=\"166\"></i>\n        <span class=\"absolute -top-1 -right-1 w-4 h-4 bg-[var(--k-color-primary)] text-black text-[9px] font-bold rounded-full flex items-center justify-center\" data-kid=\"167\">3</span>\n        <span class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"168\">Active</span>\n      </button>\n      <button class=\"flex flex-col items-center gap-1 text-[var(--k-color-text-secondary)]\" data-kid=\"169\">\n        <i class=\"ti ti-user text-2xl\" data-kid=\"170\"></i>\n        <span class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"171\">Profile</span>\n      </button>\n    </div>\n  </div>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"172\"></script>\n<script data-kid=\"173\">\n  window.addEventListener('DOMContentLoaded', () => {\n    gsap.from(\"header\", { y: -100, opacity: 0, duration: 1, ease: \"power4.out\" });\n    gsap.from(\"nav\", { y: 20, opacity: 0, duration: 1, delay: 0.2, ease: \"power4.out\" });\n    gsap.from(\".ticket-stub\", { \n      y: 40, \n      opacity: 0, \n      duration: 0.8, \n      stagger: 0.1, \n      delay: 0.4, \n      ease: \"back.out(1.2)\" \n    });\n  });\n</script>",
