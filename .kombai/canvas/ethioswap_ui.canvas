      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: 'Manrope', sans-serif; background: #010B13; color: #e8edf5; min-height: 100vh; }\n  h1, h2, h3, h4, h5 { font-family: 'Space Grotesk', sans-serif; }\n\n  /* Navbar */\n  .navbar {\n    position: sticky; top: 0; z-index: 50;\n    background: rgba(1, 11, 19, 0.85);\n    backdrop-filter: blur(16px);\n    border-bottom: 1px solid rgba(0, 212, 160, 0.15);\n    padding: 0 32px;\n    height: 64px;\n    display: flex; align-items: center; gap: 24px;\n  }\n  .navbar-logo { display: flex; align-items: center; gap: 8px; text-decoration: none; }\n  .navbar-logo-icon { width: 34px; height: 34px; background: linear-gradient(135deg, #FFD700, #e6a800); border-radius: 8px; display: flex; align-items: center; justify-content: center; }\n  .navbar-logo-text { font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 700; color: #fff; }\n  .navbar-logo-text span { color: #FFD700; }\n  .navbar-search { flex: 1; max-width: 380px; position: relative; }\n  .navbar-search input { width: 100%; background: #0d1520; border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 8px 16px 8px 38px; font-size: 13px; color: #e8edf5; outline: none; font-family: 'Manrope', sans-serif; }\n  .navbar-search input::placeholder { color: #4a6380; }\n  .navbar-search .search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #4a6380; font-size: 15px; }\n  .navbar-actions { margin-left: auto; display: flex; align-items: center; gap: 16px; }\n  .notif-btn { position: relative; width: 38px; height: 38px; background: #0d1520; border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; display: flex; align-items: center; justify-content: center; cursor: pointer; }\n  .notif-btn i { font-size: 18px; color: #8ba0b8; }\n  .notif-badge { position: absolute; top: 6px; right: 6px; width: 8px; height: 8px; background: #FFD700; border-radius: 50%; border: 2px solid #010B13; }\n  .user-chip { display: flex; align-items: center; gap: 8px; background: #0d1520; border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 5px 12px 5px 5px; cursor: pointer; }\n  .user-chip img { width: 28px; height: 28px; border-radius: 8px; object-fit: cover; }\n  .user-chip span { font-size: 13px; font-weight: 600; color: #e8edf5; }\n  .nav-links { display: flex; gap: 4px; }\n  .nav-link { padding: 6px 14px; font-size: 13px; font-weight: 500; color: #8ba0b8; border-radius: 8px; cursor: pointer; }\n  .nav-link.active { color: #FFD700; background: rgba(255, 215, 0, 0.08); }\n\n  /* Page content */\n  .page-content { padding: 28px 32px 48px; max-width: 1216px; margin: 0 auto; }\n\n  /* Page header */\n  .page-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 28px; }\n  .page-header-left h1 { font-size: 26px; font-weight: 700; color: #fff; margin-bottom: 4px; }\n  .page-header-left p { font-size: 14px; color: #4a6380; }\n  .btn-post-ad { display: flex; align-items: center; gap: 7px; background: linear-gradient(135deg, #FFD700, #e6a800); color: #010B13; font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 700; padding: 10px 20px; border-radius: 10px; border: none; cursor: pointer; }\n\n  /* Buy/Sell toggle + filters */\n  .filters-row { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; flex-wrap: wrap; }\n  .buy-sell-toggle { display: flex; background: #0d1520; border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 4px; }\n  .toggle-btn { padding: 8px 28px; border-radius: 8px; font-family: 'Space Grotesk', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; border: none; }\n  .toggle-btn.buy.active { background: linear-gradient(135deg, #FFD700, #e6a800); color: #010B13; }\n  .toggle-btn.sell { background: transparent; color: #4a6380; }\n  .filter-chips { display: flex; gap: 8px; flex-wrap: wrap; }\n  .chip { padding: 7px 14px; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; border: 1px solid rgba(255,255,255,0.08); background: #0d1520; color: #8ba0b8; }\n  .chip.active { background: rgba(0, 212, 160, 0.12); border-color: #00d4a0; color: #00d4a0; }\n  .amount-filter { margin-left: auto; display: flex; align-items: center; gap: 8px; }\n  .amount-filter label { font-size: 12px; color: #4a6380; white-space: nowrap; }\n  .amount-filter input { background: #0d1520; border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 7px 12px; font-size: 13px; color: #e8edf5; outline: none; width: 140px; font-family: 'Manrope', sans-serif; }\n\n  /* Listings */\n  .listings-list { display: flex; flex-direction: column; gap: 12px; }\n\n  .listing-card {\n    background: #0d1520;\n    border: 1px solid rgba(255,255,255,0.07);\n    border-radius: 16px;\n    padding: 18px 22px;\n    display: flex;\n    align-items: center;\n    gap: 20px;\n  }\n  .listing-card.featured {\n    border-color: rgba(255, 215, 0, 0.4);\n    box-shadow: 0 0 0 1px rgba(255,215,0,0.15), 0 4px 24px rgba(255,215,0,0.08);\n  }\n  .featured-badge {\n    display: inline-flex; align-items: center; gap: 4px;\n    background: rgba(255,215,0,0.12); color: #FFD700;\n    font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 6px;\n    border: 1px solid rgba(255,215,0,0.25); margin-bottom: 4px;\n    letter-spacing: 0.5px;\n  }\n\n  /* Merchant section */\n  .merchant { display: flex; align-items: center; gap: 12px; min-width: 200px; }\n  .hex-avatar { width: 46px; height: 46px; border-radius: 12px; object-fit: cover; border: 2px solid rgba(0,212,160,0.3); }\n  .merchant-info { display: flex; flex-direction: column; gap: 3px; }\n  .merchant-name { font-size: 14px; font-weight: 700; color: #e8edf5; font-family: 'Space Grotesk', sans-serif; }\n  .merchant-meta { display: flex; align-items: center; gap: 6px; }\n  .star-rating { display: flex; align-items: center; gap: 3px; font-size: 12px; color: #FFD700; font-weight: 600; }\n  .trade-count { font-size: 11px; color: #4a6380; }\n  .badge-verified { display: inline-flex; align-items: center; gap: 3px; background: rgba(0,212,160,0.1); color: #00d4a0; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 5px; border: 1px solid rgba(0,212,160,0.25); }\n\n  /* Divider */\n  .card-divider { width: 1px; height: 52px; background: rgba(255,255,255,0.07); flex-shrink: 0; }\n\n  /* Price section */\n  .price-section { flex: 1; display: flex; flex-direction: column; gap: 4px; padding: 0 16px; }\n  .eth-amount { font-size: 20px; font-weight: 700; color: #fff; font-family: 'Space Grotesk', sans-serif; }\n  .eth-amount span { font-size: 13px; color: #8ba0b8; font-weight: 500; margin-left: 4px; }\n  .price-per { font-size: 13px; color: #4a6380; }\n  .price-per strong { color: #FFD700; }\n  .limits { display: flex; align-items: center; gap: 6px; margin-top: 4px; }\n  .limit-chip { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 6px; padding: 3px 8px; font-size: 11px; color: #8ba0b8; }\n\n  /* Payment + actions section */\n  .action-section { display: flex; flex-direction: column; align-items: flex-end; gap: 10px; min-width: 180px; }\n  .payment-methods { display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end; }\n  .payment-chip { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.09); border-radius: 6px; padding: 4px 9px; font-size: 11px; color: #8ba0b8; font-weight: 500; }\n  .btn-buy { background: linear-gradient(135deg, #FFD700, #e6a800); color: #010B13; font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 700; padding: 9px 22px; border-radius: 9px; border: none; cursor: pointer; white-space: nowrap; }\n  .btn-sell { background: transparent; color: #00d4a0; font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 700; padding: 9px 22px; border-radius: 9px; border: 1px solid rgba(0,212,160,0.4); cursor: pointer; white-space: nowrap; }\n\n  /* Results info row */\n  .results-info { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }\n  .results-count { font-size: 13px; color: #4a6380; }\n  .results-count strong { color: #e8edf5; }\n  .sort-control { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #4a6380; }\n  .sort-select { background: #0d1520; border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 5px 10px; color: #e8edf5; font-size: 12px; outline: none; }\n\n  /* Pagination */\n  .pagination { display: flex; align-items: center; justify-content: center; gap: 6px; margin-top: 28px; }\n  .page-btn { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 9px; font-size: 13px; font-weight: 600; cursor: pointer; border: 1px solid rgba(255,255,255,0.08); background: #0d1520; color: #8ba0b8; }\n  .page-btn.active { background: rgba(255,215,0,0.12); border-color: rgba(255,215,0,0.4); color: #FFD700; }\n  .page-btn.nav { font-size: 16px; }\n</style>\n\n\n<div class=\"navbar\" data-kid=\"1\">\n  <a class=\"navbar-logo\" href=\"#\" data-kid=\"2\">\n    <div class=\"navbar-logo-icon\" data-kid=\"3\">\n      <i class=\"ti ti-shield-check\" style=\"font-size:18px;color:#010B13;\" data-kid=\"4\"></i>\n    </div>\n    <span class=\"navbar-logo-text\" data-kid=\"5\">Ethio<span data-kid=\"6\">Swap</span></span>\n  </a>\n  <div class=\"nav-links\" data-kid=\"7\">\n    <span class=\"nav-link\" data-kid=\"8\">Home</span>\n    <span class=\"nav-link active\" data-kid=\"9\">P2P Market</span>\n    <span class=\"nav-link\" data-kid=\"10\">Trade Room</span>\n    <span class=\"nav-link\" data-kid=\"11\">Wall