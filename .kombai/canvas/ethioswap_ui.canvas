           <span style=\"font-size:13px;font-weight:700;color:#00d4a0;\" data-kid=\"145\">+ETB 13,570</span>\n          </div>\n\n          <div style=\"display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #1a2840;\" data-kid=\"146\">\n            <div style=\"width:36px;height:36px;background:rgba(255,215,0,0.1);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\" data-kid=\"147\">\n              <i class=\"ti ti-arrow-up-right\" style=\"color:#FFD700;font-size:18px;\" data-kid=\"148\"></i>\n            </div>\n            <div style=\"flex:1;\" data-kid=\"149\">\n              <div style=\"font-size:13px;font-weight:600;color:#e2e8f0;\" data-kid=\"150\">ETH Deposit</div>\n              <div style=\"font-size:11px;color:#4a6380;\" data-kid=\"151\">From wallet 0x3f…8a2e · June 2</div>\n            </div>\n            <span style=\"font-size:13px;font-weight:700;color:#FFD700;\" data-kid=\"152\">+0.12 ETH</span>\n          </div>\n\n          <div style=\"display:flex;align-items:center;gap:12px;padding:10px 0;\" data-kid=\"153\">\n            <div style=\"width:36px;height:36px;background:rgba(239,68,68,0.1);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;\" data-kid=\"154\">\n              <i class=\"ti ti-receipt\" style=\"color:#ef4444;font-size:18px;\" data-kid=\"155\"></i>\n            </div>\n            <div style=\"flex:1;\" data-kid=\"156\">\n              <div style=\"font-size:13px;font-weight:600;color:#e2e8f0;\" data-kid=\"157\">Trade Fee</div>\n              <div style=\"font-size:11px;color:#4a6380;\" data-kid=\"158\">0.5% on trade #TRD-2831 · June 1</div>\n            </div>\n            <span style=\"font-size:13px;font-weight:700;color:#ef4444;\" data-kid=\"159\">-ETB 67</span>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div style=\"display:flex;flex-direction:column;gap:16px;\" data-kid=\"160\">\n\n      \n      <d