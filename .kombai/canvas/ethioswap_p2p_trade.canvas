      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  :root {\n    --bg: #0B0E1A;\n    --surface: #141827;\n    --surface-light: #1E2640;\n    --gold: #F5A623;\n    --gold-bright: #FFD700;\n    --gold-glow: rgba(245, 166, 35, 0.25);\n    --text-primary: #FFFFFF;\n    --text-secondary: #8A9BB8;\n    --border: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    background-color: var(--bg);\n    color: var(--text-primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    padding: 0;\n  }\n\n  .glass-card {\n    background: rgba(20, 24, 39, 0.6);\n    backdrop-filter: blur(12px);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n  }\n\n  .gold-gradient {\n    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-bright) 100%);\n  }\n\n  .gold-text-gradient {\n    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-bright) 100%);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .glow-gold {\n    box-shadow: 0 0 20px var(--gold-glow);\n  }\n\n  .nav-link {\n    color: var(--text-secondary);\n    transition: all 0.2s;\n  }\n\n  .nav-link:hover, .nav-link.active {\n    color: var(--gold);\n  }\n\n  .btn-gold {\n    background: linear-gradient(135deg, var(--gold), var(--gold-bright));\n    color: #0A0E1A;\n    font-weight: 700;\n    transition: all 0.2s;\n  }\n\n  .btn-gold:hover {\n    transform: translateY(-1px);\n    box-shadow: 0 4px 15px rgba(245, 166, 35, 0.4);\n  }\n\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 6px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: var(--bg);\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: var(--surface-light);\n    border-radius: 3px;\n  }\n\n  @keyframes pulse-gold {\n    0% { box-shadow: 0 0 0 0 rgba(245, 166, 35, 0.4); }\n    70% { box-shadow: 0 0 0 10px rgba(245, 166, 35, 0); }\n    100% { box-shadow: 0 0 0 0 rgba(245, 166, 35, 0); }\n  }\n</style>\n\n<div class=\"min-h-screen flex flex-col\" data-kid=\"1\">\n  \n  <header class=\"h-20 border-b border-[var(--border)] bg-[var(--bg)] sticky top-0 z-50\" data-kid=\"2\">\n    <div class=\"max-w-[1400px] mx-auto h-full px-6 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-10\" data-kid=\"4\">\n        <div class=\"flex items-center gap-2\" data-kid=\"5\">\n          <div class=\"w-10 h-10 gold-gradient rounded-xl flex items-center justify-center shadow-lg\" data-kid=\"6\">\n            <span class=\"text-[#0A0E1A] font-black text-xl italic\" data-kid=\"7\">E</span>\n          </div>\n          <span class=\"text-xl font-extrabold tracking-tight\" data-kid=\"8\">Ethio<span class=\"gold-text-gradient\" data-kid=\"9\">Swap</span></span>\n        </div>\n        \n        <nav class=\"hidden md:flex items-center gap-8\" data-kid=\"10\">\n          <a href=\"#\" class=\"nav-link active font-semibold\" data-kid=\"11\">Trade</a>\n          <a href=\"#\" class=\"nav-link font-medium\" data-kid=\"12\">Wallet</a>\n          <a href=\"#\" class=\"nav-link font-medium\" data-kid=\"13\">History</a>\n          <a href=\"#\" class=\"nav-link font-medium\" data-kid=\"14\">Support</a>\n        </nav>\n      </div>\n\n      <div class=\"flex items-center gap-6\" data-kid=\"15\">\n        <div class=\"flex flex-col items-end\" data-kid=\"16\">\n          <span class=\"text-[10px] uppercase tracking-widest text-[var(--text-secondary)] font-bold\" data-kid=\"17\">Total Balance</span>\n          <div class=\"flex items-center gap-2\" data-kid=\"18\">\n            <span class=\"text-[var(--gold)] font-['JetBrains_Mono'] font-bold text-lg\" data-kid=\"19\">$2,450.85</span>\n            <span class=\"text-xs font-medium text-[var(--text-secondary)]\" data-kid=\"20\">USD</s