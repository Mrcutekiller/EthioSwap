      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  :root {\n    --bg: #0B0E1A;\n    --surface: #141827;\n    --surface-light: #1E2640;\n    --gold: #F5A623;\n    --gold-bright: #FFD700;\n    --gold-glow: rgba(245, 166, 35, 0.25);\n    --gold-neon: rgba(245, 166, 35, 0.6);\n    --text-primary: #FFFFFF;\n    --text-secondary: #8A9BB8;\n    --border: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    background-color: var(--bg);\n    color: var(--text-primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    padding: 0;\n    padding-bottom: 90px;\n  }\n\n  .glass-card {\n    background: rgba(20, 24, 39, 0.6);\n    backdrop-filter: blur(12px);\n    border: 1px solid var(--border);\n    border-radius: 20px;\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .glass-card:active {\n    border-color: var(--gold);\n    box-shadow: 0 0 20px var(--gold-glow);\n    transform: scale(0.99);\n  }\n\n  .gold-gradient {\n    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-bright) 100%);\n  }\n\n  .gold-text-gradient {\n    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-bright) 100%);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .btn-gold {\n    background: linear-gradient(135deg, var(--gold), var(--gold-bright));\n    color: #0A0E1A;\n    font-weight: 800;\n    box-shadow: 0 4px 15px rgba(245, 166, 35, 0.2);\n  }\n\n  @keyframes neon-pulse {\n    0%, 100% { \n      box-shadow: 0 0 15px var(--gold-neon), 0 0 5px var(--gold); \n      transform: translate(-50%, -50%) scale(1);\n    }\n    50% { \n      box-shadow: 0 0 30px var(--gold-neon), 0 0 10px var(--gold-bright); \n      transform: translate(-50%, -50%) scale(1.05);\n    }\n  }\n\n  .neon-post-btn {\n    position: absolute;\n    left: 50%;\n    top: -20px;\n    transform: translateX(-50%);\n    width: 60px;\n    height: 60px;\n    background: rgba(245, 166, 35, 0.15);\n    backdrop-filter: blur(12px);\n    border: 2px solid var(--gold);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    z-index: 100;\n    animation: neon-pulse 2s infinite ease-in-out;\n    box-shadow: inset 0 0 10px rgba(255, 255, 255, 0.2);\n  }\n\n  .neon-post-btn i {\n    font-size: 28px;\n    color: var(--gold-bright);\n    text-shadow: 0 0 10px var(--gold);\n  }\n\n  .bottom-nav {\n    background: rgba(13, 17, 23, 0.85);\n    backdrop-filter: blur(25px);\n    -webkit-backdrop-filter: blur(25px);\n    border-top: 1px solid var(--border);\n  }\n\n  .stat-badge {\n    background: rgba(255, 255, 255, 0.03);\n    border: 1px solid var(--border);\n    border-radius: 6px;\n    padding: 2px 6px;\n  }\n\n  .font-mono {\n    font-family: 'JetBrains Mono', monospace;\n  }\n</style>\n\n<div class=\"flex flex-col min-h-screen\" data-kid=\"1\">\n  \n  <header class=\"px-5 py-5 border-b border-[var(--border)] bg-[var(--bg)] flex items-center justify-between sticky top-0 z-50\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <div class=\"w-9 h-9 gold-gradient rounded-xl flex items-center justify-center shadow-lg\" data-kid=\"4\">\n        <span class=\"text-[#0A0E1A] font-black text-xl italic\" data-kid=\"5\">E</span>\n      </div>\n      <span class=\"text-xl font-extrabold tracking-tight\" data-kid=\"6\">Ethio<span class=\"gold-text-gradient\" data-kid=\"7\">Swap</span></span>\n    </div>\n    \n    <div class=\"flex items-center gap-3\" data-kid=\"8\">\n      <div class=\"flex flex-col items-end\" data-kid=\"9\">\n        <span class=\"text-[var(--gold)] font-mono font-bold text-base\" data-kid=\"10\">$2,450.85</span>\n        <span class=\"text-[8px] text-[var(--text-secondary)] font-bold uppercase tracking-widest\" data-kid=\"11\">Live Balance</span>\n      </div>\n      <div class=\"p-0.5 rounded-full gold-gradient\" data-kid=\"12\">\n        <img src=\"https://i.pravatar.cc/40?u=biruk\" class=\"w-8 h-8 rounded-full bg-[var(--bg)]\" alt=\"Profile\" data-kid=\"13\">\n      </div>\n    </div>\n  </header>\n\n  <main class=\"px-5 py-6 flex flex-col gap-6\" data-kid=\"14\">\n    \n    <div class=\"flex p-1.5 bg-[var(--surface)] rounded-2xl border border-[var(--border)] shadow-inner\" data-kid=\"15\">\n      <button class=\"flex-1 py-3 rounded-xl bg-[var(--gold)] text-[#0A0E1A] font-extrabold text-sm shadow-xl tracking-tight\" data-kid=\"16\">Buy USDT</button>\n      <button class=\"flex-1 py-3 rounded-xl text-[var(--text-secondary)] font-bold text-sm\" data-kid=\"17\">Sell USDT</button>\n    </div>\n\n    \n    <div class=\"flex flex-col gap-4\" data-kid=\"18\">\n      <div class=\"relative\" data-kid=\"19\">\n        <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-[var(--gold)]\" data-kid=\"20\"></i>\n        <input type=\"text\" placeholder=\"Search elite traders...\" class=\"w-full bg-[var(--surface)] border border-[var(--border)] rounded-2xl py-3.5 pl-11 pr-4 text-sm focus:outline-none focus:border-[var(--gold)]/30 transition-all font-medium\" data-kid=\"21\">\n      </div>\n\n      <div class=\"flex items-center gap-2.5 overflow-x-auto pb-1 scroll-smooth\" data-kid=\"22\">\n        <button class=\"px-5 py-2 rounded-full gold-gradient text-[#0A0E1A] text-[11px] font-black shadow-lg whitespace-nowrap\" data-kid=\"23\">Elite Methods</button>\n        <button class=\"px-5 py-2 rounded-full bg-[var(--surface)] border border-[var(--border)] text-[var(--text-secondary)] text-[11px] font-bold whitespace-nowrap\" data-kid=\"24\">Telebirr Pro</button>\n        <button class=\"px-5 py-2 rounded-full bg-[var(--surface)] border border-[var(--border)] text-[var(--text-secondary)] text-[11px] font-bold whitespace-nowrap\" data-kid=\"25\">CBE VIP</button>\n        <button 