      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n  :root {\n    --bg: #0B0E1A;\n    --surface: #141827;\n    --surface-light: #1E2640;\n    --gold: #F5A623;\n    --gold-bright: #FFD700;\n    --gold-glow: rgba(245, 166, 35, 0.25);\n    --text-primary: #FFFFFF;\n    --text-secondary: #8A9BB8;\n    --border: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    background-color: var(--bg);\n    color: var(--text-primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    padding: 0;\n    padding-bottom: 80px; /* Space for bottom nav */\n  }\n\n  .glass-card {\n    background: rgba(20, 24, 39, 0.6);\n    backdrop-filter: blur(12px);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n  }\n\n  .gold-gradient {\n    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-bright) 100%);\n  }\n\n  .gold-text-gradient {\n    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-bright) 100%);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n\n  .btn-gold {\n    background: linear-gradient(135deg, var(--gold), var(--gold-bright));\n    color: #0A0E1A;\n    font-weight: 700;\n  }\n\n  .custom-scrollbar::-webkit-scrollbar {\n    display: none;\n  }\n\n  .bottom-nav-blur {\n    background: rgba(13, 17, 23, 0.8);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n  }\n</style>\n\n<div class=\"flex flex-col min-h-screen\" data-kid=\"1\">\n  \n  <header class=\"px-5 py-4 border-b border-[var(--border)] bg-[var(--bg)] flex items-center justify-between sticky top-0 z-50\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <div class=\"w-8 h-8 gold-gradient rounded-lg flex items-center justify-center shadow-lg\" data-kid=\"4\">\n        <span class=\"text-[#0A0E1A] font-black text-lg italic\" data-kid=\"5\">E</span>\n      </div>\n      <span class=\"text-lg font-extrabold tracking-tight\" data-kid=\"6\">Ethio<span class=\"gold-text-gradient\" data-kid=\"7\">Swap</span></span>\n    </div>\n    \n    <div class=\"flex items-center gap-3\" data-kid=\"8\">\n      <div class=\"flex flex-col items-end mr-1\" data-kid=\"9\">\n        <span class=\"text-[var(--gold)] font-['JetBrains_Mono'] font-bold text-sm\" data-kid=\"10\">$2,450.85</span>\n        <span class=\"text-[8px] text-[var(--text-secondary)] font-bold uppercase tracking-widest\" data-kid=\"11\">USD Balance</span>\n      </div>\n      <img src=\"https://i.pravatar.cc/40?u=biruk\" class=\"w-8 h-8 rounded-full border border-[var(--gold)]\" alt=\"Profile\" data-kid=\"12\">\n    </div>\n  </header>\n\n  <main class=\"px-5 py-6 flex flex-col gap-6\" data-kid=\"13\">\n    \n    <section class=\"flex flex-col gap-3\" data-kid=\"14\">\n      <div class=\"glass-card p-4 flex items-center justify-between overflow-hidden relative\" data-kid=\"15\">\n        <div class=\"relative z-10\" data-kid=\"16\">\n          <span class=\"text-[10px] font-bold text-[var(--text-secondary)] uppercase tracking-wider\" data-kid=\"17\">Best Buy Rate</span>\n          <div class=\"mt-1 flex items-baseline gap-1.5\" data-kid=\"18\">\n            <span class=\"text-2xl font-['JetBrains_Mono'] font-extrabold text-[var(--gold)]\" data-kid=\"19\">125.50</span>\n            <span class=\"text-[10px] font-semibold text-[var(--text-secondary)]\" data-kid=\"20\">ETB/$</span>\n          </div>\n        </div>\n        <i class=\"ti ti-trending-up text-5xl absolute -right-2 -bottom-2 opacity-5\" data-kid=\"21\"></i>\n        <div class=\"px-2 py-0.5 bg-[#00C896]/10 rounded flex items-center gap-1.5 text-[8px] font-bold text-[#00C896]\" data-kid=\"22\">\n          <i class=\"ti ti-circle-filled text-[4px]\" data-kid=\"23\"></i> LIVE\n        </div>\n      </div>\n\n      <div class=\"glass-card p-4 flex items-center justify-between overflow-hidden relative\" data-kid=\"24\">\n        <div class=\"relative z-10\" data-kid=\"25\">\n          <span class=\"text-[10px] font-bold text-[var(--text-secondary)] uppercase tracking-wider\" data-kid=\"26\">Best Sell Rate</span>\n          <div class=\"mt-1 flex items-baseline gap-1.5\" data-kid=\"27\">\n            <span class=\"text-2xl font-['JetBrains_Mono'] font-extrabold text-white\" data-kid=\"28\">126.15</span>\n            <span class=\"text-[10px] font-semibold text-[var(--text-secondary)]\" data-kid=\"29\">ETB/$</span>\n          </div>\n        </div>\n        <i class=\"ti ti-trending-down text-5xl absolute -right-2 -bottom-2 opacity-5 text-[var(--gold)]\" data-kid=\"30\"></i>\n        <div class=\"px-2 py-0.5 bg-[var(--gold)]/10 rounded flex items-center gap-1.5 text-[8px] font-bold text-[var(--gold)]\" data-kid=\"31\">\n          <i class=\"ti ti-circle-filled text-[4px]\" data-kid=\"32\"></i> HOT\n        </div>\n      </div>\n    </section>\n\n    \n    <div class=\"flex p-1 bg-[var(--surface)] rounded-xl border border-[var(--border)]\" data-kid=\"33\">\n      <button class=\"flex-1 py-2.5 rounded-lg bg-[var(--gold)] text-[#0A0E1A] font-bold text-xs shadow-lg\" data-kid=\"34\">Buy USDT</button>\n      <button class=\"flex-1 py-2.5 rounded-lg text-[var(--text-secondary)] font-bold text-xs\" data-kid=\"35\">Sell USDT</button>\n    </div>\n\n    \n    <div class=\"flex flex-col gap-4\" data-kid=\"36\">\n      <div class=\"relative\" data-kid=\"37\">\n        <i class=\"ti ti-search absolute left-4 top-1/2 -translate-y-1/2 text-[var(--text-secondary)]\" data-kid=\"38\"></i>\n        <input type=\"text\" placeholder=\"Search by trader...\" class=\"w-full bg-[var(--surface)] border border-[var(--border)] rounded-xl py-3 pl-11 pr-4 text-xs focus:outline-none\" data-kid=\"39\">\n      </div>\n\n      <div class=\"flex items-center gap-2 overflow-x-auto pb-1 custom-scrollbar\" data-kid=\"40\">\n        <button class=\"px-4 py-1.5 rounded-full gold-gradient text-[#0A0E1A] text-[10px] font-bold shadow-md whitespace-nowrap\" data-kid=\"41\">All Payments</button>\n        <button class=\"px-4 py-1.5 rounded-full bg-[var(--surface)] border border-[var(--border)] text-[var(--text-secondary)] text-[10px] font-bold whitespace-nowrap\" data-kid=\"42\">Telebirr</button>\n        <button class=\"px-4 py-1.5 rounded-full bg-[var(--surface)] border border-[var(--border)] text-[var(--text-secondary)] text-[10px] font-bold whitespace-nowrap\" data-kid=\"43\">CBE Bank</button>\n        <button class=\"px-4 py-1.5 rounded-full bg-[var(--surface)] border border-[var(--border)] text-[var(--text-secondary)] text-[10px] font-bold whitespace-nowrap\" data-kid=\"44\">Dashen</button>\n      </div>\n    </div>\n\n    \n    <section class=\"flex flex-col gap-4\" data-kid=\"45\">\n      \n      <div class=\"glass-card p-5 flex flex-col gap-4\" data-kid=\"46\">\n        <div class=\"flex items-center justify-between\" data-kid=\"47\">\n          <div class=\"flex items-center gap-2.5\" data-kid=\"48\">\n            <div class=\"relative\" data-kid=\"49\">\n              <img src=\"https://i.pravatar.cc/100?u=dawit\" class=\"w-10 h-10 rounded-full border-2 border-[var(--gold)]\" data-kid=\"50\">\n              <div class=\"absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-[#00C896] border-2 border-[var(--bg)] rounded-full\" data-kid=\"51\"></div>\n            </div>\n            <div class=\"flex flex-col\" data-kid=\"52\">\n              <span class=\"text-xs font-bold\" data-kid=\"53\">@dawit_trade</span>\n              <div class=\"flex items-center gap-1\" data-kid=\"54\">\n                <span class=\"text-[8px] font-bold text-[var(--gold)] uppercase\" data-kid=\"55\">98.5% Rep</span>\n                <span class=\"text-[8px] text-[var(--text-secondary)]\" data-kid=\"56\">(1.2k)</span>\n              </div>\n            </div>\n          </div>\n          <span class=\"px-2 py-0.5 bg-[