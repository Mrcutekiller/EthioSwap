d=\"93\">\n          <span class=\"text-[var(--text-secondary)]\" data-kid=\"94\">Limit: 2k – 100k ETB</span>\n          <span class=\"text-white font-medium\" data-kid=\"95\">15m Window</span>\n        </div>\n\n        <div class=\"flex gap-2\" data-kid=\"96\">\n          <span class=\"px-2 py-0.5 bg-[#FF9100]/10 border border-[#FF9100]/20 rounded text-[9px] font-bold text-[#FFB74D]\" data-kid=\"97\">DASHEN</span>\n          <span class=\"px-2 py-0.5 bg-[#00C896]/10 border border-[#00C896]/20 rounded text-[9px] font-bold text-[#5DFCCB]\" data-kid=\"98\">M-PESA</span>\n        </div>\n\n        <button class=\"btn-gold w-full py-3 rounded-xl text-xs shadow-lg uppercase tracking-wider\" data-kid=\"99\">Buy USDT</button>\n      </div>\n    </section>\n  </main>\n\n  \n  <nav class=\"fixed bottom-0 left-0 right-0 h-16 bottom-nav-blur border-t border-[var(--border)] flex items-center justify-around px-2 z-50\" data-kid=\"100\">\n    <button class=\"flex flex-col items-center gap-1 text-[var(--gold)]\" data-kid=\"101\">\n      <i class=\"ti ti-arrows-left-right text-xl\" data-kid=\"102\"></i>\n      <span class=\"text-[8px] font-bold uppercase tracking-tighter\" data-kid=\"103\">Trade</span>\n    </button>\n    <button class=\"flex flex-col items-center gap-1 text-[var(--text-secondary)]\" data-kid=\"104\">\n      <i class=\"ti ti-wallet text-xl\" data-kid=\"105\"></i>\n      <span class=\"text-[8px] font-bold uppercase tracking-tighter\" data-kid=\"106\">Wallet</span>\n    </button>\n    \n    \n    <div class=\"relative\" data-kid=\"107\">\n      <button class=\"w-12 h-12 gold-gradient rounded-full flex items-center justify-center -mt-8 shadow-2xl border-4 border-[var(--bg)] transform active:scale-95 transition-transform\" data-kid=\"108\">\n        <i class=\"ti ti-plus text-[#0A0E1A] text-2xl font-bold\" data-kid=\"109\"></i>\n      </button>\n    </div>\n\n    <button class=\"flex flex-col items-center gap-1 text-[var(--text-secondary)]\" data-kid=\"110\">\n      <