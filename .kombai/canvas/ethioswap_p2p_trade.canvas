reate <span class=\"gold-text-gradient\" data-kid=\"172\">Listing</span></h3>\n            <div class=\"flex items-center gap-1.5 px-2.5 py-1 bg-[var(--gold)]/10 rounded-full\" data-kid=\"173\">\n              <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--gold)] animate-pulse\" data-kid=\"174\"></div>\n              <span class=\"text-[10px] font-bold text-[var(--gold)] uppercase\" data-kid=\"175\">Pro Mode</span>\n            </div>\n          </div>\n\n          <form class=\"flex flex-col gap-5\" data-kid=\"176\">\n            \n            <div class=\"flex flex-col gap-2\" data-kid=\"177\">\n              <label class=\"text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider\" data-kid=\"178\">I want to...</label>\n              <div class=\"flex p-1 bg-black/30 rounded-xl border border-[var(--border)]\" data-kid=\"179\">\n                <button type=\"button\" class=\"flex-1 py-2 rounded-lg bg-[var(--surface-light)] text-[var(--gold)] font-bold text-xs\" data-kid=\"180\">Sell USD</button>\n                <button type=\"button\" class=\"flex-1 py-2 rounded-lg text-[var(--text-secondary)] font-bold text-xs hover:text-white\" data-kid=\"181\">Buy USD</button>\n              </div>\n            </div>\n\n            \n            <div class=\"flex flex-col gap-2\" data-kid=\"182\">\n              <label class=\"text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider\" data-kid=\"183\">USD Amount</label>\n              <div class=\"relative\" data-kid=\"184\">\n                <input type=\"number\" placeholder=\"0.00\" class=\"w-full bg-black/30 border border-[var(--border)] rounded-xl py-3 pl-4 pr-14 text-sm font-['JetBrains_Mono'] focus:outline-none focus:border-[var(--gold)]/50\" data-kid=\"185\">\n                <span class=\"absolute right-4 top-1/2 -translate-y-1/2 text-xs font-bold text-[var(--text-secondary)]\" data-kid=\"186\">USD</span>\n              </div>\n            </div>\n\n            \n            <div class=\"flex flex-col gap-2\" data-kid=\"187\">\n              <label class=\"text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider\" data-kid=\"188\">Exchange Rate (ETB/$)</label>\n              <div class=\"relative\" data-kid=\"189\">\n                <input type=\"number\" value=\"125.80\" class=\"w-full bg-black/30 border border-[var(--border)] rounded-xl py-3 pl-4 pr-14 text-sm font-['JetBrains_Mono'] text-[var(--gold)] focus:outline-none focus:border-[var(--gold)]/50\" data-kid=\"190\">\n                <span class=\"absolute right-4 top-1/2 -translate-y-1/2 text-xs font-bold text-[var(--text-secondary)]\" data-kid=\"191\">ETB</span>\n              </div>\n              <p class=\"text-[10px] text-right text-[#00C896] font-medium\" data-kid=\"192\">+0.25% above market</p>\n            </div>\n\n            \n            <div class=\"flex flex-col gap-2\" data-kid=\"193\">\n              <label class=\"text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider\" data-kid=\"194\">Payment Methods</label>\n              <div class=\"grid grid-cols-2 gap-2\" data-kid=\"195\">\n                <label class=\"flex items-center gap-2 bg-black/20 p-2.5 rounded-lg border border-[var(--border)] cursor-pointer hover:border-[var(--gold)]/30 transition-all\" data-kid=\"196\">\n                  <input type=\"checkbox\" checked class=\"accent-[var(--gold)]\" data-kid=\"197\">\n                  <span class=\"text-[10px] font-bold\" data-kid=\"198\">Telebirr</span>\n                </label>\n                <label class=\"flex items-center gap-2 bg-black/20 p-2.5 rounded-lg border border-[var(--border)] cursor-pointer hover:border-[var(--gold)]/30 transition-all\" data-kid=\"199\">\n                  <input type=\"checkbox\" checked class=\"accent-[var(--gold)]\" data-kid=\"200\">\n                  <span class=\"text-[10px] font-bold\" data-kid=\"201\">CBE Bank</span>\n                </label>\n                <label class=\"flex items-center gap-2 bg-black/20 p-2.5 rounded-lg border border-[var(--border)] cursor-pointer hover:border-[var(--gold)]/30 transition-all\" data-kid=\"202\">\n                  <input type=\"checkbox\" class=\"accent-[var(--gold)]\" data-kid=\"203\">\n                  <span class=\"text-[10px] font-bold\" data-kid=\"204\">BOA Bank</span>\n                </label>\n                <label class=\"flex items-center gap-2 bg-black/20 p-2.5 rounded-lg border border-[var(--border)] cursor-pointer hover:border-[var(--gold)]/30 transition-all\" data-kid=\"205\">\n                  <input type=\"checkbox\" class=\"accent-[var(--gold)]\" data-kid=\"206\">\n                  <span class=\"text-[10px] font-bold\" data-kid=\"207\">M-Pesa</span>\n                </label>\n              </div>\n            </div>\n\n            \n            <div class=\"flex flex-col gap-2\" data-kid=\"208\">\n              <label class=\"text-xs font-bold text-[var(--text-secondary)] uppercase tracking-wider\" data-kid=\"209\">Trade Terms & Instructions</label>\n              <textarea placeholder=\"e.g. Only transfers from personal accounts. Fast release after payment.\" class=\"w-full bg-black/30 border border-[var(--border)] rounded-xl py-3 px-4 text-xs h-24 focus:outline-none focus:border-[var(--gold)]/50 custom-scrollbar resize-none\" data-kid=\"210\"></textarea>\n            </div>\n\n            <button type=\"submit\" class=\"btn-gold w-full py-4 rounded-xl mt-4 text-sm uppercase tracking-widest shadow-2xl overflow-hidden relative group\" data-kid=\"211\">\n              <span class=\"relative z-10\" data-kid=\"212\">Post Advertisement</span>\n              <div class=\"absolute inset-0 bg-white/10 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 skew-x-[-20deg]\" data-kid=\"213\"></div>\n            </button>\n          </form>\n        </div>\n\n        <div class=\"glass-card p-6 bg-gradient-to-br from-[#1E2640]/50 to-transparent\" data-kid=\"214\">\n          <h4 class=\"text-xs font-bold uppercase tracking-wider mb-4 flex items-center gap-2\" data-kid=\"215\">\n            <i class=\"ti ti-shield-check text-[var(--gold)]\" data-kid=\"216\"></i> Safety Reminder\n          </h4>\n          <ul class=\"flex flex-col gap-3\" data-kid=\"217\">\n            <li class=\"flex gap-3 items-start\" data-kid=\"218\">\n              <i class=\"ti ti-point-filled mt-1 text-[var(--gold)]\" data-kid=\"219\"></i>\n              <p class=\"text-[11px] text-[var(--text-secondary)] leading-relaxed\" data-kid=\"220\">Never release crypto before verifying the payment in your bank app.</p>\n            </li>\n            <li class=\"flex gap-3 items-start\" data-kid=\"221\">\n              <i class=\"ti ti-point-filled mt-1 text-[var(--gold)]\" data-kid=\"222\"></i>\n              <p class=\"text-[11px] text-[var(--text-secondary)] leading-relaxed\" data-kid=\"223\">Check if the sender's name matches the KYC name on EthioSwap.</p>\n            </li>\n          </ul>\n        </div>\n      </aside>\n\n    </div>\n  </main>\n\n  \n  <div class=\"md:hidden fixed bottom-0 left-0 right-0 h-16 bg-[#0D1117] border-t border-[var(--border)] flex items-center justify-around px-4 z-50\" data-kid=\"224\">\n    <button class=\"flex flex-col items-center gap-1 text-[var(--gold)]\" data-kid=\"225\">\n      <i class=\"ti ti-arrows-left-right text-xl\" data-kid=\"226\"></i>\n      <span class=\"text-[9px] font-bold\" data-kid=\"227\">Trade</span>\n    </button>\n    <button class=\"flex flex-col items-center gap-1 text-[var(--text-secondary)]\" data-kid=\"228\">\n      <i class=\"ti ti-wallet text-xl\" data-kid=\"229\"></i>\n      <span class=\"text-[9px] font-bold\" data-kid=\"230\">Wallet</span>\n    </button>\n    <button class=\"w-12 h-12 gold-gradient rounded-full flex items-center justify-center -mt-8 shadow-xl border-4 border-[#0B0E1A]\" data-kid=\"231\">\n      <i class=\"ti ti-plus text-[#0A0E1A] text-2xl font-bold\" data-kid=\"232\"></i>\n    </button>\n    <button class=\"flex flex-col items-center gap-1 text-[var(--text-secondary)]\" data-kid=\"233\">\n      <i class=\"ti ti-history text-xl\" data-kid=\"234\"></i>\n      <span class=\"text-[9px] font-bold\" data-kid=\"235\">History</span>\n    </button>\n    <button class=\"flex flex-col items-center gap-1 text-[var(--text-secondary)]\" data-kid=\"236\">\n      <i class=\"ti ti-user text-xl\" data-kid=\"237\"></i>\n      <span class=\"text-[9px] font-bold\" data-kid=\"238\">Profile</span>\n    </button>\n  </div>\n</div>",
